@model RevenueReportViewModel
@{
    ViewData["Title"] = "Báo cáo doanh thu";
    var labels = System.Text.Json.JsonSerializer.Serialize(Model.DataPoints.Select(d => d.Label));
    var revenuesM = System.Text.Json.JsonSerializer.Serialize(Model.DataPoints.Select(d => (double)d.Revenue / 1_000_000));
    var bookings = System.Text.Json.JsonSerializer.Serialize(Model.DataPoints.Select(d => d.Bookings));
}

<div class="page-header">
    <div>
        <h1 class="page-title">Báo cáo doanh thu</h1>
        <p class="page-subtitle">Phân tích doanh thu và số lượng booking theo thời gian</p>
    </div>
</div>

<div class="stat-grid" style="grid-template-columns:repeat(2,1fr);max-width:500px">
    <div class="stat-card emerald">
        <div><div class="stat-label">Tổng doanh thu</div><div class="stat-value text-success">@DisplayHelpers.FormatCurrency(Model.TotalRevenue)</div></div>
    </div>
    <div class="stat-card indigo">
        <div><div class="stat-label">Tổng booking</div><div class="stat-value" style="color:#818cf8">@Model.TotalBookings</div></div>
    </div>
</div>

<div class="filter-bar">
    <span class="text-secondary small">Kỳ báo cáo:</span>
    <a asp-action="Revenue" asp-route-period="Week" class="filter-chip @(Model.Period=="Week"?"active":"")">Tuần</a>
    <a asp-action="Revenue" asp-route-period="Month" class="filter-chip @(Model.Period=="Month"?"active":"")">Tháng</a>
    <a asp-action="Revenue" asp-route-period="Year" class="filter-chip @(Model.Period=="Year"?"active":"")">Năm</a>
</div>

<div class="admin-card p-4">
    <h2 class="h6 text-white mb-3"><i class="fa-solid fa-chart-line me-2"></i>Biểu đồ doanh thu</h2>
    <div class="chart-container">
        <canvas id="revenueChart"></canvas>
    </div>
</div>

<div class="admin-card p-4 mt-4">
    <h2 class="h6 text-white mb-3">Chi tiết theo kỳ</h2>
    <table class="admin-table">
        <thead><tr><th>Kỳ</th><th>Doanh thu</th><th>Booking</th></tr></thead>
        <tbody>
            @foreach (var d in Model.DataPoints)
            {
                <tr>
                    <td>@d.Label</td>
                    <td class="text-success fw-semibold">@DisplayHelpers.FormatCurrency(d.Revenue)</td>
                    <td>@d.Bookings</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(labels),
                datasets: [
                    { label: 'Doanh thu (triệu VNĐ)', data: @Html.Raw(revenuesM), backgroundColor: 'rgba(34,197,94,0.6)', borderColor: '#22c55e', borderWidth: 1, yAxisID: 'y' },
                    { label: 'Booking', data: @Html.Raw(bookings), type: 'line', borderColor: '#818cf8', backgroundColor: 'rgba(129,140,248,0.1)', yAxisID: 'y1' }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { labels: { color: '#94a3b8' } } },
                scales: {
                    x: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } },
                    y: { position: 'left', ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.5)' } },
                    y1: { position: 'right', ticks: { color: '#64748b' }, grid: { drawOnChartArea: false } }
                }
            }
        });
    </script>
}
