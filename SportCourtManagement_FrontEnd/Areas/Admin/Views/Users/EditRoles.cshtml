@model UserEditRolesViewModel
@{
    ViewData["Title"] = "Gán vai trò";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Gán vai trò</h1>
        <p class="page-subtitle">@Model.FullName — @Model.Email</p>
    </div>
    <a asp-action="Index" class="btn-secondary-custom"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
</div>

<div class="admin-card p-4" style="max-width:480px">
    <partial name="_UserEditRolesModal" model="Model" />
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('userRolesForm');
            if (!form) return;
            const cancelBtn = form.querySelector('[data-bs-dismiss="modal"]');
            if (cancelBtn) {
                cancelBtn.type = 'button';
                cancelBtn.removeAttribute('data-bs-dismiss');
                cancelBtn.addEventListener('click', function () {
                    window.location.href = '@Url.Action("Index")';
                });
            }
        })();
    </script>
}
