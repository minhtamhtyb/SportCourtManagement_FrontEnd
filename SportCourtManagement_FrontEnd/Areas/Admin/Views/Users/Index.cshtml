@model UserListViewModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý người dùng</h1>
        <p class="page-subtitle">Danh sách tài khoản và phân vai trò — <a asp-area="Admin" asp-controller="Roles" asp-action="Index" class="text-success text-decoration-none">Xem ma trận phân quyền</a></p>
    </div>
    <button type="button" class="btn-primary-custom" data-user-create>
        <i class="fa-solid fa-plus"></i> Thêm người dùng mới
    </button>
</div>

<form method="get" class="filter-bar">
    <div class="filter-search">
        <i class="fa-solid fa-magnifying-glass text-secondary"></i>
        <input type="text" name="search" value="@Model.Search" placeholder="Tìm tên, email, SĐT..." />
    </div>
    <a asp-action="Index" class="filter-chip @(string.IsNullOrEmpty(Model.Role) ? "active" : "")">Tất cả</a>
    @foreach (var r in Model.RoleOptions)
    {
        <a asp-action="Index" asp-route-role="@r" asp-route-search="@Model.Search"
           class="filter-chip @(Model.Role == r ? "active" : "")">@r</a>
    }
    <span class="text-secondary small ms-auto"><strong class="text-white">@Model.TotalCount</strong> người dùng</span>
</form>

@if (!Model.Users.Any())
{
    <div class="empty-state py-5">
        <i class="fa-solid fa-users d-block"></i>
        <p class="text-secondary">Không tìm thấy người dùng phù hợp.</p>
    </div>
}
else
{
    <div class="admin-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Email / SĐT</th>
                    <th>Vai trò</th>
                    <th>Hạng</th>
                    <th>Trạng thái</th>
                    <th>Ngày tham gia</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr class="@(!u.IsActive ? "opacity-50" : "")">
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(u.AvatarUrl ?? $"https://api.dicebear.com/8.x/avataaars/svg?seed={u.UserId}")" class="rounded-circle" width="36" height="36" alt="" />
                                <span class="fw-semibold text-white">@u.FullName</span>
                            </div>
                        </td>
                        <td class="small text-secondary">
                            <div>@u.Email</div>
                            <div>@(u.Phone ?? "—")</div>
                        </td>
                        <td><span class="type-badge type-default">@u.Role</span></td>
                        <td class="text-secondary small">@(u.MembershipTier ?? "—")</td>
                        <td>
                            @if (u.IsActive)
                            { <span class="status-badge status-available">Active</span> }
                            else
                            { <span class="status-badge status-inactive">Vô hiệu</span> }
                        </td>
                        <td class="text-secondary small">
                            @(u.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@u.UserId" class="btn-ghost" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                            <button type="button" class="btn-ghost" title="Sửa người dùng"
                                    data-user-edit data-user-id="@u.UserId">
                                <i class="fa-solid fa-pen text-info"></i>
                            </button>
                            <button type="button" class="btn-ghost" title="@(u.IsActive ? "Vô hiệu hóa" : "Kích hoạt")"
                                    data-user-toggle-status
                                    data-user-id="@u.UserId"
                                    data-user-name="@u.FullName"
                                    data-is-active="@u.IsActive.ToString().ToLower()">
                                <i class="fa-solid @(u.IsActive ? "fa-ban text-warning" : "fa-check text-success")"></i>
                            </button>
                            @if (u.UserId != 1)
                            {
                                <button type="button" class="btn-ghost" title="Xóa người dùng"
                                        data-user-delete
                                        data-user-id="@u.UserId"
                                        data-user-name="@u.FullName">
                                    <i class="fa-solid fa-trash text-danger"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-custom">
            @* Nút Trang trước *@
            @if (Model.Page > 1)
            {
                <a asp-action="Index" 
                   asp-route-page="@(Model.Page - 1)" 
                   asp-route-search="@Model.Search" 
                   asp-route-role="@Model.Role"
                   title="Trang trước">
                    <i class="fa-solid fa-chevron-left"></i>
                </a>
            }
            else
            {
                <span class="disabled"><i class="fa-solid fa-chevron-left"></i></span>
            }

            @* Tính toán khoảng trang hiển thị *@
            @{
                int startPage = Math.Max(1, Model.Page - 2);
                int endPage = Math.Min(Model.TotalPages, Model.Page + 2);

                if (Model.Page <= 3)
                {
                    endPage = Math.Min(Model.TotalPages, 5);
                }
                if (Model.Page >= Model.TotalPages - 2)
                {
                    startPage = Math.Max(1, Model.TotalPages - 4);
                }
            }

            @* Trang đầu và dấu ba chấm bên trái *@
            @if (startPage > 1)
            {
                <a asp-action="Index" asp-route-page="1" asp-route-search="@Model.Search" asp-route-role="@Model.Role">1</a>
                @if (startPage > 2)
                {
                    <span class="dots">...</span>
                }
            }

            @* Các trang ở giữa *@
            @for (int i = startPage; i <= endPage; i++)
            {
                if (i == Model.Page)
                {
                    <span class="active">@i</span>
                }
                else
                {
                    <a asp-action="Index" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-role="@Model.Role">@i</a>
                }
            }

            @* Trang cuối và dấu ba chấm bên phải *@
            @if (endPage < Model.TotalPages)
            {
                @if (endPage < Model.TotalPages - 1)
                {
                    <span class="dots">...</span>
                }
                <a asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-search="@Model.Search" asp-route-role="@Model.Role">@Model.TotalPages</a>
            }

            @* Nút Trang sau *@
            @if (Model.Page < Model.TotalPages)
            {
                <a asp-action="Index" 
                   asp-route-page="@(Model.Page + 1)" 
                   asp-route-search="@Model.Search" 
                   asp-route-role="@Model.Role"
                   title="Trang sau">
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            }
            else
            {
                <span class="disabled"><i class="fa-solid fa-chevron-right"></i></span>
            }
        </div>
    }
}

<div class="modal fade" id="userRolesModal" tabindex="-1" aria-labelledby="userRolesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content admin-modal">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white" id="userRolesModalLabel">Gán vai trò</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" id="userRolesModalBody">
                <div class="text-center py-4 text-secondary">
                    <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                    <span class="ms-2">Đang tải...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="userToggleStatusForm" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

<form id="userDeleteForm" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="~/js/users.js" asp-append-version="true"></script>
}
