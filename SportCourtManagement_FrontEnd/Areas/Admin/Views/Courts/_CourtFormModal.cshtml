@model CourtFormViewModel
@{
    var isEdit = Model.CourtId.HasValue;
    var formAction = isEdit ? "Edit" : "Create";
}

<form asp-action="@formAction" asp-route-id="@Model.CourtId" asp-route-complexId="@Model.ComplexId" method="post" enctype="multipart/form-data" class="form-dark" id="courtForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ComplexId" />
    @if (isEdit)
    {
        <input type="hidden" asp-for="CourtId" />
    }
    <input type="hidden" asp-for="ImageUrl" id="courtImageUrl" />
    <div id="existingImageUrlsContainer">
        @if (Model.ImageUrls != null)
        {
            for (int i = 0; i < Model.ImageUrls.Count; i++)
            {
                <input type="hidden" name="ImageUrls[@i]" value="@Model.ImageUrls[i]" class="existing-image-url-input" />
            }
        }
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small d-none"></div>

    <div class="row g-3">
        <div class="col-md-6 mb-3">
            <label asp-for="CourtName" class="form-label"></label>
            <input asp-for="CourtName" class="form-control" placeholder="VD: Sân Pickleball A1" />
            <span asp-validation-for="CourtName" class="text-danger small field-error"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="CourtCode" class="form-label"></label>
            <input asp-for="CourtCode" class="form-control text-uppercase" placeholder="VD: PI0001, FB0001, BA0001" id="CourtCode" maxlength="6" />
            <span asp-validation-for="CourtCode" class="text-danger small field-error"></span>
            <div id="courtCodeHelpText" class="form-text text-info small mt-1"></div>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="CourtTypeId" class="form-label"></label>
            <select asp-for="CourtTypeId" class="form-select" id="CourtTypeId" asp-items="@(new SelectList(Model.CourtTypes, "CourtTypeId", "TypeName"))"></select>
            <span asp-validation-for="CourtTypeId" class="text-danger small field-error"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                @foreach (var s in Model.StatusOptions)
                {
                    <option value="@s">@DisplayHelpers.GetCourtStatus(s).Label</option>
                }
            </select>
            <span asp-validation-for="Status" class="text-danger small field-error"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Location" class="form-label"></label>
            <input asp-for="Location" class="form-control" placeholder="Khu A - Tầng 1" />
            <span asp-validation-for="Location" class="text-danger small field-error"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Capacity" class="form-label"></label>
            <input asp-for="Capacity" class="form-control" type="number" min="1" />
            <span asp-validation-for="Capacity" class="text-danger small field-error"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="OpenTime" class="form-label">Giờ mở cửa (Theo khung Slot)</label>
            <select asp-for="OpenTime" class="form-select">
                <option value="06:00">Slot 1 — 06:00</option>
                <option value="07:30">Slot 2 — 07:30</option>
                <option value="09:00">Slot 3 — 09:00</option>
                <option value="15:00">Slot 4 — 15:00</option>
                <option value="16:30">Slot 5 — 16:30</option>
                <option value="18:00">Slot 6 — 18:00</option>
                <option value="19:30">Slot 7 — 19:30</option>
                <option value="21:00">Slot 8 — 21:00</option>
            </select>
            <span asp-validation-for="OpenTime" class="text-danger small field-error"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="CloseTime" class="form-label">Giờ đóng cửa (Theo khung Slot)</label>
            <select asp-for="CloseTime" class="form-select">
                <option value="07:30">Slot 1 — 07:30</option>
                <option value="09:00">Slot 2 — 09:00</option>
                <option value="10:30">Slot 3 — 10:30</option>
                <option value="16:30">Slot 4 — 16:30</option>
                <option value="18:00">Slot 5 — 18:00</option>
                <option value="19:30">Slot 6 — 19:30</option>
                <option value="21:00">Slot 7 — 21:00</option>
                <option value="22:30" selected>Slot 8 — 22:30</option>
            </select>
            <span asp-validation-for="CloseTime" class="text-danger small field-error"></span>
        </div>
        
        <input type="hidden" asp-for="PricePerHour" id="PricePerHour" value="@(Model.PricePerHour > 0 ? Model.PricePerHour : 100000)" />
        <input type="hidden" asp-for="Surface" value="@(Model.Surface ?? "")" />

        <div class="col-12 mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Description" class="text-danger small field-error"></span>
        </div>
        <!-- BẢNG GIÁ THEO CA KHUNG GIỜ -->
        <div class="col-12 mb-3">
            <div class="card bg-dark border-secondary p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label text-warning fw-bold mb-0">
                        <i class="fa-solid fa-coins me-1"></i> Bảng giá chi tiết từng ca (Time Slot Pricing)
                    </label>
                    <button type="button" class="btn btn-sm btn-outline-info" id="btnApplyDefaultPrices">
                        <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Áp dụng giá mặc định
                    </button>
                </div>
                <div class="small text-secondary mb-3">Tuỳ chỉnh giá áp dụng riêng cho từng Ca chơi. Bạn có thể tự do đặt giá cao hơn cho các ca giờ vàng (Slot 6, 7, 8).</div>
                <div class="table-responsive">
                    <table class="table table-dark table-bordered table-sm text-center align-middle mb-0" style="font-size: 13px;">
                        <thead>
                            <tr class="table-secondary text-white">
                                <th>Ca / Khung giờ</th>
                                <th style="width: 220px;">Giá thuê ca (VNĐ)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Pricings != null && Model.Pricings.Any())
                            {
                                for (int i = 0; i < Model.Pricings.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <input type="hidden" name="Pricings[@i].SlotId" value="@Model.Pricings[i].SlotId" />
                                            <input type="hidden" name="Pricings[@i].SlotName" value="@Model.Pricings[i].SlotName" />
                                            <input type="hidden" name="Pricings[@i].StartTime" value="@Model.Pricings[i].StartTime" />
                                            <input type="hidden" name="Pricings[@i].EndTime" value="@Model.Pricings[i].EndTime" />
                                            <span class="fw-semibold text-info">@Model.Pricings[i].SlotName</span>
                                        </td>
                                        <td>
                                            <div class="input-group input-group-sm">
                                                <input type="number" name="Pricings[@i].Price" value="@Model.Pricings[i].Price" class="form-control text-end slot-price-input" min="0" step="5000" data-duration="1.5" />
                                                <span class="input-group-text">đ</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 mb-0">
            <label class="form-label">Ảnh sân (Tối đa 3 ảnh mô tả — Click vào ảnh để chọn Ảnh Chính)</label>
            <input type="file" name="ImageFiles" class="form-control" accept="image/jpeg,image/png,image/webp,image/gif" id="courtImageFile" multiple />
            <div class="form-text text-secondary small">Bấm vào 1 ảnh bất kỳ bên dưới để chọn làm <strong>Ảnh chính</strong> (mặc định là ảnh đầu tiên được thêm vào). Mọi ảnh sẽ tự động được tải lên Cloudinary.</div>
            
            <!-- Existing images gallery preview -->
            <div id="courtImageGalleryPreview" class="d-flex flex-wrap gap-3 mt-3">
                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    for (int i = 0; i < Model.ImageUrls.Count; i++)
                    {
                        var url = Model.ImageUrls[i];
                        var isPrimary = (url == Model.ImageUrl) || (string.IsNullOrEmpty(Model.ImageUrl) && i == 0);
                        <div class="position-relative img-thumb-item existing-img-thumb @(isPrimary ? "is-primary-thumb" : "")" 
                             style="width: 110px; height: 80px; cursor: pointer;" 
                             data-url="@url"
                             title="Bấm để chọn làm ảnh chính">
                            <img src="@url" class="rounded w-100 h-100 object-fit-cover @(isPrimary ? "border border-2 border-success" : "border border-secondary")" />
                            <span class="badge bg-success position-absolute bottom-0 start-0 m-1 primary-badge @(isPrimary ? "" : "d-none")" style="font-size: 10px;">Ảnh chính</span>
                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0 d-flex align-items-center justify-content-center btn-remove-existing-img" style="width: 20px; height: 20px; border-radius: 50%; font-size: 10px; z-index: 10;" data-url="@url">&times;</button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top border-secondary">
        <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Hủy</button>
        <button type="submit" class="btn-primary-custom" id="courtFormSubmit">
            <i class="fa-solid fa-floppy-disk"></i> @(isEdit ? "Lưu thay đổi" : "Thêm mới")
        </button>
    </div>
</form>

<script>
    document.getElementById('btnApplyDefaultPrices')?.addEventListener('click', function() {
        var basePrice = parseFloat(document.getElementById('PricePerHour')?.value || 100000);
        document.querySelectorAll('.slot-price-input').forEach(function(input) {
            var duration = parseFloat(input.getAttribute('data-duration') || 1.5);
            input.value = Math.round(basePrice * duration);
        });
    });

    (function() {
        var typeSelect = document.getElementById('CourtTypeId');
        var codeInput = document.getElementById('CourtCode');
        var helpText = document.getElementById('courtCodeHelpText');
        if (!typeSelect || !codeInput) return;

        function getPrefixInfo() {
            var selectedText = typeSelect.options[typeSelect.selectedIndex]?.text?.toLowerCase() || '';
            if (selectedText.includes('bóng đá') || selectedText.includes('football')) {
                return { prefix: 'FB', example: 'FB0001', name: 'Bóng đá' };
            } else if (selectedText.includes('pickleball') || selectedText.includes('pickle')) {
                return { prefix: 'PI', example: 'PI0001', name: 'Pickleball' };
            } else if (selectedText.includes('cầu lông') || selectedText.includes('badminton')) {
                return { prefix: 'BA', example: 'BA0001', name: 'Cầu lông' };
            } else {
                return { prefix: 'XX', example: 'XX0001', name: 'Khác' };
            }
        }

        function updateHelp() {
            var info = getPrefixInfo();
            if (helpText) {
                helpText.innerHTML = '<i class="fa-solid fa-circle-info me-1"></i>Loại ' + info.name + ': Mã phải bắt đầu bằng <strong>' + info.prefix + '</strong> và 4 chữ số cuối (Ví dụ: <code>' + info.example + '</code>)';
            }
        }

        typeSelect.addEventListener('change', updateHelp);
        codeInput.addEventListener('input', function() {
            this.value = this.value.toUpperCase();
        });

        updateHelp();
    })();
</script>
