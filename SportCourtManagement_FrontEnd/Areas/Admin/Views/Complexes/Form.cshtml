@model ComplexFormViewModel
@{
    var isEdit = Model.ComplexId.HasValue;
    ViewData["Title"] = isEdit ? "Sửa tổ hợp sân" : "Thêm tổ hợp sân";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">@(isEdit ? "Cập nhật thông tin tổ hợp sân" : "Tạo tổ hợp sân mới")</p>
    </div>
    <a asp-action="Index" class="btn-secondary-custom"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
</div>

<div class="admin-card p-4" style="max-width:720px">
    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.ComplexId" method="post" class="form-dark">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="mb-3">
            <label asp-for="ComplexName" class="form-label"></label>
            <input asp-for="ComplexName" class="form-control" placeholder="VD: SportZone Cầu Giấy" />
            <span asp-validation-for="ComplexName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" placeholder="VD: 123 Nguyễn Trãi, Hà Nội" />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" placeholder="024 xxxx xxxx" />
        </div>
        <div class="mb-3">
            <label asp-for="ManagerId" class="form-label">Quản lý phụ trách</label>
            <select asp-for="ManagerId" class="form-select">
                <option value="">-- Chọn quản lý --</option>
                @foreach (var m in Model.Managers)
                {
                    <option value="@m.UserId">#@m.UserId — @m.FullName (@m.Email)</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Loại sân cung cấp</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var t in Model.CourtTypeOptions)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="CourtTypeIds" value="@t.CourtTypeId"
                               id="type_@t.CourtTypeId" @(Model.CourtTypeIds.Contains(t.CourtTypeId) ? "checked" : "") />
                        <label class="form-check-label text-secondary small" for="type_@t.CourtTypeId">@t.TypeName</label>
                    </div>
                }
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn..."></textarea>
        </div>
        <div class="mb-4">
            <label asp-for="ImageUrl" class="form-label"></label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="preview" class="mt-2 rounded" style="max-height:120px;width:100%;object-fit:cover" />
            }
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn-secondary-custom">Hủy</a>
            <button type="submit" class="btn-primary-custom"><i class="fa-solid fa-floppy-disk"></i> @(isEdit ? "Lưu thay đổi" : "Thêm mới")</button>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
