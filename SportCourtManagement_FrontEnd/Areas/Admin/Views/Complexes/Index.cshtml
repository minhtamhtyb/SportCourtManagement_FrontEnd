<div class="stat-grid">
    <div class="stat-card indigo">
        <div><i class="fa-solid fa-building fa-lg" style="color:#818cf8"></i></div>
        <div><div class="stat-label">Tổ hợp sân</div><div class="stat-value" style="color:#818cf8">@Model.Stats.TotalComplexes</div></div>
    </div>
    <div class="stat-card slate">
        <div><i class="fa-solid fa-table-tennis-paddle-ball fa-lg text-secondary"></i></div>
        <div><div class="stat-label">Tổng số sân</div><div class="stat-value">@Model.Stats.TotalCourts</div></div>
    </div>
    <div class="stat-card emerald">
        <div><i class="fa-solid fa-circle-check fa-lg text-success"></i></div>
        <div><div class="stat-label">Đang hoạt động</div><div class="stat-value text-success">@Model.Stats.ActiveCourts</div></div>
    </div>
    <div class="stat-card amber">
        <div><i class="fa-solid fa-wrench fa-lg text-warning"></i></div>
        <div><div class="stat-label">Bảo trì</div><div class="stat-value text-warning">@Model.Stats.MaintenanceCourts</div></div>
    </div>
    <div class="stat-card slate">
        <div><i class="fa-solid fa-ban fa-lg text-secondary"></i></div>
        <div><div class="stat-label">Ngưng hoạt động</div><div class="stat-value text-secondary">@Model.Stats.InactiveCourts</div></div>
    </div>
</div>

<form method="get" class="filter-bar">
    <div class="filter-search">
        <i class="fa-solid fa-magnifying-glass text-secondary"></i>
        <input type="text" name="search" value="@Model.Search" placeholder="Tìm tên, địa chỉ, quản lý..." />
    </div>
    <a asp-action="Index" class="filter-chip @(Model.CourtTypeId == null ? "active" : "")">Tất cả</a>
    @foreach (var t in Model.CourtTypes)
    {
        <a asp-action="Index" asp-route-search="@Model.Search" asp-route-courtTypeId="@t.CourtTypeId"
           class="filter-chip @(Model.CourtTypeId == t.CourtTypeId ? "active" : "")">@t.TypeName</a>
    }
    <span class="text-secondary small ms-auto"><strong class="text-white">@Model.TotalCount</strong> tổ hợp</span>
</form>

@if (!Model.Complexes.Any())
{
    <div class="empty-state">
        <i class="fa-solid fa-building d-block"></i>
