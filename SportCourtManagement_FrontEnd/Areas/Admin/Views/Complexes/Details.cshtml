@model ComplexDetailsViewModel
@{
    ViewData["Title"] = Model.Complex.ComplexName;
}

<div class="page-header">
    <div>
        <a asp-action="Index" class="text-secondary small text-decoration-none"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách</a>
        <h1 class="page-title mt-1">@Model.Complex.ComplexName</h1>
        <p class="page-subtitle"><i class="fa-solid fa-location-dot me-1"></i>@Model.Complex.Address</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <button type="button" class="btn-secondary-custom" data-complex-modal="edit" data-complex-id="@Model.Complex.ComplexId">
            <i class="fa-solid fa-pen"></i> Sửa tổ hợp
        </button>
        <a asp-action="Services" asp-route-id="@Model.Complex.ComplexId" class="btn-secondary-custom">
            <i class="fa-solid fa-toolbox"></i> Quản lý dịch vụ
        </a>
        <button type="button" class="btn-primary-custom" data-court-modal="create" data-complex-id="@Model.Complex.ComplexId">
            <i class="fa-solid fa-plus"></i> Thêm sân
        </button>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="admin-card p-4">
            @if (!string.IsNullOrEmpty(Model.Complex.ImageUrl))
            {
                <img src="@Model.Complex.ImageUrl" alt="" class="w-100 rounded mb-3" style="max-height:200px;object-fit:cover" />
            }
            <p class="text-secondary mb-0">@(Model.Complex.Description ?? "Không có mô tả.")</p>
            <div class="d-flex flex-wrap gap-3 mt-3 small text-secondary">
                <span><i class="fa-solid fa-phone me-1"></i>@(Model.Complex.Phone ?? "—")</span>
                <span><i class="fa-solid fa-table-tennis-paddle-ball me-1"></i>@Model.Complex.TotalCourts sân</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        @if (Model.Manager != null)
        {
            <div class="admin-card p-3">
                <h2 class="h6 text-white mb-3"><i class="fa-solid fa-user-check me-2 text-success"></i>Quản lý phụ trách</h2>
                <div class="d-flex align-items-center gap-3">
                    <img src="@(Model.Manager.AvatarUrl ?? $"https://api.dicebear.com/8.x/avataaars/svg?seed={Model.Manager.UserId}")" class="rounded-circle" width="48" height="48" alt="" />
                    <div>
                        <div class="fw-semibold text-white">@Model.Manager.FullName</div>
                        <div class="text-secondary small">#@Model.Manager.UserId · @Model.Manager.Email</div>
                    </div>
                </div>
            </div>
        }
        <div class="stat-grid mt-0" style="grid-template-columns:1fr 1fr">
            <div class="stat-card emerald p-3"><div class="stat-label">Hoạt động</div><div class="stat-value text-success">@Model.Complex.ActiveCourts</div></div>
            <div class="stat-card amber p-3"><div class="stat-label">Bảo trì</div><div class="stat-value text-warning">@Model.Complex.MaintenanceCourts</div></div>
        </div>
    </div>
</div>

<hr class="border-secondary my-4" />

<form asp-action="Details" asp-route-id="@Model.Complex.ComplexId" method="get" class="filter-bar">
    <div class="filter-search">
        <i class="fa-solid fa-magnifying-glass text-secondary"></i>
        <input type="text" name="search" value="@Model.Search" placeholder="Tìm tên hoặc mã sân..." />
    </div>
    <a asp-action="Details" asp-route-id="@Model.Complex.ComplexId" class="filter-chip @(string.IsNullOrEmpty(Model.StatusFilter) ? "active" : "")">Tất cả</a>
    @foreach (var s in new[] { "Available", "Maintenance", "Inactive", "Booked" })
    {
        <a asp-action="Details" asp-route-id="@Model.Complex.ComplexId" asp-route-search="@Model.Search" asp-route-status="@s"
           class="filter-chip @(Model.StatusFilter == s ? "active" : "")">@((DisplayHelpers.GetCourtStatus(s).Label))</a>
    }
</form>

<h2 class="h6 text-white mb-3">Danh sách sân (@Model.Courts.Count)</h2>

@if (!Model.Courts.Any())
{
    <div class="empty-state">
        <i class="fa-solid fa-table-tennis-paddle-ball d-block"></i>
        <p class="text-secondary">Chưa có sân trong tổ hợp này</p>
        <button type="button" class="btn-primary-custom" data-court-modal="create" data-complex-id="@Model.Complex.ComplexId">Thêm sân đầu tiên</button>
    </div>
}
else
{
    <div class="court-card-grid">
        @foreach (var court in Model.Courts)
        {
            <div class="court-card">
                <img src="@court.ImageUrl" alt="@court.CourtName" class="court-card-img" onerror="this.src='https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=400'" />
                <div class="court-card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="fw-semibold text-white">@court.CourtName</div>
                            <div class="text-secondary small">@court.CourtCode · @court.CourtTypeName</div>
                        </div>
                        <partial name="_CourtStatusBadge" model="court.Status" />
                    </div>
                    <div class="small text-secondary mb-2">
                        <i class="fa-solid fa-clock me-1"></i>@court.OpenTime — @court.CloseTime
                        · <i class="fa-solid fa-tag ms-1 me-1"></i>@DisplayHelpers.FormatCurrency(court.PricePerHour)/giờ
                    </div>
                    <div class="d-flex gap-1 flex-wrap align-items-center">
                        <button type="button" class="btn-secondary-custom btn-sm py-1 px-2" style="font-size:.75rem" data-court-modal="edit" data-court-id="@court.CourtId" title="Chỉnh sửa">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button type="button"
                                class="btn-secondary-custom btn-sm py-1 px-2"
                                style="font-size:.75rem"
                                data-maintenance-court
                                data-court-id="@court.CourtId"
                                data-court-name="@court.CourtName"
                                data-complex-id="@Model.Complex.ComplexId"
                                title="Bảo trì">
                            <i class="fa-solid fa-wrench"></i>
                        </button>
                        @if (string.Equals(court.Status, "Inactive", StringComparison.OrdinalIgnoreCase))
                        {
                            <form asp-area="Admin" asp-controller="Courts" asp-action="Restore" method="post" class="d-inline ms-auto">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@court.CourtId" />
                                <input type="hidden" name="complexId" value="@Model.Complex.ComplexId" />
                                <button type="submit" class="btn-ghost text-success btn-sm" title="Khôi phục hoạt động"
                                        onclick="return confirm('Khôi phục sân @court.CourtName về trạng thái Hoạt động?')">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-area="Admin" asp-controller="Courts" asp-action="Deactivate" method="post" class="d-inline ms-auto">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@court.CourtId" />
                                <input type="hidden" name="complexId" value="@Model.Complex.ComplexId" />
                                <button type="submit" class="btn-ghost text-warning btn-sm" title="Ngưng hoạt động"
                                        onclick="return confirm('Ngưng hoạt động sân @court.CourtName?\n\nChỉ cho phép khi KHÔNG còn lịch Pending/Confirmed.\nNếu còn lịch đặt, hãy dùng Bảo trì.')">
                                    <i class="fa-solid fa-pause"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="modal fade" id="complexModal" tabindex="-1" aria-labelledby="complexModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content admin-modal">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white" id="complexModalLabel">Tổ hợp sân</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" id="complexModalBody">
                <div class="text-center py-4 text-secondary">
                    <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                    <span class="ms-2">Đang tải...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="courtModal" tabindex="-1" aria-labelledby="courtModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content admin-modal">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white" id="courtModalLabel">Sân thể thao</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" id="courtModalBody">
                <div class="text-center py-4 text-secondary">
                    <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                    <span class="ms-2">Đang tải...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="maintenanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content admin-modal">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white">
                    <i class="fa-solid fa-wrench text-warning me-2"></i>Bảo trì sân
                    <span class="text-secondary fs-6" id="maintCourtName"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="maintCourtId" />
                <input type="hidden" id="maintComplexId" value="@Model.Complex.ComplexId" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Bắt đầu</label>
                        <input type="datetime-local" id="maintStart" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Kết thúc</label>
                        <input type="datetime-local" id="maintEnd" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label text-secondary small">Lý do</label>
                        <input type="text" id="maintReason" class="form-control" maxlength="500" placeholder="VD: Thay thảm, sửa lưới..." />
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button type="button" class="btn-secondary-custom btn-sm" id="btnPreviewMaint">
                        <i class="fa-solid fa-magnifying-glass me-1"></i> Kiểm tra conflict
                    </button>
                </div>
                <div id="maintConflictBox" class="mt-3 d-none">
                    <div class="alert alert-warning py-2 mb-2" id="maintConflictSummary"></div>
                    <div class="table-responsive">
                        <table class="admin-table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Khách</th>
                                    <th>Thời gian</th>
                                    <th>Hoàn tiền</th>
                                </tr>
                            </thead>
                            <tbody id="maintConflictBody"></tbody>
                        </table>
                    </div>
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="maintConfirmRefund" />
                        <label class="form-check-label text-secondary small" for="maintConfirmRefund">
                            Xác nhận hủy các lịch conflict và hoàn tiền vào ví khách
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn-primary-custom" id="btnSaveMaint">
                    <i class="fa-solid fa-floppy-disk me-1"></i> Xác nhận bảo trì
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/complexes.js" asp-append-version="true"></script>
    <script src="~/js/courts.js" asp-append-version="true"></script>
    <script>
        (function () {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('#maintenanceModal')?.closest('body')?.querySelector('input[name="__RequestVerificationToken"]')?.value;

            function getAntiForgery() {
                return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            }

            function toLocalInputValue(d) {
                const pad = n => String(n).padStart(2, '0');
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
            }

            document.querySelectorAll('[data-maintenance-court]').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.getElementById('maintCourtId').value = btn.dataset.courtId;
                    document.getElementById('maintCourtName').textContent = '— ' + (btn.dataset.courtName || '');
                    document.getElementById('maintReason').value = '';
                    document.getElementById('maintConfirmRefund').checked = false;
                    document.getElementById('maintConflictBox').classList.add('d-none');
                    document.getElementById('maintConflictBody').innerHTML = '';

                    const start = new Date();
                    start.setMinutes(0, 0, 0);
                    start.setHours(start.getHours() + 1);
                    const end = new Date(start.getTime() + 2 * 60 * 60 * 1000);
                    document.getElementById('maintStart').value = toLocalInputValue(start);
                    document.getElementById('maintEnd').value = toLocalInputValue(end);

                    bootstrap.Modal.getOrCreateInstance(document.getElementById('maintenanceModal')).show();
                });
            });

            document.getElementById('btnPreviewMaint')?.addEventListener('click', async () => {
                const id = document.getElementById('maintCourtId').value;
                const start = document.getElementById('maintStart').value;
                const end = document.getElementById('maintEnd').value;
                if (!start || !end) {
                    alert('Vui lòng chọn thời gian bắt đầu và kết thúc.');
                    return;
                }
                try {
                    const url = `/Admin/Courts/PreviewMaintenance?id=${id}&start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;
                    const res = await fetch(url);
                    const json = await res.json();
                    if (!json.success) {
                        alert(json.message || 'Không kiểm tra được conflict.');
                        return;
                    }
                    const data = json.data;
                    const box = document.getElementById('maintConflictBox');
                    const summary = document.getElementById('maintConflictSummary');
                    const body = document.getElementById('maintConflictBody');
                    box.classList.remove('d-none');
                    if (!data.conflictCount) {
                        summary.className = 'alert alert-success py-2 mb-2';
                        summary.textContent = 'Không có lịch đặt nào bị trùng khung bảo trì.';
                        body.innerHTML = '';
                        document.getElementById('maintConfirmRefund').checked = false;
                        document.getElementById('maintConfirmRefund').closest('.form-check').classList.add('d-none');
                    } else {
                        summary.className = 'alert alert-warning py-2 mb-2';
                        summary.textContent = `Có ${data.conflictCount} lịch bị trùng — tổng hoàn ước tính ${Number(data.totalRefundAmount).toLocaleString('vi-VN')}đ.`;
                        document.getElementById('maintConfirmRefund').closest('.form-check').classList.remove('d-none');
                        body.innerHTML = (data.conflicts || []).map(c => `
                            <tr>
                                <td>${c.bookingCode || ('#' + c.bookingId)}</td>
                                <td>${c.customerName || ''}</td>
                                <td>${new Date(c.bookingDate).toLocaleDateString('vi-VN')} ${c.startTime}-${c.endTime}</td>
                                <td>${Number(c.refundAmount).toLocaleString('vi-VN')}đ</td>
                            </tr>`).join('');
                    }
                } catch (e) {
                    alert('Không kết nối được máy chủ.');
                }
            });

            document.getElementById('btnSaveMaint')?.addEventListener('click', async () => {
                const id = document.getElementById('maintCourtId').value;
                const complexId = document.getElementById('maintComplexId').value;
                const start = document.getElementById('maintStart').value;
                const end = document.getElementById('maintEnd').value;
                const reason = document.getElementById('maintReason').value;
                const conflictVisible = !document.getElementById('maintConflictBox').classList.contains('d-none');
                const conflictRows = document.getElementById('maintConflictBody').children.length;
                const confirmRefund = document.getElementById('maintConfirmRefund').checked;

                if (!start || !end) {
                    alert('Vui lòng chọn thời gian bảo trì.');
                    return;
                }
                if (conflictVisible && conflictRows > 0 && !confirmRefund) {
                    alert('Có lịch conflict. Hãy tick xác nhận hủy & hoàn tiền, hoặc đổi khung giờ.');
                    return;
                }

                const form = new FormData();
                form.append('id', id);
                form.append('complexId', complexId);
                form.append('startDateTime', start);
                form.append('endDateTime', end);
                form.append('reason', reason || '');
                form.append('confirmRefund', confirmRefund ? 'true' : 'false');
                form.append('__RequestVerificationToken', getAntiForgery());

                const btn = document.getElementById('btnSaveMaint');
                btn.disabled = true;
                try {
                    const res = await fetch('/Admin/Courts/ScheduleMaintenance', {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: form
                    });
                    const json = await res.json().catch(() => null);
                    if (!res.ok || !json?.success) {
                        alert(json?.message || 'Lên lịch bảo trì thất bại.');
                        return;
                    }
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('maintenanceModal')).hide();
                    if (window.showToast) showToast(json.message, 'success');
                    else alert(json.message);
                    setTimeout(() => location.reload(), 800);
                } catch {
                    alert('Không kết nối được máy chủ.');
                } finally {
                    btn.disabled = false;
                }
            });
        })();
    </script>
}
