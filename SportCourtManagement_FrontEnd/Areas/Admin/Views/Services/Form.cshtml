@model ServiceFormViewModel
@{
    var isEdit = Model.ServiceId.HasValue;
    ViewData["Title"] = isEdit ? "Sửa dịch vụ" : "Thêm dịch vụ";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
    </div>
    <a asp-action="Index" class="btn-secondary-custom"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
</div>

<div class="admin-card p-4" style="max-width:600px">
    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.ServiceId" method="post" class="form-dark">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="mb-3">
            <label asp-for="ServiceName" class="form-label"></label>
            <input asp-for="ServiceName" class="form-control" />
            <span asp-validation-for="ServiceName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Category" class="form-label"></label>
            <select asp-for="Category" class="form-select">
                @foreach (var c in Model.CategoryOptions)
                {
                    <option value="@c">@DisplayHelpers.GetServiceCategory(c).Item1</option>
                }
            </select>
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" type="number" min="0" />
            </div>
            <div class="col-md-6">
                <label asp-for="Unit" class="form-label"></label>
                <input asp-for="Unit" class="form-control" placeholder="Giờ, Chai, Bộ..." />
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="StockQty" class="form-label"></label>
            <input asp-for="StockQty" class="form-control" type="number" min="0" />
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
        </div>
        <div class="mb-4 form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label text-secondary"></label>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn-secondary-custom">Hủy</a>
            <button type="submit" class="btn-primary-custom"><i class="fa-solid fa-floppy-disk"></i> Lưu</button>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
