@model ServiceListViewModel
@{
    ViewData["Title"] = "Dịch vụ & Kho";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý dịch vụ & Kho</h1>
        <p class="page-subtitle">Dụng cụ, đồ uống, huấn luyện viên và dịch vụ sự kiện</p>
    </div>
    <a asp-action="Create" class="btn-primary-custom"><i class="fa-solid fa-plus"></i> Thêm dịch vụ</a>
</div>

<form method="get" class="filter-bar">
    <input type="hidden" name="category" value="@Model.Category" />
    <div class="filter-search">
        <i class="fa-solid fa-magnifying-glass text-secondary"></i>
        <input type="text" name="search" value="@Model.Search" placeholder="Tìm tên dịch vụ..." />
    </div>
    <a asp-action="Index" class="filter-chip @(string.IsNullOrEmpty(Model.Category) ? "active" : "")">Tất cả</a>
    @foreach (var cat in new[] { "Equipment", "Drink", "Coach", "Event" })
    {
        var (label, _) = DisplayHelpers.GetServiceCategory(cat);
        <a asp-action="Index" asp-route-category="@cat" asp-route-search="@Model.Search"
           class="filter-chip @(Model.Category == cat ? "active" : "")">@label</a>
    }
</form>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Dịch vụ</th>
                <th>Loại</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Services)
            {
                var (catLabel, catCss) = DisplayHelpers.GetServiceCategory(s.Category);
                <tr class="@(!s.IsActive ? "opacity-50" : "")">
                    <td>
                        <div class="fw-semibold text-white">@s.ServiceName</div>
                        <div class="text-secondary small">@s.Description</div>
                    </td>
                    <td><span class="@catCss small fw-semibold">@catLabel</span></td>
                    <td>@DisplayHelpers.FormatCurrency(s.Price)<span class="text-secondary small">/@s.Unit</span></td>
                    <td>
                        <span class="fw-semibold @(s.StockQty < 10 ? "text-warning" : "")">@s.StockQty</span>
                    </td>
                    <td>
                        @if (s.IsActive)
                        { <span class="status-badge status-available">Hoạt động</span> }
                        else
                        { <span class="status-badge status-inactive">Ngưng</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@s.ServiceId" class="btn-ghost"><i class="fa-solid fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@s.ServiceId" class="btn-ghost"><i class="fa-solid fa-pen"></i></a>
                        @if (s.IsActive)
                        {
                            <form asp-action="Delete" asp-route-id="@s.ServiceId" method="post" class="d-inline" onsubmit="return confirm('Vô hiệu hóa dịch vụ?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-ghost text-danger"><i class="fa-solid fa-ban"></i></button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <div class="pagination-custom">
        @* Nút Trang trước *@
        @if (Model.PageNumber > 1)
        {
            <a asp-action="Index" 
               asp-route-page="@(Model.PageNumber - 1)" 
               asp-route-search="@Model.Search" 
               asp-route-category="@Model.Category"
               title="Trang trước">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
        }
        else
        {
            <span class="disabled"><i class="fa-solid fa-chevron-left"></i></span>
        }

        @* Tính toán khoảng trang hiển thị *@
        @{
            int startPage = Math.Max(1, Model.PageNumber - 2);
            int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

            if (Model.PageNumber <= 3)
            {
                endPage = Math.Min(Model.TotalPages, 5);
            }
            if (Model.PageNumber >= Model.TotalPages - 2)
            {
                startPage = Math.Max(1, Model.TotalPages - 4);
            }
        }

        @* Trang đầu và dấu ba chấm bên trái *@
        @if (startPage > 1)
        {
            <a asp-action="Index" asp-route-page="1" asp-route-search="@Model.Search" asp-route-category="@Model.Category">1</a>
            @if (startPage > 2)
            {
                <span class="dots">...</span>
            }
        }

        @* Các trang ở giữa *@
        @for (int i = startPage; i <= endPage; i++)
        {
            if (i == Model.PageNumber)
            {
                <span class="active">@i</span>
            }
            else
            {
                <a asp-action="Index" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-category="@Model.Category">@i</a>
            }
        }

        @* Trang cuối và dấu ba chấm bên phải *@
        @if (endPage < Model.TotalPages)
        {
            @if (endPage < Model.TotalPages - 1)
            {
                <span class="dots">...</span>
            }
            <a asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-search="@Model.Search" asp-route-category="@Model.Category">@Model.TotalPages</a>
        }

        @* Nút Trang sau *@
        @if (Model.PageNumber < Model.TotalPages)
        {
            <a asp-action="Index" 
               asp-route-page="@(Model.PageNumber + 1)" 
               asp-route-search="@Model.Search" 
               asp-route-category="@Model.Category"
               title="Trang sau">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        }
        else
        {
            <span class="disabled"><i class="fa-solid fa-chevron-right"></i></span>
        }
    </div>
}
