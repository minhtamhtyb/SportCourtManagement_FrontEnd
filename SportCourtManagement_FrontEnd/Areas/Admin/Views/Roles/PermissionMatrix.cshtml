@model RoleListViewModel
@{
    ViewData["Title"] = "Ma trận phân quyền";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Ma trận phân quyền</h1>
        <p class="page-subtitle">Theo đặc tả SRS — FE-10. <span class="text-secondary">Manager = Staff quản lý tổ hợp sân.</span></p>
    </div>
    <a asp-action="Index" class="btn-secondary-custom"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
</div>

<div class="admin-card p-4">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Chức năng</th>
                    <th class="text-center">Admin</th>
                    <th class="text-center">Manager</th>
                    <th class="text-center">Staff</th>
                    <th class="text-center">Customer</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.PermissionMatrix)
                {
                    <tr>
                        <td class="fw-semibold">@row.Feature</td>
                        <td class="text-center"><span class="@(row.Admin ? "permission-yes" : "permission-no")">@(row.Admin ? "✓" : "✗")</span></td>
                        <td class="text-center"><span class="@(row.Manager ? "permission-yes" : "permission-no")">@(row.Manager ? "✓" : "✗")</span></td>
                        <td class="text-center"><span class="@(row.Staff ? "permission-yes" : "permission-no")">@(row.Staff ? "✓" : "✗")</span></td>
                        <td class="text-center"><span class="@(row.Customer ? "permission-yes" : "permission-no")">@(row.Customer ? "✓" : "✗")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
