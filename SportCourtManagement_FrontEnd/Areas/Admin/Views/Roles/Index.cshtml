@model RoleListViewModel
@{
    ViewData["Title"] = "Phân quyền";
}

@* ─── Toast Container ─── *@
<div id="toastContainer"
     style="position:fixed;top:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:10px;min-width:320px;pointer-events:none;">
</div>

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý vai trò & Phân quyền</h1>
        <p class="page-subtitle">RBAC — Role-Based Access Control theo SRS. Cột <strong class="text-white">Manager</strong> = Staff được gán quản lý tổ hợp sân.</p>
    </div>
    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn-primary-custom btn-sm"><i class="fa-solid fa-users"></i> Quản lý người dùng</a>
    <a asp-action="PermissionMatrix" class="btn-secondary-custom btn-sm"><i class="fa-solid fa-table"></i> Ma trận đầy đủ</a>
</div>

<div class="row g-4 mb-4">
    @foreach (var role in Model.Roles)
    {
        <div class="col-md-6 col-lg-3">
            <div class="admin-card p-4">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa-solid fa-shield-halved text-success"></i>
                    <h2 class="h6 text-white mb-0">@role.RoleName</h2>
                </div>
                <p class="text-secondary small mb-2">@role.Description</p>
                <span class="text-secondary" style="font-size:.75rem"><strong class="text-white">@role.UserCount</strong> người dùng</span>
            </div>
        </div>
    }
</div>

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h6 text-white mb-0"><i class="fa-solid fa-shield-cat me-2 text-warning"></i>Ma trận phân quyền (Cho phép chỉnh sửa trực tiếp)</h2>
        <button type="button" id="btnSavePermissions" class="btn-primary-custom btn-sm">
            <i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi phân quyền
        </button>
    </div>
    <form id="permissionForm">
        @Html.AntiForgeryToken()
        <div class="table-responsive">
            <table class="admin-table text-center align-middle" id="permissionTable">
                <thead>
                    <tr>
                        <th class="text-start">Chức năng</th>
                        <th>Admin</th>
                        <th>Manager</th>
                        <th>Staff</th>
                        <th>Customer</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.PermissionMatrix.Count; i++)
                    {
                        var row = Model.PermissionMatrix[i];
                        <tr data-feature="@row.Feature">
                            <td class="text-start fw-semibold text-white">@row.Feature</td>
                            <td>
                                <input type="checkbox" class="form-check-input permission-chk" data-role="Admin" @(row.Admin ? "checked" : "") />
                            </td>
                            <td>
                                <input type="checkbox" class="form-check-input permission-chk" data-role="Manager" @(row.Manager ? "checked" : "") />
                            </td>
                            <td>
                                <input type="checkbox" class="form-check-input permission-chk" data-role="Staff" @(row.Staff ? "checked" : "") />
                            </td>
                            <td>
                                <input type="checkbox" class="form-check-input permission-chk" data-role="Customer" @(row.Customer ? "checked" : "") />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // ── Toast helper ─────────────────────────────────────────────────────
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            if (!container) return;
            var colors = {
                success: { bg: 'rgba(16,185,129,.95)', icon: 'fa-circle-check' },
                error:   { bg: 'rgba(239,68,68,.95)',  icon: 'fa-circle-xmark' },
                info:    { bg: 'rgba(59,130,246,.95)',  icon: 'fa-circle-info'  }
            };
            var cfg = colors[type] || colors.info;
            var toast = document.createElement('div');
            toast.style.cssText = [
                'background:' + cfg.bg,
                'color:#fff', 'padding:12px 18px', 'border-radius:10px',
                'font-size:.9rem', 'display:flex', 'align-items:center', 'gap:10px',
                'box-shadow:0 4px 20px rgba(0,0,0,.4)', 'pointer-events:auto',
                'opacity:0', 'transform:translateX(40px)',
                'transition:all .3s ease', 'min-width:280px', 'max-width:420px',
                'word-break:break-word'
            ].join(';');
            toast.innerHTML = '<i class="fa-solid ' + cfg.icon + '" style="flex-shrink:0"></i>' +
                              '<span>' + message + '</span>';
            container.appendChild(toast);
            requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                    toast.style.opacity = '1';
                    toast.style.transform = 'translateX(0)';
                });
            });
            setTimeout(function () {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(40px)';
                setTimeout(function () { toast.remove(); }, 350);
            }, 4000);
        }

        // ── Save permission matrix ────────────────────────────────────────────
        document.getElementById('btnSavePermissions')?.addEventListener('click', async function () {
            var btn = this;
            var originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> Đang lưu...';

            var rows = [];
            document.querySelectorAll('#permissionTable tbody tr').forEach(function (tr) {
                var feature = tr.getAttribute('data-feature');
                var getChk = function (role) {
                    return tr.querySelector('.permission-chk[data-role="' + role + '"]')?.checked || false;
                };
                rows.push({
                    feature: feature,
                    admin:    getChk('Admin'),
                    manager:  getChk('Manager'),
                    staff:    getChk('Staff'),
                    customer: getChk('Customer')
                });
            });

            // ✅ CSRF header name khớp với Program.cs: options.HeaderName = "RequestVerificationToken"
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            try {
                var res = await fetch('/Admin/Roles/UpdatePermissionMatrix', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(rows)
                });

                var result;
                try { result = await res.json(); }
                catch { result = { success: false, message: 'Phản hồi không hợp lệ (HTTP ' + res.status + ').' }; }

                if (result.success) {
                    showToast(result.message || 'Cập nhật phân quyền thành công!', 'success');
                } else {
                    showToast(result.message || 'Cập nhật thất bại.', 'error');
                }
            } catch (err) {
                showToast('Có lỗi xảy ra: ' + (err.message || err), 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });
    </script>
}
