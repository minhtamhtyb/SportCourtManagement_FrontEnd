                        <div class="d-flex align-items-center gap-3 border-top pt-3" style="border-top-color: rgba(255,255,255,0.05) !important;">
                            <span class="rounded-circle d-flex align-items-center justify-content-center text-white font-outfit" style="width: 38px; height: 38px; background: linear-gradient(135deg, #F59E0B 0%, #EF4444 100%); font-weight: 700; font-size: 13px;">KM</span>
