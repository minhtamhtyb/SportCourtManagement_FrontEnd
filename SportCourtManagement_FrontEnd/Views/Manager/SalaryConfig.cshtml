@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Salary Configuration";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/salary-config.css" asp-append-version="true" />
}

<div class="salary-config-container">
    <!-- Module Header & Tabs -->
    <div class="module-header">
        <div class="module-title">
            <h3>Quản lý nhân sự</h3>
            <p>Cấu hình mức lương cơ bản, lương theo ca, phụ cấp và các quy tắc phạt chuyên cần.</p>
        </div>
        <div class="header-actions">
            <button class="btn-secondary-custom">
                <span class="material-symbols-outlined">history</span>
                Lịch sử thay đổi
            </button>
            <button class="btn-primary-custom" onclick="alert('Lưu cấu hình thành công!')">
                <span class="material-symbols-outlined">save</span>
                Lưu cấu hình
            </button>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-navigation">
        <a class="tab-link" href="/manager/staff/shifts">
            Lịch trực hàng tuần
        </a>
        <a class="tab-link" href="/manager/staff/attendance">
            Chấm công &amp; Chuyên cần
        </a>
        <a class="tab-link" href="/manager/staff/list">
            Danh sách nhân viên
        </a>
        <a class="tab-link active" href="/manager/staff/salary">
            Cấu hình tiền lương
        </a>
    </div>

    <!-- Configuration Grid Layout -->
    <div class="config-grid">
        <!-- Panel 1: Salary by Role -->
        <div class="glass-panel">
            <div class="panel-header">
                <span class="material-symbols-outlined">payments</span>
                <h4>Mức lương theo Vai trò</h4>
            </div>
            
            <div class="config-group">
                <!-- Role 1 -->
                <div class="role-rate-card">
                    <div class="role-details">
                        <span class="role-title-text">Quản lý (Manager)</span>
                        <span class="role-subtitle-text">Chịu trách nhiệm vận hành chi nhánh</span>
                    </div>
                    <div class="rate-inputs">
                        <input type="text" value="50.000" />
                        <span class="rate-label-addon">đ/giờ</span>
                    </div>
                </div>

                <!-- Role 2 -->
                <div class="role-rate-card">
                    <div class="role-details">
                        <span class="role-title-text">Nhân viên sân (Court Staff)</span>
                        <span class="role-subtitle-text">Hỗ trợ khách hàng, dọn dẹp sân</span>
                    </div>
                    <div class="rate-inputs">
                        <input type="text" value="25.000" />
                        <span class="rate-label-addon">đ/giờ</span>
                    </div>
                </div>

                <!-- Role 3 -->
                <div class="role-rate-card">
                    <div class="role-details">
                        <span class="role-title-text">Kỹ thuật (Technical Staff)</span>
                        <span class="role-subtitle-text">Bảo trì hệ thống ánh sáng, cơ sở vật chất</span>
                    </div>
                    <div class="rate-inputs">
                        <input type="text" value="35.000" />
                        <span class="rate-label-addon">đ/giờ</span>
                    </div>
                </div>

                <div class="form-item" style="margin-top: 16px;">
                    <label>Hệ số lương làm thêm giờ (OT)</label>
                    <div class="input-with-addon">
                        <input type="text" value="1.5" style="text-align: right;" />
                        <span class="input-addon">Hệ số</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel 2: Attendance & Allowances rules -->
        <div class="glass-panel">
            <div class="panel-header">
                <span class="material-symbols-outlined">rule</span>
                <h4>Quy tắc chuyên cần &amp; Phụ cấp</h4>
            </div>

            <div class="config-group">
                <div class="form-item">
                    <label>Khấu trừ đi muộn (Mỗi phút)</label>
                    <div class="input-with-addon">
                        <input type="text" value="1.000" style="text-align: right;" />
                        <span class="input-addon">VNĐ / phút</span>
                    </div>
                </div>

                <div class="form-item">
                    <label>Khấu trừ về sớm (Mỗi phút)</label>
                    <div class="input-with-addon">
                        <input type="text" value="1.000" style="text-align: right;" />
                        <span class="input-addon">VNĐ / phút</span>
                    </div>
                </div>

                <div class="form-item">
                    <label>Phụ cấp tiền ăn (Mỗi ca trực)</label>
                    <div class="input-with-addon">
                        <input type="text" value="30.000" style="text-align: right;" />
                        <span class="input-addon">VNĐ / ca</span>
                    </div>
                </div>

                <div class="form-item">
                    <label>Phụ cấp xăng xe / đi lại (Mỗi ca trực)</label>
                    <div class="input-with-addon">
                        <input type="text" value="15.000" style="text-align: right;" />
                        <span class="input-addon">VNĐ / ca</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
