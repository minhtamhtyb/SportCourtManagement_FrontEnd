                        <div class="actions-cell">
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Xóa">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Row 4: Cancelled -->
                <tr data-id="4" data-court-id="1" data-court-name="Khu WC" data-type="Upgrade" data-reason="Lắp thêm bồn rửa tay mới khu nhà vệ sinh" data-start="2026-06-20T14:00" data-end="2026-06-20T18:00" data-status="Cancelled" data-staff-id="" data-staff-name="Chưa phân công" data-result="Từ chối: Không đủ ngân sách quý này">
                    <td>
                        <div class="court-cell">
                            <div class="court-icon">
                                <span class="material-symbols-outlined">sports_tennis</span>
                            </div>
                            <div>
                                <p class="court-name">Khu WC</p>
                                <p class="court-location">ProCourt – Chi nhánh Q1</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="type-badge upgrade">Upgrade</span></td>
                    <td class="reason-cell">Lắp thêm bồn rửa tay mới khu nhà vệ sinh</td>
