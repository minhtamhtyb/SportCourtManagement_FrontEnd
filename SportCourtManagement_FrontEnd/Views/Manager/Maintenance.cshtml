@{
    ViewData["Title"] = "Bảo trì sân | ProCourt";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/maintenance.css" asp-append-version="true" />
}

<div class="maintenance-container">

    <!-- Module Header -->
    <div class="module-header">
        <div class="module-title">
            <h3>Bảo trì sân</h3>
            <p>Theo dõi lịch bảo trì sân theo trạng thái: <strong>Pending</strong>, <strong>InProgress</strong>, <strong>Completed</strong>, <strong>Cancelled</strong>.</p>
        </div>
        <div class="header-actions">
            <a class="btn-secondary-custom" href="#">
                <span class="material-symbols-outlined">download</span>
                Xuất báo cáo
            </a>
            <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createMaintenanceModal">
                <span class="material-symbols-outlined">add</span>
                Tạo lịch bảo trì
            </button>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="summary-stats">
        <div class="stat-card glass-panel">
            <div class="stat-icon orange">
                <span class="material-symbols-outlined">pending_actions</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Pending</p>
                <span class="stat-value orange">5</span>
                <p class="stat-sub">Chờ bắt đầu</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon sky">
                <span class="material-symbols-outlined">construction</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">In Progress</p>
                <span class="stat-value sky">3</span>
                <p class="stat-sub">Đang thi công – Sân bị khoá</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon emerald">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Completed</p>
                <span class="stat-value emerald">18</span>
                <p class="stat-sub">Hoàn thành tháng này</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon rose">
                <span class="material-symbols-outlined">cancel</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Cancelled</p>
                <span class="stat-value rose">2</span>
                <p class="stat-sub">Bị huỷ / từ chối</p>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar-container">
        <div class="toolbar-filters">
            <div class="search-input-wrapper">
                <span class="material-symbols-outlined">search</span>
                <input type="text" id="searchInput" placeholder="Tìm theo tên sân, loại bảo trì..." />
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">filter_list</span>
                <select id="statusFilter">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Pending">Pending</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">build</span>
                <select id="typeFilter">
                    <option value="">Tất cả loại bảo trì</option>
                    <option value="Routine">Routine (Định kỳ)</option>
                    <option value="Emergency">Emergency (Khẩn cấp)</option>
                    <option value="Upgrade">Upgrade (Nâng cấp)</option>
                    <option value="Inspection">Inspection (Kiểm tra)</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Maintenance Table -->
    <div class="table-panel glass-panel">
        <table class="maintenance-table">
            <thead>
                <tr>
                    <th>Sân</th>
                    <th>Loại bảo trì</th>
                    <th>Lý do / Mô tả</th>
                    <th>Thời gian</th>
                    <th>Trạng thái</th>
                    <th>Người phụ trách</th>
                    <th>Kết quả</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <!-- Row 1: Pending -->
                <tr data-id="1" data-court-id="1" data-court-name="Sân A1" data-type="Emergency" data-reason="Thay đèn chiếu sáng bị hỏng, mất 3/8 bóng" data-start="2026-06-28T06:00" data-end="2026-06-28T14:00" data-status="Pending" data-staff-id="1" data-staff-name="Lê Hoàng C" data-result="–">
                    <td>
                        <div class="court-cell">
                            <div class="court-icon">
                                <span class="material-symbols-outlined">sports_tennis</span>
                            </div>
                            <div>
                                <p class="court-name">Sân A1</p>
                                <p class="court-location">ProCourt – Chi nhánh Q1</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="type-badge emergency">Emergency</span></td>
                    <td class="reason-cell">Thay đèn chiếu sáng bị hỏng, mất 3/8 bóng</td>
                    <td>
                        <p class="time-start">28/06 06:00</p>
                        <p class="time-end">28/06 14:00</p>
                    </td>
                    <td><span class="status-badge pending">Pending</span></td>
                    <td>
                        <div class="assigned-cell">
                            <div class="assigned-avatar">
                                <img alt="Lê Hoàng C" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZC88s__sDzig7zx6x5SRgxmC_F5FKkS3a6sskzkbNOIeavyfvYbYYaa2wKvYMaA1Wl_gWOSReizjq_R2G99Wpy79k4HMOFXGkgcSiEx5PuG_m9L_mGmLPWTmGpbZe6hn_u1AERYQhoR_F2MHib22eYE-VjaZ4OVRrc_-qhiRZpqHOYBfJrPB4pHx1BJEb2RErunCQ7NOv5FzQQ8s4PZ2C4Na_lXICTtJvS5SwXt5y9E730TjkiqOgPRJvl1lJ9mKaIF6hMOn3u1w" />
                            </div>
                            <span class="assigned-name">Lê Hoàng C</span>
                        </div>
                    </td>
                    <td class="result-cell">–</td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn verify" title="Duyệt / Từ chối">
                                <span class="material-symbols-outlined">how_to_reg</span>
                            </button>
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Xóa">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Row 2: InProgress -->
                <tr data-id="2" data-court-id="2" data-court-name="Sân B3" data-type="Routine" data-reason="Căng lại lưới sân, thay dây cọc bị mòn" data-start="2026-06-28T08:00" data-end="2026-06-28T12:00" data-status="InProgress" data-staff-id="2" data-staff-name="Đỗ Hoàng Long" data-result="Đang thi công – Sân tạm đóng">
                    <td>
                        <div class="court-cell">
                            <div class="court-icon">
                                <span class="material-symbols-outlined">sports_tennis</span>
                            </div>
                            <div>
                                <p class="court-name">Sân B3</p>
                                <p class="court-location">ProCourt – Chi nhánh Q1</p>
                            </div>
