                    <div class="form-group">
                        <label class="form-label-custom">Thời gian kết thúc (EndDateTime)</label>
                        <input type="datetime-local" class="form-input-custom" id="editEndDateTime" />
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Nhân viên phụ trách (AssignedStaffId)</label>
                        <select class="form-input-custom" id="editAssignedStaffId">
