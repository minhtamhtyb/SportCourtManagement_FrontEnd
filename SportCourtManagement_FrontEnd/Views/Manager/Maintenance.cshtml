                    </td>
                    <td><span class="type-badge routine">Routine</span></td>
                    <td class="reason-cell">Căng lại lưới sân, thay dây cọc bị mòn</td>
                    <td>
                        <p class="time-start">28/06 08:00</p>
                        <p class="time-end">28/06 12:00</p>
                    </td>
                    <td><span class="status-badge in-progress">In Progress</span></td>
                    <td>
                        <div class="assigned-cell">
                            <div class="assigned-avatar">
                                <img alt="Đỗ Hoàng Long" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCcEWKF1CnspJSj_QYaU3G1i4pdivJ2Jv77qI2KCvJ1ciOYJFq5-rcFVNW0mGZdy6kkEqQ0xxoXLPnPf3f4dqydPkgMG7DV6MqRIKXw-4slH12hU2hekitsuTSPxVCJ9_Ea63bmsLRUU7iEHZrEK-IlZTSIUqGNp8QhZFNoFqQ9a3-i7ad9bTmo69xYaqTfDKfv83raCHzg2VtQoMFcmZRXiQKF7b_vskHMZJa-0kHtKNeMFNVDr6d-1ADKqg4K4mwLk4owz5N5jrY" />
                            </div>
                            <span class="assigned-name">Đỗ Hoàng Long</span>
                        </div>
                    </td>
                    <td class="result-cell">Đang thi công – Sân tạm đóng</td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn verify" title="Duyệt / Từ chối">
                                <span class="material-symbols-outlined">how_to_reg</span>
                            </button>
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Xóa">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Row 3: Completed -->
                <tr data-id="3" data-court-id="3" data-court-name="Sân C2" data-type="Inspection" data-reason="Kiểm tra định kỳ hệ thống điện toàn bộ tầng 3" data-start="2026-06-25T09:00" data-end="2026-06-25T11:00" data-status="Completed" data-staff-id="1" data-staff-name="Lê Hoàng C" data-result="Đã hoàn thành bảo trì (Duyệt bởi Manager)">
                    <td>
                        <div class="court-cell">
                            <div class="court-icon">
                                <span class="material-symbols-outlined">sports_tennis</span>
                            </div>
                            <div>
                                <p class="court-name">Sân C2</p>
                                <p class="court-location">ProCourt – Chi nhánh Q1</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="type-badge inspection">Inspection</span></td>
                    <td class="reason-cell">Kiểm tra định kỳ hệ thống điện toàn bộ tầng 3</td>
                    <td>
                        <p class="time-start">25/06 09:00</p>
                        <p class="time-end">25/06 11:00</p>
                    </td>
                    <td><span class="status-badge done">Completed</span></td>
                    <td>
                        <div class="assigned-cell">
                            <div class="assigned-avatar">
                                <img alt="Lê Hoàng C" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZC88s__sDzig7zx6x5SRgxmC_F5FKkS3a6sskzkbNOIeavyfvYbYYaa2wKvYMaA1Wl_gWOSReizjq_R2G99Wpy79k4HMOFXGkgcSiEx5PuG_m9L_mGmLPWTmGpbZe6hn_u1AERYQhoR_F2MHib22eYE-VjaZ4OVRrc_-qhiRZpqHOYBfJrPB4pHx1BJEb2RErunCQ7NOv5FzQQ8s4PZ2C4Na_lXICTtJvS5SwXt5y9E730TjkiqOgPRJvl1lJ9mKaIF6hMOn3u1w" />
                            </div>
                            <span class="assigned-name">Lê Hoàng C</span>
                        </div>
                    </td>
                    <td class="result-cell" style="color: var(--emerald-400);">Đã hoàn thành bảo trì (Duyệt bởi Manager)</td>
