                    </div>
                    <div class="form-group form-group-full">
                        <label class="form-label-custom">Ghi chú kết quả (Result)</label>
                        <textarea class="form-input-custom" id="editResult" rows="2" maxlength="500" placeholder="Nhập kết quả, ghi chú sau bảo trì (tối đa 500 ký tự)..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer maintenance-modal-footer">
                <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-primary-custom" id="saveEditMaintenanceBtn">
                    <span class="material-symbols-outlined">save</span>
                    Lưu thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Verify Maintenance Modal -->
<div class="modal fade" id="verifyMaintenanceModal" tabindex="-1" aria-labelledby="verifyMaintenanceLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content maintenance-modal-content">
            <div class="modal-header maintenance-modal-header">
                <h5 class="modal-title" id="verifyMaintenanceLabel">
                    <span class="material-symbols-outlined">how_to_reg</span>
                    Phê duyệt / Từ chối lịch bảo trì
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="verifyMaintenanceId" />
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <div class="form-group">
                        <label class="form-label-custom">Quyết định (IsApproved)</label>
                        <div style="display: flex; gap: 20px; margin-top: 6px;">
                            <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; color: var(--on-surface);">
                                <input type="radio" name="verifyIsApproved" value="true" checked style="accent-color: var(--primary);" />
                                <span class="material-symbols-outlined" style="color: var(--emerald-400); font-size: 18px;">check_circle</span>
                                Duyệt (Chuyển sang Completed)
                            </label>
                            <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; color: var(--on-surface);">
                                <input type="radio" name="verifyIsApproved" value="false" style="accent-color: var(--primary);" />
                                <span class="material-symbols-outlined" style="color: var(--rose-400); font-size: 18px;">cancel</span>
                                Từ chối (Chuyển sang Cancelled)
                            </label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Ghi chú phê duyệt (Note)</label>
                        <textarea class="form-input-custom" id="verifyNote" rows="3" maxlength="500" placeholder="Nhập ghi chú phê duyệt hoặc lý do từ chối (tối đa 500 ký tự)..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer maintenance-modal-footer">
                <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-primary-custom" id="saveVerifyMaintenanceBtn">
                    <span class="material-symbols-outlined">send</span>
                    Gửi quyết định
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Setup state variables
        let activeRow = null;

        // Custom sliding Toast notification
        function showToast(message, type = 'success') {
            let container = document.getElementById('toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.style.position = 'fixed';
                container.style.bottom = '24px';
                container.style.right = '24px';
                container.style.zIndex = '9999';
                container.style.display = 'flex';
                container.style.flexDirection = 'column';
                container.style.gap = '10px';
                document.body.appendChild(container);
            }

            const toast = document.createElement('div');
            toast.className = `toast-notification ${type}`;
            toast.style.backgroundColor = 'var(--surface-container-high, #1e1e24)';
            toast.style.color = 'var(--on-surface, #e4e4eb)';
            toast.style.padding = '14px 20px';
            toast.style.borderRadius = '8px';
            toast.style.boxShadow = '0 8px 16px rgba(0,0,0,0.3)';
            toast.style.display = 'flex';
            toast.style.alignItems = 'center';
            toast.style.gap = '10px';
            toast.style.minWidth = '280px';
            toast.style.borderLeft = `4px solid ${type === 'success' ? 'var(--emerald-400, #10b981)' : 'var(--rose-400, #f43f5e)'}`;
            toast.style.animation = 'slideIn 0.3s ease forwards';

            const iconName = type === 'success' ? 'check_circle' : 'error';
            const iconColor = type === 'success' ? 'var(--emerald-400)' : 'var(--rose-400)';

            toast.innerHTML = `
                <span class="material-symbols-outlined" style="color: ${iconColor}">${iconName}</span>
                <span style="font-size: 13px; font-weight: 500;">${message}</span>
            `;

            container.appendChild(toast);

            setTimeout(() => {
                toast.style.animation = 'fadeOut 0.3s ease forwards';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Search & Filter Logic
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const typeFilter = document.getElementById('typeFilter');
        const tableRows = document.querySelectorAll('.maintenance-table tbody tr');

        function filterTable() {
            const query = searchInput.value.toLowerCase().trim();
            const status = statusFilter.value;
            const type = typeFilter.value;

            tableRows.forEach(row => {
                const courtName = row.dataset.courtName.toLowerCase();
                const reason = row.dataset.reason.toLowerCase();
                const rowStatus = row.dataset.status;
                const rowType = row.dataset.type;

                const matchesSearch = courtName.includes(query) || reason.includes(query);
                const matchesStatus = !status || rowStatus === status;
                const matchesType = !type || rowType === type;

                if (matchesSearch && matchesStatus && matchesType) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
            updatePaginationInfo();
        }

        searchInput.addEventListener('input', filterTable);
        statusFilter.addEventListener('change', filterTable);
        typeFilter.addEventListener('change', filterTable);

        // Helper to update displayed stats count based on table rows
        function updateStats() {
            let pendingCount = 0;
            let inProgressCount = 0;
            let completedCount = 0;
            let cancelledCount = 0;

            document.querySelectorAll('.maintenance-table tbody tr').forEach(row => {
                const status = row.dataset.status;
                if (status === 'Pending') pendingCount++;
                else if (status === 'InProgress') inProgressCount++;
                else if (status === 'Completed') completedCount++;
                else if (status === 'Cancelled') cancelledCount++;
            });

            // Update stats widgets
            document.querySelector('.summary-stats .stat-card:nth-child(1) .stat-value').textContent = pendingCount;
            document.querySelector('.summary-stats .stat-card:nth-child(2) .stat-value').textContent = inProgressCount;
            document.querySelector('.summary-stats .stat-card:nth-child(3) .stat-value').textContent = completedCount;
            document.querySelector('.summary-stats .stat-card:nth-child(4) .stat-value').textContent = cancelledCount;
        }

        function updatePaginationInfo() {
            const visibleRows = Array.from(document.querySelectorAll('.maintenance-table tbody tr')).filter(r => r.style.display !== 'none').length;
            const totalRows = document.querySelectorAll('.maintenance-table tbody tr').length;
            document.querySelector('.pagination-info').textContent = `Hiển thị 1 - ${visibleRows} của ${totalRows} lịch bảo trì`;
        }

        // Trigger action click events inside table using Event Delegation
        document.querySelector('.maintenance-table tbody').addEventListener('click', function(e) {
            const btnEdit = e.target.closest('.action-icon-btn.edit');
            const btnVerify = e.target.closest('.action-icon-btn.verify');
            const btnDelete = e.target.closest('.action-icon-btn.delete');
            const row = e.target.closest('tr');

            if (row) {
                activeRow = row;
            }

            if (btnEdit) {
                // Populate edit modal fields
                document.getElementById('editMaintenanceId').value = row.dataset.id;
                document.getElementById('editCourtId').value = row.dataset.courtId;
                document.getElementById('editMaintenanceType').value = row.dataset.type;
                document.getElementById('editStartDateTime').value = row.dataset.start;
                document.getElementById('editEndDateTime').value = row.dataset.end;
                document.getElementById('editAssignedStaffId').value = row.dataset.staffId || '';
                document.getElementById('editStatus').value = row.dataset.status;
                document.getElementById('editReason').value = row.dataset.reason;
                document.getElementById('editResult').value = row.dataset.result === '–' ? '' : row.dataset.result;

                const editModal = new bootstrap.Modal(document.getElementById('editMaintenanceModal'));
                editModal.show();
            }

            if (btnVerify) {
                document.getElementById('verifyMaintenanceId').value = row.dataset.id;
                document.getElementById('verifyNote').value = '';
                document.querySelector('input[name="verifyIsApproved"][value="true"]').checked = true;

                const verifyModal = new bootstrap.Modal(document.getElementById('verifyMaintenanceModal'));
                verifyModal.show();
            }

            if (btnDelete) {
                if (confirm(`Bạn có chắc chắn muốn xóa lịch bảo trì cho ${row.dataset.courtName}?`)) {
                    row.remove();
                    showToast('Đã xóa lịch bảo trì thành công!', 'success');
                    updateStats();
                    updatePaginationInfo();
                }
            }
        });

        // Save Create Logic (CreateMaintenanceRequest)
        document.getElementById('saveCreateMaintenanceBtn').addEventListener('click', () => {
            const courtId = document.getElementById('createCourtId').value;
            const courtName = document.querySelector(`#createCourtId option[value="${courtId}"]`)?.textContent || '';
            const type = document.getElementById('createMaintenanceType').value;
            const start = document.getElementById('createStartDateTime').value;
            const end = document.getElementById('createEndDateTime').value;
            const staffId = document.getElementById('createAssignedStaffId').value;
            const staffName = document.querySelector(`#createAssignedStaffId option[value="${staffId}"]`)?.textContent || 'Chưa phân công';
            const status = document.getElementById('createStatus').value;
            const reason = document.getElementById('createReason').value;

            if (!courtId) {
                showToast('Vui lòng chọn sân!', 'error');
                return;
            }
            if (!start || !end) {
                showToast('Vui lòng nhập thời gian bắt đầu và kết thúc!', 'error');
                return;
            }
            if (!reason) {
                showToast('Vui lòng nhập lý do bảo trì!', 'error');
                return;
            }

            // Create new row
            const mockId = Math.floor(Math.random() * 9000) + 1000;
            const tbody = document.querySelector('.maintenance-table tbody');
            const tr = document.createElement('tr');

            tr.dataset.id = mockId;
            tr.dataset.courtId = courtId;
            tr.dataset.courtName = courtName;
            tr.dataset.type = type;
            tr.dataset.reason = reason;
            tr.dataset.start = start;
            tr.dataset.end = end;
            tr.dataset.status = status;
            tr.dataset.staffId = staffId;
            tr.dataset.staffName = staffName;
            tr.dataset.result = '–';

            // Format date for visual representation
            const startFormatted = start.replace('T', ' ');
            const endFormatted = end.replace('T', ' ');

            // Status badges
            let statusBadgeClass = status.toLowerCase();
            if (status === 'InProgress') statusBadgeClass = 'in-progress';
            if (status === 'Completed') statusBadgeClass = 'done';
            if (status === 'Cancelled') statusBadgeClass = 'cancelled';

            // Avatar for staff
            const avatarHtml = staffId ? `
                <div class="assigned-cell">
                    <div class="assigned-avatar">
                        <img alt="${staffName}" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZC88s__sDzig7zx6x5SRgxmC_F5FKkS3a6sskzkbNOIeavyfvYbYYaa2wKvYMaA1Wl_gWOSReizjq_R2G99Wpy79k4HMOFXGkgcSiEx5PuG_m9L_mGmLPWTmGpbZe6hn_u1AERYQhoR_F2MHib22eYE-VjaZ4OVRrc_-qhiRZpqHOYBfJrPB4pHx1BJEb2RErunCQ7NOv5FzQQ8s4PZ2C4Na_lXICTtJvS5SwXt5y9E730TjkiqOgPRJvl1lJ9mKaIF6hMOn3u1w" />
                    </div>
                    <span class="assigned-name">${staffName}</span>
                </div>
            ` : `<span class="assigned-name" style="color: var(--on-surface-variant);">Chưa phân công</span>`;

            // Action buttons
            const verifyButtonHtml = (status === 'Pending' || status === 'InProgress') ? `
                <button class="action-icon-btn verify" title="Duyệt / Từ chối">
                    <span class="material-symbols-outlined">how_to_reg</span>
                </button>
            ` : '';

            tr.innerHTML = `
                <td>
                    <div class="court-cell">
                        <div class="court-icon">
                            <span class="material-symbols-outlined">sports_tennis</span>
                        </div>
                        <div>
                            <p class="court-name">${courtName}</p>
                            <p class="court-location">ProCourt – Chi nhánh Q1</p>
                        </div>
                    </div>
                </td>
                <td><span class="type-badge ${type.toLowerCase()}">${type}</span></td>
                <td class="reason-cell">${reason}</td>
                <td>
                    <p class="time-start">${startFormatted.split(' ')[0]} ${startFormatted.split(' ')[1] || ''}</p>
                    <p class="time-end">${endFormatted.split(' ')[0]} ${endFormatted.split(' ')[1] || ''}</p>
                </td>
                <td><span class="status-badge ${statusBadgeClass}">${status}</span></td>
                <td>${avatarHtml}</td>
                <td class="result-cell">–</td>
                <td>
                    <div class="actions-cell">
                        ${verifyButtonHtml}
                        <button class="action-icon-btn edit" title="Chỉnh sửa">
                            <span class="material-symbols-outlined">edit</span>
                        </button>
                        <button class="action-icon-btn delete" title="Xóa">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </div>
                </td>
            `;

            tbody.insertBefore(tr, tbody.firstChild);

            // Hide modal & reset
            const modalEl = document.getElementById('createMaintenanceModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();

            // Clear inputs
            document.getElementById('createCourtId').value = '';
            document.getElementById('createStartDateTime').value = '';
            document.getElementById('createEndDateTime').value = '';
            document.getElementById('createAssignedStaffId').value = '';
            document.getElementById('createReason').value = '';

            showToast('Tạo lịch bảo trì mới thành công!');
            updateStats();
            updatePaginationInfo();
        });

        // Save Edit Logic (UpdateMaintenanceRequest)
        document.getElementById('saveEditMaintenanceBtn').addEventListener('click', () => {
            if (!activeRow) return;

            const courtId = document.getElementById('editCourtId').value;
            const courtName = document.querySelector(`#editCourtId option[value="${courtId}"]`)?.textContent || '';
            const type = document.getElementById('editMaintenanceType').value;
            const start = document.getElementById('editStartDateTime').value;
            const end = document.getElementById('editEndDateTime').value;
            const staffId = document.getElementById('editAssignedStaffId').value;
            const staffName = document.querySelector(`#editAssignedStaffId option[value="${staffId}"]`)?.textContent || 'Chưa phân công';
            const status = document.getElementById('editStatus').value;
            const reason = document.getElementById('editReason').value;
            const result = document.getElementById('editResult').value;

            if (!courtId) {
                showToast('Vui lòng chọn sân!', 'error');
                return;
            }
            if (!start || !end) {
                showToast('Vui lòng nhập thời gian bắt đầu và kết thúc!', 'error');
                return;
            }
            if (!reason) {
                showToast('Vui lòng nhập lý do bảo trì!', 'error');
                return;
            }

            // Update row dataset
            activeRow.dataset.courtId = courtId;
            activeRow.dataset.courtName = courtName;
            activeRow.dataset.type = type;
            activeRow.dataset.reason = reason;
            activeRow.dataset.start = start;
            activeRow.dataset.end = end;
            activeRow.dataset.status = status;
            activeRow.dataset.staffId = staffId;
            activeRow.dataset.staffName = staffName;
            activeRow.dataset.result = result || '–';

            // Update UI components in the row
            activeRow.querySelector('.court-name').textContent = courtName;
            
            const typeBadge = activeRow.querySelector('.type-badge');
            typeBadge.className = `type-badge ${type.toLowerCase()}`;
            typeBadge.textContent = type;

            activeRow.querySelector('.reason-cell').textContent = reason;

            // Format date for display
            const startFormatted = start.replace('T', ' ');
            const endFormatted = end.replace('T', ' ');
            activeRow.querySelector('.time-start').textContent = `${startFormatted.split(' ')[0]} ${startFormatted.split(' ')[1] || ''}`;
            activeRow.querySelector('.time-end').textContent = `${endFormatted.split(' ')[0]} ${endFormatted.split(' ')[1] || ''}`;

            // Status Badge update
            let statusBadgeClass = status.toLowerCase();
            if (status === 'InProgress') statusBadgeClass = 'in-progress';
            if (status === 'Completed') statusBadgeClass = 'done';
            if (status === 'Cancelled') statusBadgeClass = 'cancelled';
            const statusBadge = activeRow.querySelector('.status-badge');
            statusBadge.className = `status-badge ${statusBadgeClass}`;
            statusBadge.textContent = status;

            // Staff cell
            const staffContainer = activeRow.cells[5];
            if (staffId) {
                staffContainer.innerHTML = `
                    <div class="assigned-cell">
                        <div class="assigned-avatar">
                            <img alt="${staffName}" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZC88s__sDzig7zx6x5SRgxmC_F5FKkS3a6sskzkbNOIeavyfvYbYYaa2wKvYMaA1Wl_gWOSReizjq_R2G99Wpy79k4HMOFXGkgcSiEx5PuG_m9L_mGmLPWTmGpbZe6hn_u1AERYQhoR_F2MHib22eYE-VjaZ4OVRrc_-qhiRZpqHOYBfJrPB4pHx1BJEb2RErunCQ7NOv5FzQQ8s4PZ2C4Na_lXICTtJvS5SwXt5y9E730TjkiqOgPRJvl1lJ9mKaIF6hMOn3u1w" />
                        </div>
                        <span class="assigned-name">${staffName}</span>
                    </div>
                `;
            } else {
                staffContainer.innerHTML = `<span class="assigned-name" style="color: var(--on-surface-variant);">Chưa phân công</span>`;
            }

            // Result cell
            const resultCell = activeRow.querySelector('.result-cell');
            resultCell.textContent = result || '–';
            if (status === 'Completed') {
                resultCell.style.color = 'var(--emerald-400)';
            } else if (status === 'Cancelled') {
                resultCell.style.color = 'var(--rose-400)';
            } else {
                resultCell.style.color = '';
            }

            // Update verify button visibility
            const actionsCell = activeRow.querySelector('.actions-cell');
            let verifyBtn = actionsCell.querySelector('.verify');
            if (status === 'Pending' || status === 'InProgress') {
                if (!verifyBtn) {
                    const btn = document.createElement('button');
                    btn.className = 'action-icon-btn verify';
                    btn.title = 'Duyệt / Từ chối';
                    btn.innerHTML = `<span class="material-symbols-outlined">how_to_reg</span>`;
                    actionsCell.insertBefore(btn, actionsCell.firstChild);
                }
            } else {
                if (verifyBtn) verifyBtn.remove();
            }

            // Hide modal
            const modalEl = document.getElementById('editMaintenanceModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();

            showToast('Cập nhật thông tin bảo trì thành công!');
            updateStats();
        });

        // Save Verify Logic (VerifyMaintenanceRequest)
        document.getElementById('saveVerifyMaintenanceBtn').addEventListener('click', () => {
            if (!activeRow) return;

            const isApproved = document.querySelector('input[name="verifyIsApproved"]:checked').value === 'true';
            const note = document.getElementById('verifyNote').value;

            // Map verify request response
            const targetStatus = isApproved ? 'Completed' : 'Cancelled';
            const resultText = isApproved ? `Đã hoàn thành: ${note || 'Manager phê duyệt'}` : `Từ chối: ${note || 'Lý do từ chối'}`;

            // Update row dataset
            activeRow.dataset.status = targetStatus;
            activeRow.dataset.result = resultText;

            // Status Badge update
            const statusBadge = activeRow.querySelector('.status-badge');
            statusBadge.className = `status-badge ${isApproved ? 'done' : 'cancelled'}`;
            statusBadge.textContent = targetStatus;

            // Result cell
            const resultCell = activeRow.querySelector('.result-cell');
            resultCell.textContent = resultText;
            resultCell.style.color = isApproved ? 'var(--emerald-400)' : 'var(--rose-400)';

            // Remove verify action button since it's now finalized
            const verifyBtn = activeRow.querySelector('.action-icon-btn.verify');
            if (verifyBtn) verifyBtn.remove();

            // Hide modal
            const modalEl = document.getElementById('verifyMaintenanceModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();

            showToast(isApproved ? 'Đã duyệt lịch bảo trì thành công!' : 'Đã từ chối lịch bảo trì!', isApproved ? 'success' : 'error');
            updateStats();
        });
    </script>
}
