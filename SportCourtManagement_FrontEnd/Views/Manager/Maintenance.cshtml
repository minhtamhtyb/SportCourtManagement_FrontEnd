            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-panel">
        <p class="pagination-info">Hiển thị 1 - 4 của 28 lịch bảo trì</p>
        <div class="pagination-buttons">
            <button class="pagination-btn" disabled>
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="pagination-btn active">1</button>
            <button class="pagination-btn">2</button>
            <button class="pagination-btn">3</button>
            <button class="pagination-btn">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    </div>

</div>

<!-- Create Maintenance Modal -->
<div class="modal fade" id="createMaintenanceModal" tabindex="-1" aria-labelledby="createMaintenanceLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content maintenance-modal-content">
            <div class="modal-header maintenance-modal-header">
                <h5 class="modal-title" id="createMaintenanceLabel">
                    <span class="material-symbols-outlined">handyman</span>
                    Tạo lịch bảo trì mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="modal-form-grid">
                    <div class="form-group">
                        <label class="form-label-custom">Sân (CourtId)</label>
                        <select class="form-input-custom" id="createCourtId">
                            <option value="">-- Chọn sân --</option>
                            <option value="1">Sân A1</option>
                            <option value="2">Sân B3</option>
                            <option value="3">Sân C2</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Loại bảo trì (MaintenanceType)</label>
                        <select class="form-input-custom" id="createMaintenanceType">
                            <option value="Routine">Routine – Định kỳ</option>
                            <option value="Emergency">Emergency – Khẩn cấp</option>
                            <option value="Upgrade">Upgrade – Nâng cấp</option>
                            <option value="Inspection">Inspection – Kiểm tra</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Thời gian bắt đầu (StartDateTime)</label>
                        <input type="datetime-local" class="form-input-custom" id="createStartDateTime" />
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Thời gian kết thúc (EndDateTime)</label>
                        <input type="datetime-local" class="form-input-custom" id="createEndDateTime" />
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Nhân viên phụ trách (AssignedStaffId)</label>
                        <select class="form-input-custom" id="createAssignedStaffId">
                            <option value="">-- Chọn nhân viên --</option>
                            <option value="1">Lê Hoàng C</option>
                            <option value="2">Đỗ Hoàng Long</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label-custom">Trạng thái ban đầu (Status)</label>
                        <select class="form-input-custom" id="createStatus">
                            <option value="Scheduled">Scheduled</option>
                            <option value="Pending">Pending</option>
                            <option value="InProgress">InProgress</option>
                        </select>
                    </div>
                    <div class="form-group form-group-full">
                        <label class="form-label-custom">Lý do bảo trì (Reason)</label>
                        <textarea class="form-input-custom" id="createReason" rows="3" maxlength="500" placeholder="Mô tả chi tiết vấn đề hoặc lý do bảo trì (tối đa 500 ký tự)..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer maintenance-modal-footer">
                <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-primary-custom" id="saveCreateMaintenanceBtn">
                    <span class="material-symbols-outlined">check</span>
                    Tạo lịch bảo trì
                </button>
            </div>
        </div>
    </div>
</div>
</div>

<!-- Edit Maintenance Modal -->
