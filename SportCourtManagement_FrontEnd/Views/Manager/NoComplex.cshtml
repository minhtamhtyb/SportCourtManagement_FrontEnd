@{
    Layout = "_ManagerLayout";
}
<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card shadow border-0 p-5 text-center" style="max-width: 550px; border-radius: 16px; background-color: var(--surface);">
        <div class="mb-4">
            <span class="material-symbols-outlined text-warning" style="font-size: 80px;">storefront</span>
        </div>
        <h3 class="fw-bold mb-3" style="color: var(--on-surface);">Chưa có chi nhánh nào</h3>
        <p class="text-muted mb-4" style="font-size: 15px; line-height: 1.6;">
            Hệ thống quản lý chưa ghi nhận bất kỳ chi nhánh (sân thể thao) nào. Vui lòng thêm chi nhánh mới vào cơ sở dữ liệu để bắt đầu quản lý nhân sự, ca trực, công việc và lịch bảo trì.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a href="/manager/dashboard" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
                Tải lại trang
            </a>
        </div>
    </div>
</div>
