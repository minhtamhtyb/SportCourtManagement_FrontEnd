@{
    ViewData["Title"] = "Shift Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/shifts.css" asp-append-version="true" />
}

<div class="shift-dashboard-container">
    <!-- Module Header -->
    <div class="module-header">
        <div class="module-title">
            <h3>Quản lý nhân sự</h3>
            <p>Lịch trực hàng tuần – 3 ca cố định: Morning (06–14h), Afternoon (14–22h), Evening (22–06h).</p>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-navigation">
        <a class="tab-link active" href="/manager/staff/shifts">Lịch trực hàng tuần</a>
        <a class="tab-link" href="/manager/staff/attendance">Chấm công &amp; Chuyên cần</a>
        <a class="tab-link" href="/manager/staff/list">Danh sách nhân viên</a>
        <a class="tab-link" href="/manager/staff/salary">Cấu hình tiền lương</a>
    </div>

    <!-- Toolbar -->
    <div class="shift-toolbar glass-panel">
        <div class="toolbar-left">
            <div class="week-picker">
                <button class="picker-btn">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <div class="picker-label">
                    WeekStart – WeekEnd (từ API <code>GetWeeklyScheduleAsync</code>)
                </div>
                <button class="picker-btn">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
            <button class="today-btn">Hôm nay</button>
        </div>
        <div class="toolbar-right">
            <div class="shift-legend">
                <span class="legend-dot morning"></span><span>Morning 06–14h</span>
                <span class="legend-dot afternoon"></span><span>Afternoon 14–22h</span>
                <span class="legend-dot evening"></span><span>Evening 22–06h</span>
            </div>
            <button class="add-staff-btn" data-bs-toggle="modal" data-bs-target="#createShiftModal">
                <span class="material-symbols-outlined">add</span>
                Thêm ca trực
            </button>
        </div>
    </div>

    <!-- Shift Grid Table (WeeklyScheduleResponse) -->
    <div class="shift-grid-container glass-panel">
        <div class="table-responsive custom-scrollbar">
            <table class="shift-table">
                <thead>
                    <tr class="court-grid-header">
                        <th class="sticky-col">NHÂN VIÊN</th>
                        <th>Thứ Hai<br /><span class="day-sub">23/06</span></th>
                        <th>Thứ Ba<br /><span class="day-sub">24/06</span></th>
                        <th>Thứ Tư<br /><span class="day-sub">25/06</span></th>
                        <th>Thứ Năm<br /><span class="day-sub">26/06</span></th>
                        <th>Thứ Sáu<br /><span class="day-sub">27/06</span></th>
                        <th class="weekend-col">Thứ Bảy<br /><span class="day-sub">28/06</span></th>
                        <th class="weekend-col">Chủ Nhật<br /><span class="day-sub">29/06</span></th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Staff 1: Nguyễn Văn A -->
                    <tr>
                        <td class="sticky-col staff-info-col">
                            <div class="staff-info">
                                <div class="avatar-container">
                                    <img class="avatar-img" alt="Nguyễn Văn A"
                                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuC7qVwjVMMInSzX3jgRwu6VFj5ISqC8nl3eY7u518JJyWie9Isu9jELtYGhmgwfHM80nNsq7qaj_jLZbGmQRdPKkI4dRYHS_c5YsUlS_HnEE30urPzP4H_0YColY_vGrCmUOqKJa1u_2QUEx11vndCWIVYUElcJUb7ChmgMN4EYQ3v-1wyzY1lQhUuz7Rdq4UK0fABHjJZ8hP2FdeqhklXdaFfXUUZWYLned69BxcTYjZUDe6VQRimnzEYbB1i5fFG6ES7FJ5X479Q" />
                                    <span class="status-dot online"></span>
                                </div>
                                <div class="staff-details">
                                    <p class="staff-name">Nguyễn Văn A</p>
                                    <span class="staff-role">Quản lý</span>
                                </div>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card morning">
                                <span class="shift-type-label">Morning</span>
                                <span class="shift-time-label">06:00–14:00</span>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card morning">
                                <span class="shift-type-label">Morning</span>
                                <span class="shift-time-label">06:00–14:00</span>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card off">OFF</div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card afternoon">
                                <span class="shift-type-label">Afternoon</span>
                                <span class="shift-time-label">14:00–22:00</span>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card afternoon">
                                <span class="shift-type-label">Afternoon</span>
                                <span class="shift-time-label">14:00–22:00</span>
                            </div>
                        </td>
                        <td class="shift-cell weekend-cell">
                            <div class="shift-card morning">
                                <span class="shift-type-label">Morning</span>
