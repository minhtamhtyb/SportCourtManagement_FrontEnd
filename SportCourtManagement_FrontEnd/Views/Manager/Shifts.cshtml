                                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuBZvbDSS6preTvZWuJnh_FlG18V7UScyIykWzOxZCPTIHy8hdBeeTyBC_hQHpA5oqm8ln6xUZ2Tvsacw8NhQzei2Yf7WYhuFi7_iWynkA0EAgwAU_tcMEW5Ve17oj-0o-pBesTV904mhzMrwVP5tGIPOBEN-n8TAVW0DXDeoqCKlZjSX7j4bJx998rT4vjbnohJBnYatyHQHTcG2T0EJjQYzg2iRs8PR42VEMPAgiodHiuFB5PyEevqfNXFyFLDnlOEPDvtbKtQBlo" />
                                    <span class="status-dot online"></span>
                                </div>
                                <div class="staff-details">
                                    <p class="staff-name">Trần Thị B</p>
                                    <span class="staff-role">Nhân viên sân</span>
                                </div>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card afternoon">
                                <span class="shift-type-label">Afternoon</span>
                                <span class="shift-time-label">14:00–22:00</span>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card off">OFF</div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card morning">
                                <span class="shift-type-label">Morning</span>
                                <span class="shift-time-label">06:00–14:00</span>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card morning">
                                <span class="shift-type-label">Morning</span>
                                <span class="shift-time-label">06:00–14:00</span>
                            </div>
                        </td>
                        <td class="shift-cell">
                            <div class="shift-card evening">
                                <span class="shift-type-label">Evening</span>
                                <span class="shift-time-label">22:00–06:00</span>
                            </div>
                        </td>
                        <td class="shift-cell weekend-cell">
                            <div class="shift-card evening">
                                <span class="shift-type-label">Evening</span>
                                <span class="shift-time-label">22:00–06:00</span>
                            </div>
                        </td>
                        <td class="shift-cell weekend-cell">
                            <div class="shift-card afternoon">
                                <span class="shift-type-label">Afternoon</span>
                                <span class="shift-time-label">14:00–22:00</span>
                            </div>
