        <div class="table-responsive custom-scrollbar">
            <table class="shift-table">
                <thead>
                    <tr class="court-grid-header">
                        <th class="sticky-col">NHÂN VIÊN</th>
                        <th>Thứ Hai<br /><span class="day-sub">23/06</span></th>
                        <th>Thứ Ba<br /><span class="day-sub">24/06</span></th>
                        <th>Thứ Tư<br /><span class="day-sub">25/06</span></th>
                        <th>Thứ Năm<br /><span class="day-sub">26/06</span></th>
                        <th>Thứ Sáu<br /><span class="day-sub">27/06</span></th>
                        <th class="weekend-col">Thứ Bảy<br /><span class="day-sub">28/06</span></th>
                        <th class="weekend-col">Chủ Nhật<br /><span class="day-sub">29/06</span></th>
                    </tr>
                </thead>
