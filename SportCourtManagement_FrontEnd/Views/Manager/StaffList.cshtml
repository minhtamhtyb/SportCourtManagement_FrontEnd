@{
    ViewData["Title"] = "Staff List";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/staff-list.css" asp-append-version="true" />
}

<div class="staff-list-container">
    <!-- Module Header -->
    <div class="module-header">
        <div class="module-title">
            <h3>Quản lý nhân sự</h3>
            <p>Xem danh sách và quản lý thông tin hồ sơ của toàn bộ nhân viên.</p>
        </div>
        <div class="header-actions">
            <button class="btn-secondary-custom">
                <span class="material-symbols-outlined">download</span>
                Xuất danh sách (CSV)
            </button>
            <button class="btn-primary-custom">
                <span class="material-symbols-outlined">person_add</span>
                Thêm nhân viên mới
            </button>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-navigation">
        <a class="tab-link" href="/manager/staff/shifts">Lịch trực hàng tuần</a>
        <a class="tab-link" href="/manager/staff/attendance">Chấm công &amp; Chuyên cần</a>
        <a class="tab-link active" href="/manager/staff/list">Danh sách nhân viên</a>
        <a class="tab-link" href="/manager/staff/salary">Cấu hình tiền lương</a>
    </div>

    <!-- Toolbar -->
    <div class="toolbar-container">
        <div class="toolbar-filters">
            <div class="search-input-wrapper">
                <span class="material-symbols-outlined">search</span>
                <input type="text" placeholder="Tìm FullName, Email, Phone..." />
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">filter_list</span>
                <select>
                    <option value="">Tất cả trạng thái</option>
                    <option value="true">IsActive = true</option>
                    <option value="false">IsActive = false</option>
                </select>
            </div>
        </div>

        <div class="metrics-summary">
            <span>Tổng số: <strong>24 nhân viên</strong></span>
            <span class="separator">|</span>
            <span>Đang hoạt động: <strong style="color: var(--emerald-400);">22</strong></span>
            <span class="separator">|</span>
            <span>Ngưng hoạt động: <strong style="color: var(--rose-400);">2</strong></span>
        </div>
    </div>

    <!-- Staff Table -->
    <!-- StaffSummaryResponse: UserId, FullName, Email, Phone, AvatarUrl, IsActive, ShiftsThisWeek, TodayShift -->
    <div class="table-panel glass-panel">
        <table class="staff-table">
            <thead>
                <tr>
                    <th>Nhân viên</th>
                    <th>Liên hệ</th>
                    <th>Ca tuần này</th>
                    <th>Ca hôm nay (TodayShift)</th>
                    <th>Trạng thái (IsActive)</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <!-- Staff 1: IsActive=true, ShiftsThisWeek=5, TodayShift=Morning checked in -->
                <tr>
                    <td>
                        <div class="employee-cell">
                            <div class="employee-avatar">
                                <img alt="Nguyễn Văn A" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC7qVwjVMMInSzX3jgRwu6VFj5ISqC8nl3eY7u518JJyWie9Isu9jELtYGhmgwfHM80nNsq7qaj_jLZbGmQRdPKkI4dRYHS_c5YsUlS_HnEE30urPzP4H_0YColY_vGrCmUOqKJa1u_2QUEx11vndCWIVYUElcJUb7ChmgMN4EYQ3v-1wyzY1lQhUuz7Rdq4UK0fABHjJZ8hP2FdeqhklXdaFfXUUZWYLned69BxcTYjZUDe6VQRimnzEYbB1i5fFG6ES7FJ5X479Q" />
                            </div>
                            <div>
                                <p class="employee-name">Nguyễn Văn A</p>
                                <p class="employee-id">UserId: 1</p>
                            </div>
                        </div>
                    </td>
                    <td>
                        <p class="employee-id" style="color: var(--on-surface);">0901234567</p>
                        <p class="employee-id">nguyenva@procourt.com</p>
                    </td>
                    <td>
                        <span class="shifts-week-badge">5 ca / tuần</span>
                    </td>
                    <td>
                        <div class="today-shift-cell">
                            <span class="shift-type-pill morning">Morning</span>
                            <span class="checkin-time">Check-in: 05:55</span>
                        </div>
                    </td>
                    <td><span class="badge-status active">Hoạt động</span></td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Vô hiệu hoá">
                                <span class="material-symbols-outlined">person_off</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Staff 2: IsActive=true, ShiftsThisWeek=4, TodayShift=Afternoon, no checkin yet -->
                <tr>
                    <td>
                        <div class="employee-cell">
                            <div class="employee-avatar">
                                <img alt="Trần Thị B" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBZvbDSS6preTvZWuJnh_FlG18V7UScyIykWzOxZCPTIHy8hdBeeTyBC_hQHpA5oqm8ln6xUZ2Tvsacw8NhQzei2Yf7WYhuFi7_iWynkA0EAgwAU_tcMEW5Ve17oj-0o-pBesTV904mhzMrwVP5tGIPOBEN-n8TAVW0DXDeoqCKlZjSX7j4bJx998rT4vjbnohJBnYatyHQHTcG2T0EJjQYzg2iRs8PR42VEMPAgiodHiuFB5PyEevqfNXFyFLDnlOEPDvtbKtQBlo" />
                            </div>
                            <div>
                                <p class="employee-name">Trần Thị B</p>
                                <p class="employee-id">UserId: 2</p>
                            </div>
                        </div>
                    </td>
                    <td>
                        <p class="employee-id" style="color: var(--on-surface);">0909876543</p>
                        <p class="employee-id">tranthib@procourt.com</p>
                    </td>
                    <td>
                        <span class="shifts-week-badge">4 ca / tuần</span>
                    </td>
                    <td>
                        <div class="today-shift-cell">
                            <span class="shift-type-pill afternoon">Afternoon</span>
                            <span class="checkin-time no-checkin">Chưa check-in</span>
                        </div>
                    </td>
                    <td><span class="badge-status active">Hoạt động</span></td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Vô hiệu hoá">
                                <span class="material-symbols-outlined">person_off</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Staff 3: IsActive=true, ShiftsThisWeek=5, TodayShift=Evening -->
                <tr>
                    <td>
                        <div class="employee-cell">
                            <div class="employee-avatar">
                                <img alt="Lê Hoàng C" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZC88s__sDzig7zx6x5SRgxmC_F5FKkS3a6sskzkbNOIeavyfvYbYYaa2wKvYMaA1Wl_gWOSReizjq_R2G99Wpy79k4HMOFXGkgcSiEx5PuG_m9L_mGmLPWTmGpbZe6hn_u1AERYQhoR_F2MHib22eYE-VjaZ4OVRrc_-qhiRZpqHOYBfJrPB4pHx1BJEb2RErunCQ7NOv5FzQQ8s4PZ2C4Na_lXICTtJvS5SwXt5y9E730TjkiqOgPRJvl1lJ9mKaIF6hMOn3u1w" />
                            </div>
                            <div>
                                <p class="employee-name">Lê Hoàng C</p>
                                <p class="employee-id">UserId: 3</p>
                            </div>
                        </div>
                    </td>
                    <td>
                        <p class="employee-id" style="color: var(--on-surface);">0987654321</p>
                        <p class="employee-id">lehoangc@procourt.com</p>
                    </td>
                    <td>
                        <span class="shifts-week-badge">5 ca / tuần</span>
                    </td>
                    <td>
                        <div class="today-shift-cell">
                            <span class="shift-type-pill evening">Evening</span>
                            <span class="checkin-time">Check-in: 22:02</span>
                        </div>
                    </td>
                    <td><span class="badge-status active">Hoạt động</span></td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Vô hiệu hoá">
                                <span class="material-symbols-outlined">person_off</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Staff 4: IsActive=true, TodayShift=null (không có ca hôm nay) -->
                <tr>
                    <td>
                        <div class="employee-cell">
                            <div class="employee-avatar">
                                <img alt="Phạm Minh Hoàng" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC3OyqucUhAQNTGfk0bk_7nAylbuHhOhqSF0k1VdjPWLOlH2aEvH46drxY4VYGrqD0HERsQ0EyYwlLNZQUQ6GeGwMqVFX__sTe-5sE57bO7Uq1IEo33FQhfryeU4Uzcdk8Io6fprE76zTLyRi_GE6BbaJOn0Lhs7pbCwidrYoVVaBxXRJc4Dimihb6ClQJhWP0ISRR3UYlIMcnhde186-LLoY1A6JOsT5oTIAdPccFwbHpUdGzR80xt7wY2dIbcRnpuN2HytJTqvTo" />
                            </div>
                            <div>
                                <p class="employee-name">Phạm Minh Hoàng</p>
                                <p class="employee-id">UserId: 42</p>
                            </div>
                        </div>
                    </td>
                    <td>
                        <p class="employee-id" style="color: var(--on-surface);">0912345678</p>
                        <p class="employee-id">phamhoang@procourt.com</p>
                    </td>
                    <td>
                        <span class="shifts-week-badge">3 ca / tuần</span>
                    </td>
                    <td>
                        <span class="employee-id" style="font-style: italic;">Không có ca hôm nay</span>
                    </td>
                    <td><span class="badge-status active">Hoạt động</span></td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn edit" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button class="action-icon-btn delete" title="Vô hiệu hoá">
                                <span class="material-symbols-outlined">person_off</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Staff 5: IsActive=false (vô hiệu hoá) -->
                <tr style="opacity: 0.6;">
                    <td>
                        <div class="employee-cell">
                            <div class="employee-avatar">
                                <img alt="Đỗ Hoàng Long" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCcEWKF1CnspJSj_QYaU3G1i4pdivJ2Jv77qI2KCvJ1ciOYJFq5-rcFVNW0mGZdy6kkEqQ0xxoXLPnPf3f4dqydPkgMG7DV6MqRIKXw-4slH12hU2hekitsuTSPxVCJ9_Ea63bmsLRUU7iEHZrEK-IlZTSIUqGNp8QhZFNoFqQ9a3-i7ad9bTmo69xYaqTfDKfv83raCHzg2VtQoMFcmZRXiQKF7b_vskHMZJa-0kHtKNeMFNVDr6d-1ADKqg4K4mwLk4owz5N5jrY" />
                            </div>
                            <div>
                                <p class="employee-name">Đỗ Hoàng Long</p>
                                <p class="employee-id">UserId: 102</p>
                            </div>
                        </div>
                    </td>
                    <td>
                        <p class="employee-id" style="color: var(--on-surface);">0977889900</p>
                        <p class="employee-id">longdh@procourt.com</p>
                    </td>
                    <td>
                        <span class="shifts-week-badge inactive">0 ca / tuần</span>
                    </td>
                    <td>
                        <span class="employee-id" style="font-style: italic;">–</span>
                    </td>
                    <td><span class="badge-status inactive">Vô hiệu hoá</span></td>
                    <td>
                        <div class="actions-cell">
                            <button class="action-icon-btn" title="Kích hoạt lại" style="color: var(--emerald-400);">
                                <span class="material-symbols-outlined">person_check</span>
                            </button>
                            <button class="action-icon-btn delete" title="Xóa">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-panel">
        <p class="pagination-info">Hiển thị 1 - 5 của 24 nhân viên</p>
        <div class="pagination-buttons">
            <button class="pagination-btn" disabled>
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="pagination-btn active">1</button>
            <button class="pagination-btn">2</button>
            <button class="pagination-btn">3</button>
            <button class="pagination-btn">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.staff-table tbody tr').forEach(row => {
            row.addEventListener('click', e => {
                if (e.target.closest('button')) return;
                row.style.backgroundColor = 'rgba(192, 193, 255, 0.1)';
                setTimeout(() => { row.style.backgroundColor = ''; }, 300);
            });
        });
    </script>
}
