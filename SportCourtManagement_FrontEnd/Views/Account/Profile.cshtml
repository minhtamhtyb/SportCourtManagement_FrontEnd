@model ProfilePageViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_Layout";

    var avatar = string.IsNullOrWhiteSpace(Model.CurrentUser.AvatarUrl)
        ? $"https://api.dicebear.com/8.x/initials/svg?seed={Uri.EscapeDataString(Model.CurrentUser.FullName)}"
        : Model.CurrentUser.AvatarUrl;
    var roleLabel = Model.CurrentUser.Role;
    var membership = string.IsNullOrWhiteSpace(Model.CurrentUser.MembershipTier) ? "Standard" : Model.CurrentUser.MembershipTier;
}

<section class="profile-hero">
    <div class="profile-hero__glow profile-hero__glow--one"></div>
    <div class="profile-hero__glow profile-hero__glow--two"></div>
    <div class="container py-4 py-lg-5 position-relative">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <div class="profile-title-chip mb-3">Tài khoản của bạn</div>
                <h1 class="display-6 fw-bold text-white mb-3">Chỉnh sửa hồ sơ, bảo mật và thông tin liên hệ tại một nơi.</h1>
                <p class="text-white-50 mb-0" style="max-width: 760px;">
                    Cập nhật thông tin cá nhân, đổi ảnh đại diện và quản lý mật khẩu của bạn ngay trong SportsCourt.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="profile-stat-card">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img src="@avatar" alt="Avatar" class="profile-avatar" />
                        <div>
                            <div class="text-white fw-semibold fs-5">@Model.CurrentUser.FullName</div>
                            <div class="text-white-50 small">@Model.CurrentUser.Email</div>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="profile-badge">@roleLabel</span>
                        <span class="profile-badge profile-badge--soft">@membership</span>
                        @if (Model.CurrentUser.IsActive)
                        {
                            <span class="profile-badge profile-badge--success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="profile-badge profile-badge--danger">Đang khóa</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5 profile-shell">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="profile-card h-100">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                    <div>
                        <h2 class="h4 text-white mb-1">Thông tin cá nhân</h2>
                        <p class="text-white-50 mb-0">Cập nhật tên hiển thị, số điện thoại, ngày sinh và hồ sơ đại diện.</p>
                    </div>
                    <div class="profile-inline-pill">
                        <i class="bi bi-shield-check me-1"></i> Bảo vệ tài khoản
                    </div>
                </div>

                <form asp-action="Profile" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger profile-alert"></div>

                    <div class="col-md-6">
                        <label asp-for="Profile.FullName" class="form-label text-white-50"></label>
                        <input asp-for="Profile.FullName" class="form-control profile-input" />
                        <span asp-validation-for="Profile.FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Profile.Phone" class="form-label text-white-50"></label>
                        <input asp-for="Profile.Phone" class="form-control profile-input" />
                        <span asp-validation-for="Profile.Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Profile.AvatarUrl" class="form-label text-white-50"></label>
                        <input asp-for="Profile.AvatarUrl" class="form-control profile-input" placeholder="https://..." />
                        <span asp-validation-for="Profile.AvatarUrl" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Profile.DateOfBirth" class="form-label text-white-50"></label>
                        <input asp-for="Profile.DateOfBirth" type="date" class="form-control profile-input" />
                        <span asp-validation-for="Profile.DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Profile.Gender" class="form-label text-white-50"></label>
                        <select asp-for="Profile.Gender" class="form-select profile-input">
                            <option value="">Chọn giới tính</option>
                            @foreach (var gender in Model.GenderOptions)
                            {
                                <option value="@gender">@gender</option>
                            }
                        </select>
                        <span asp-validation-for="Profile.Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Profile.SkillLevel" class="form-label text-white-50"></label>
                        <select asp-for="Profile.SkillLevel" class="form-select profile-input">
                            <option value="">Chọn trình độ</option>
                            @foreach (var skill in Model.SkillLevelOptions)
                            {
                                <option value="@skill">@skill</option>
                            }
                        </select>
                        <span asp-validation-for="Profile.SkillLevel" class="text-danger small"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="btn profile-primary-btn">
                            <i class="bi bi-check2-circle me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4 d-flex flex-column gap-4">
            <div class="profile-card">
                <h2 class="h5 text-white mb-3">Tóm tắt tài khoản</h2>
                <div class="profile-summary-list">
                    <div>
                        <span class="text-white-50">Mã người dùng</span>
                        <strong>#@Model.CurrentUser.UserId</strong>
                    </div>
                    <div>
                        <span class="text-white-50">Email</span>
                        <strong>@Model.CurrentUser.Email</strong>
                    </div>
                    <div>
                        <span class="text-white-50">Số điện thoại</span>
                        <strong>@(string.IsNullOrWhiteSpace(Model.CurrentUser.Phone) ? "Chưa cập nhật" : Model.CurrentUser.Phone)</strong>
                    </div>
                    <div>
                        <span class="text-white-50">Ngày tạo</span>
                        <strong>@(Model.CurrentUser.CreatedAt?.ToString("dd/MM/yyyy") ?? "Chưa xác định")</strong>
                    </div>
                </div>
            </div>

            <div class="profile-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="h5 text-white mb-0">Bảo mật tài khoản</h2>
                    <span class="profile-badge profile-badge--soft">
                        <i class="bi bi-shield-lock-fill"></i> Mật khẩu
                    </span>
                </div>
                <p class="text-white-50 small mb-4">
                    Để bảo vệ tài khoản tốt hơn, bạn nên thường xuyên cập nhật mật khẩu mới có độ bảo mật cao.
                </p>
                <button type="button" class="btn profile-secondary-btn w-100 d-flex align-items-center justify-content-center gap-2" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                    <i class="bi bi-key-fill text-sc-blue"></i> Đổi mật khẩu
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Modal Đổi Mật Khẩu -->
<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content profile-modal-content">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title text-white fw-bold mb-0" id="changePasswordModalLabel">Đổi mật khẩu</h5>
                    <p class="text-white-50 small mb-0">Cập nhật mật khẩu mới cho tài khoản của bạn</p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ChangePassword" method="post">
                <div class="modal-body py-4">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger profile-alert mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ChangePassword.OldPassword" class="form-label text-white-50"></label>
                        <div class="input-group">
                            <input asp-for="ChangePassword.OldPassword" type="password" class="form-control profile-input" placeholder="Nhập mật khẩu hiện tại" />
                        </div>
                        <span asp-validation-for="ChangePassword.OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ChangePassword.NewPassword" class="form-label text-white-50"></label>
                        <div class="input-group">
                            <input asp-for="ChangePassword.NewPassword" type="password" class="form-control profile-input" placeholder="Nhập mật khẩu mới" />
                        </div>
                        <span asp-validation-for="ChangePassword.NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ChangePassword.ConfirmPassword" class="form-label text-white-50"></label>
                        <div class="input-group">
                            <input asp-for="ChangePassword.ConfirmPassword" type="password" class="form-control profile-input" placeholder="Nhập lại mật khẩu mới" />
                        </div>
                        <span asp-validation-for="ChangePassword.ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 d-flex justify-content-end gap-2">
                    <button type="button" class="btn profile-secondary-btn px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn profile-primary-btn px-4">Cập nhật mật khẩu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .profile-hero {
            position: relative;
            overflow: hidden;
            background:
                radial-gradient(circle at top left, rgba(79, 110, 247, 0.35), transparent 35%),
                radial-gradient(circle at right, rgba(0, 209, 178, 0.18), transparent 30%),
                linear-gradient(180deg, #111827 0%, #0f172a 100%);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .profile-hero__glow {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.45;
        }

        .profile-hero__glow--one {
            width: 240px;
            height: 240px;
            right: -60px;
            top: -80px;
            background: rgba(79, 110, 247, 0.18);
        }

        .profile-hero__glow--two {
            width: 180px;
            height: 180px;
            left: 8%;
            bottom: -50px;
            background: rgba(0, 209, 178, 0.14);
        }

        .profile-title-chip,
        .profile-inline-pill,
        .profile-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            border-radius: 999px;
            padding: .4rem .8rem;
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .02em;
        }

        .profile-title-chip,
        .profile-inline-pill {
            background: rgba(255, 255, 255, 0.08);
            color: #e2e8f0;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .profile-stat-card,
        .profile-card {
            background: rgba(15, 23, 42, 0.86);
            border: 1px solid rgba(148, 163, 184, 0.16);
            box-shadow: 0 24px 60px rgba(2, 6, 23, 0.35);
            backdrop-filter: blur(18px);
            border-radius: 24px;
            padding: 24px;
        }

        .profile-avatar {
            width: 72px;
            height: 72px;
            border-radius: 22px;
            object-fit: cover;
            border: 2px solid rgba(255, 255, 255, 0.12);
        }

        .profile-badge {
            background: rgba(255, 255, 255, 0.08);
            color: #cbd5e1;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .profile-badge--soft { background: rgba(79, 110, 247, 0.16); color: #bfdbfe; }
        .profile-badge--success { background: rgba(34, 197, 94, 0.16); color: #bbf7d0; }
        .profile-badge--danger { background: rgba(239, 68, 68, 0.16); color: #fecaca; }

        .profile-alert {
            background: rgba(239, 68, 68, 0.12);
            color: #fecaca;
            border-color: rgba(239, 68, 68, 0.28);
        }

        .profile-input {
            background: rgba(15, 23, 42, 0.7) !important;
            border: 1px solid rgba(148, 163, 184, 0.18) !important;
            color: #f8fafc !important;
            border-radius: 14px;
            padding: .85rem 1rem;
        }

        .profile-input:focus {
            border-color: rgba(79, 110, 247, 0.65) !important;
            box-shadow: 0 0 0 .2rem rgba(79, 110, 247, 0.16) !important;
        }

        .profile-input::placeholder { color: #64748b; }

        .profile-primary-btn,
        .profile-secondary-btn {
            border-radius: 14px;
            padding: .85rem 1.1rem;
            font-weight: 700;
        }

        .profile-primary-btn {
            background: linear-gradient(135deg, #4f6ef7 0%, #6b85f8 100%);
            color: #fff;
            border: none;
        }

        .profile-secondary-btn {
            background: rgba(148, 163, 184, 0.12);
            color: #e2e8f0;
            border: 1px solid rgba(148, 163, 184, 0.18);
        }

        .profile-summary-list {
            display: grid;
            gap: 1rem;
        }

        .profile-summary-list div {
            display: flex;
            flex-direction: column;
            gap: .15rem;
            padding-bottom: .85rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .profile-summary-list div:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .profile-summary-list strong {
            color: #fff;
            font-size: .98rem;
        }

        .profile-shell {
            margin-top: -40px;
        }

        .profile-modal-content {
            background: #0f172a;
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            color: #f8fafc;
            padding: 12px;
        }

        .profile-modal-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: linear-gradient(135deg, #4f6ef7 0%, #6b85f8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any(k => k.StartsWith("ChangePassword")))
            {
                <text>
                var modalEl = document.getElementById('changePasswordModal');
                if (modalEl) {
                    var modal = new bootstrap.Modal(modalEl);
                    modal.show();
                }
                </text>
            }
        });
    </script>
}