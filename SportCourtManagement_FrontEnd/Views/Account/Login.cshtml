@model LoginViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";

    var useMock = Configuration.GetValue<bool>("ApiSettings:UseMockData", true);
    var customerEmail = useMock ? "customer@gmail.com" : "customer@sportcourt.vn";
    var customerPwd = useMock ? "Customer@123" : "customer123";
    var adminEmail = useMock ? "admin@sportscourtms.vn" : "admin@sportcourt.vn";
    var adminPwd = useMock ? "Admin@123" : "admin123";
    var staffEmail = useMock ? "staff@sportscourtms.vn" : "staff@sportcourt.vn";
    var staffPwd = useMock ? "Staff@123" : "Staff@123";
}

<div class="auth-wrapper">
    <div class="auth-blob-1"></div>
    <div class="auth-blob-2"></div>
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-logo"><i class="fa-solid fa-bolt"></i></div>
            <h1 class="h4 fw-bold text-white mb-1">Đăng nhập tài khoản</h1>
            <p class="text-secondary small mb-0">Hệ thống quản lý đặt sân SportsCourt</p>
        </div>

        @if (TempData["VerifyEmail"] is string pendingEmail)
        {
            <div class="alert alert-warning py-2 small">
                Tài khoản <strong>@pendingEmail</strong> chưa xác thực.
                <a asp-action="VerifyEmail" asp-route-email="@pendingEmail" class="alert-link">Nhập OTP ngay</a>
            </div>
        }

        <form asp-action="Login" method="post" class="form-dark">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-regular fa-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="example@gmail.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                Đăng nhập <i class="fa-solid fa-arrow-right ms-1"></i>
            </button>
        </form>

        <!-- Google Login Section -->
        <div class="position-relative my-4 text-center">
            <hr class="border-secondary" />
            <span class="position-absolute top-50 start-50 translate-middle bg-dark px-3 text-secondary small text-uppercase fw-semibold" style="font-size: 0.75rem; border-radius: 4px;">hoặc</span>
        </div>

        <div class="d-flex justify-content-center mb-3">
            <div id="g_id_onload"
                 data-client_id="@Configuration["GoogleSettings:ClientId"]"
                 data-context="signin"
                 data-ux_mode="popup"
                 data-callback="handleCredentialResponse"
                 data-auto_prompt="false">
            </div>
            <div class="g_id_signin w-100"
                 data-type="standard"
                 data-shape="rectangular"
                 data-theme="filled_black"
                 data-text="signin_with"
                 data-size="large"
                 data-logo_alignment="left"
                 data-width="100%">
            </div>
        </div>

        <!-- Hidden Form to POST token to Controller -->
        <form id="googleLoginForm" asp-action="GoogleLogin" method="post" style="display:none;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="idToken" id="googleIdToken" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        </form>

        <div class="mt-4 pt-3 border-top border-secondary">
            <p class="text-center text-secondary small text-uppercase fw-semibold mb-2">Tài khoản thử nghiệm nhanh</p>
            <div class="row g-2">
                <div class="col-4">
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="fillLogin('@customerEmail','@customerPwd')">👤 Khách</button>
                </div>
                <div class="col-4">
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="fillLogin('@adminEmail','@adminPwd')">🛡️ Admin</button>
                </div>
                <div class="col-4">
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="fillLogin('@staffEmail','@staffPwd')">👷 NV</button>
                </div>
            </div>
            <form asp-action="DevLoginAdmin" method="post" class="mt-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                    ⚡ Vào thẳng Admin
                </button>
            </form>
            <p class="text-secondary small text-center mt-1 mb-0">Gọi API login thật với tài khoản Admin seed</p>
        </div>

        <p class="text-center text-secondary small mt-3 mb-0">
            Chưa có tài khoản? <a asp-action="Register" class="text-success fw-semibold">Đăng ký ngay</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        function fillLogin(email, password) {
            document.getElementById('Email').value = email;
            document.getElementById('Password').value = password;
        }

        function handleCredentialResponse(response) {
            if (response && response.credential) {
                document.getElementById('googleIdToken').value = response.credential;
                document.getElementById('googleLoginForm').submit();
            }
        }
    </script>
}
