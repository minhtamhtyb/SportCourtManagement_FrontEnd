@model SportCourtManagement_FrontEnd.Models.Manager.PagedTaskResponse
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Công việc của tôi | ProCourt";
    string? selectedStatus = ViewBag.SelectedStatus as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/maintenance.css" asp-append-version="true" />
}

<div class="maintenance-container">

    <!-- Module Header -->
    <div class="module-header">
        <div class="module-title">
            <h3>📋 Công việc của tôi</h3>
            <p>Theo dõi, tiếp nhận và báo cáo tiến độ các công việc được phân công vận hành tại cơ sở.</p>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="summary-stats">
        <div class="stat-card glass-panel">
            <div class="stat-icon orange">
                <span class="material-symbols-outlined">pending_actions</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Pending</p>
                <span class="stat-value orange">@(ViewBag.PendingCount ?? 0)</span>
                <p class="stat-sub">Chờ bắt đầu</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon sky">
                <span class="material-symbols-outlined">construction</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">In Progress</p>
                <span class="stat-value sky">@(ViewBag.InProgressCount ?? 0)</span>
                <p class="stat-sub">Đang thực hiện</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon emerald">
                <span class="material-symbols-outlined">schedule</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Completed</p>
                <span class="stat-value emerald">@(ViewBag.CompletedCount ?? 0)</span>
                <p class="stat-sub">Chờ nghiệm thu</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon" style="background: rgba(34, 197, 94, 0.15); color: #22c55e;">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Approved</p>
                <span class="stat-value" style="color: #22c55e;">@(ViewBag.ApprovedCount ?? 0)</span>
                <p class="stat-sub">Đã duyệt hoàn thành</p>
            </div>
        </div>
    </div>

    <!-- Toolbar Filters -->
    <div class="toolbar-container">
        <div class="toolbar-filters">
            <div class="search-input-wrapper">
                <span class="material-symbols-outlined">search</span>
                <input type="text" id="searchInput" placeholder="Tìm theo tiêu đề, mô tả công việc..." />
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">filter_list</span>
                <select id="statusFilter">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Pending" selected="@(selectedStatus == "Pending")">Pending (Chờ bắt đầu)</option>
                    <option value="InProgress" selected="@(selectedStatus == "InProgress")">In Progress (Đang làm)</option>
                    <option value="Completed" selected="@(selectedStatus == "Completed")">Completed (Chờ duyệt)</option>
                    <option value="Approved" selected="@(selectedStatus == "Approved")">Approved (Đã duyệt)</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">priority_high</span>
                <select id="priorityFilter">
                    <option value="">Tất cả mức ưu tiên</option>
                    <option value="Urgent">Urgent (Khẩn cấp)</option>
                    <option value="High">High (Cao)</option>
                    <option value="Medium">Medium (Trung bình)</option>
                    <option value="Low">Low (Thấp)</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">category</span>
                <select id="categoryFilter">
                    <option value="">Tất cả hạng mục</option>
                    <option value="Cleanup">Cleanup (Dọn dẹp)</option>
                    <option value="ServicePrep">ServicePrep (Dịch vụ)</option>
                    <option value="Repair">Repair (Sửa chữa)</option>
                    <option value="Complaint">Complaint (Khiếu nại)</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Tasks Table Panel -->
    <div class="table-panel glass-panel">
        <table class="maintenance-table">
            <thead>
                <tr>
                    <th>Tên công việc</th>
                    <th>Hạng mục</th>
                    <th>Mức ưu tiên</th>
                    <th>Nội dung / Mô tả</th>
                    <th>Hạn chót</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items == null || !Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 40px; color: var(--on-surface-variant); font-style: italic;">
                            Không có công việc nào được phân công.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var task in Model.Items)
                    {
                        var isPending = task.Status == "Pending";
                        var isInProgress = task.Status == "InProgress";
                        var isCompleted = task.Status == "Completed";
                        var isApproved = task.Status == "Approved";

                        var priorityBadgeClass = task.Priority.ToLower() switch
                        {
                            "urgent" => "emergency",
                            "high" => "emergency",
                            "medium" => "routine",
                            _ => "upgrade"
                        };

                        var statusBadgeClass = task.Status.ToLower() switch
                        {
                            "inprogress" => "in-progress",
                            "completed" => "done",
                            "approved" => "done",
                            _ => "pending"
                        };

                        <tr data-id="@task.TaskId"
                            data-title="@task.Title"
                            data-desc="@task.Description"
                            data-priority="@task.Priority"
                            data-category="@task.Category"
                            data-status="@task.Status">
                            <td>
                                <div class="court-cell">
                                    <div class="court-icon" style="background: rgba(99, 102, 241, 0.15); color: var(--primary);">
                                        <span class="material-symbols-outlined">assignment</span>
                                    </div>
                                    <div>
                                        <p class="court-name">@task.Title</p>
                                        <p class="court-location">Giao bởi: @(string.IsNullOrEmpty(task.CreatedByName) ? "Hệ thống" : task.CreatedByName)</p>
                                    </div>
                                </div>
                            </td>
                            <td><span class="type-badge routine">@task.Category</span></td>
                            <td><span class="type-badge @priorityBadgeClass">@task.Priority</span></td>
                            <td class="reason-cell">@task.Description</td>
                            <td>
                                <p class="time-start" style="font-weight: 500;">
                                    <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: middle;">event</span>
                                    @task.DueDate.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </td>
                            <td><span class="status-badge @statusBadgeClass">@task.Status</span></td>
                            <td>
                                <div class="actions-cell">
                                    @if (isPending)
                                    {
                                        <form asp-controller="StaffTask" asp-action="StartTask" asp-route-taskId="@task.TaskId" asp-route-status="@selectedStatus" asp-route-page="@currentPage" method="post" style="margin: 0;">
                                            <button type="submit" class="btn-primary-custom" style="padding: 6px 12px; font-size: 12px; background: linear-gradient(135deg, var(--sky-400), #0284c7);">
                                                <span class="material-symbols-outlined" style="font-size: 16px;">play_arrow</span>
                                                Bắt đầu làm
                                            </button>
                                        </form>
                                    }
                                    else if (isInProgress)
                                    {
                                        <form asp-controller="StaffTask" asp-action="CompleteTask" asp-route-taskId="@task.TaskId" asp-route-status="@selectedStatus" asp-route-page="@currentPage" method="post" style="margin: 0;">
                                            <button type="submit" class="btn-primary-custom" style="padding: 6px 12px; font-size: 12px; background: linear-gradient(135deg, var(--emerald-400), var(--emerald-500));">
                                                <span class="material-symbols-outlined" style="font-size: 16px;">done_all</span>
                                                Hoàn thành
                                            </button>
                                        </form>
                                    }
                                    else if (isCompleted)
                                    {
                                        <span style="font-size: 12px; color: var(--emerald-400); display: inline-flex; align-items: center; gap: 4px; font-weight: 500;">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">hourglass_top</span>
                                            Chờ nghiệm thu
                                        </span>
                                    }
                                    else if (isApproved)
                                    {
                                        <span style="font-size: 12px; color: #22c55e; display: inline-flex; align-items: center; gap: 4px; font-weight: 500;">
                                            <span class="material-symbols-outlined" style="font-size: 16px;">check_circle</span>
                                            Đã duyệt
                                        </span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Panel -->
    <div class="pagination-panel">
        <p class="pagination-info"></p>
        <div class="pagination-buttons">
            <button class="pagination-btn" disabled>
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="pagination-btn active">1</button>
            <button class="pagination-btn" disabled>
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── Toast Helper ──────────────────────────────────────────────────────
        function showToast(message, type = 'success') {
            document.querySelectorAll('.toast-notification').forEach(t => t.remove());
            const toast = document.createElement('div');
            toast.className = `toast-notification ${type}`;
            const icon = type === 'error' ? 'error' : (type === 'info' ? 'info' : 'check_circle');
            toast.innerHTML = `<span class="material-symbols-outlined">${icon}</span><div>${message}</div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // ── TempData Toasts (server redirect feedback) ────────────────────────
        @if (TempData["SuccessMessage"] != null)
        {
            <text>showToast('@Html.Raw(TempData["SuccessMessage"])', 'success');</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>showToast('@Html.Raw(TempData["ErrorMessage"])', 'error');</text>
        }

        // ── Live Client-side Search & Filter Logic ────────────────────────────
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const priorityFilter = document.getElementById('priorityFilter');
        const categoryFilter = document.getElementById('categoryFilter');
        const tableRows = document.querySelectorAll('.maintenance-table tbody tr');

        function filterTable() {
            const query = searchInput.value.toLowerCase().trim();
            const status = statusFilter.value;
            const priority = priorityFilter.value;
            const category = categoryFilter.value;

            tableRows.forEach(row => {
                if (row.cells.length === 1 && row.cells[0].colSpan > 1) return; // Skip empty row

                const title = row.dataset.title ? row.dataset.title.toLowerCase() : '';
                const desc = row.dataset.desc ? row.dataset.desc.toLowerCase() : '';
                const rowStatus = row.dataset.status || '';
                const rowPriority = row.dataset.priority || '';
                const rowCategory = row.dataset.category || '';

                const matchesSearch = title.includes(query) || desc.includes(query);
                const matchesStatus = !status || rowStatus.toLowerCase() === status.toLowerCase();
                const matchesPriority = !priority || rowPriority.toLowerCase() === priority.toLowerCase();
                const matchesCategory = !category || rowCategory.toLowerCase() === category.toLowerCase();

                if (matchesSearch && matchesStatus && matchesPriority && matchesCategory) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
            updatePaginationInfo();
        }

        searchInput.addEventListener('input', filterTable);
        statusFilter.addEventListener('change', filterTable);
        priorityFilter.addEventListener('change', filterTable);
        categoryFilter.addEventListener('change', filterTable);

        function updatePaginationInfo() {
            const visibleRows = document.querySelectorAll('.maintenance-table tbody tr:not([style*="display: none"])');
            const totalRows = document.querySelectorAll('.maintenance-table tbody tr');
            
            const isNoData = totalRows.length === 1 && totalRows[0].cells[0].colSpan > 1;
            const activeCount = isNoData ? 0 : visibleRows.length;
            const totalCount = isNoData ? 0 : totalRows.length;

            document.querySelector('.pagination-info').textContent = `Hiển thị 1 - ${activeCount} của ${totalCount} công việc`;
        }

        updatePaginationInfo();
    </script>
}
