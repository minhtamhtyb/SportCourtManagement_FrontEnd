@model SportCourtManagement_FrontEnd.Models.Courts.CourtListDto

<article class="sc-card @(Model.AverageRating >= 4.8 ? "sc-card-featured" : "")" style="cursor: pointer;" onclick="location.href='@Url.Action("Detail", "Courts", new { id = Model.CourtId })'">
    <!-- Image Header -->
    <div class="position-relative w-full overflow-hidden" style="aspect-ratio: 8/5;">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="~/images/courts/@Model.ImageUrl" alt="@Model.CourtName" class="w-100 h-100 object-fit-cover" style="object-fit: cover;" />
        }
        else
        {
            <!-- Placeholder design matching sports theme -->
            <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); color: var(--sc-text-secondary);">
                <span><i class="bi bi-dribbble me-1"></i> Sân thể thao</span>
            </div>
        }
        <!-- Gradient Overlay -->
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(0deg, rgba(15,17,23,0.7) 0%, rgba(15,17,23,0) 60%); pointer-events: none;"></div>

        <!-- Badges on Image -->
        <div class="position-absolute top-0 start-0 p-3 d-flex gap-2">
            @if (Model.AverageRating >= 4.9)
            {
                <span class="sc-badge sc-badge-amber"><i class="bi bi-trophy-fill me-1"></i> VIP</span>
            }
            else if (Model.ReviewCount > 200)
            {
                <span class="sc-badge sc-badge-amber"><i class="bi bi-fire me-1"></i> Hot</span>
            }
            
            <span class="sc-badge sc-badge-blue">@Model.CourtTypeName</span>
        </div>

        <!-- Status badge top-right -->
        <div class="position-absolute top-0 end-0 p-3">
            @if (Model.Status.Equals("Available", StringComparison.OrdinalIgnoreCase))
            {
                <span class="sc-badge sc-badge-green">Còn trống</span>
            }
            else if (Model.Status.Equals("Maintenance", StringComparison.OrdinalIgnoreCase))
            {
                <span class="sc-badge sc-badge-red">Bảo trì</span>
            }
            else
            {
                <span class="sc-badge sc-badge-muted">@Model.Status</span>
            }
        </div>
    </div>

    <!-- Body -->
    <div class="sc-card-body">
        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <h4 class="font-outfit text-white mb-0" style="font-weight: 700; font-size: 15px; line-height: 1.3;">
                @Model.CourtName
            </h4>
            <span class="px-2 py-1 rounded text-sc-muted font-inter" style="font-size: 11px; font-weight: 600; background-color: rgba(255,255,255,0.04); white-space: nowrap;">
                <i class="bi bi-clipboard me-1"></i> @Model.CourtCode
            </span>
        </div>

        <div class="d-flex align-items-center gap-2 mb-1" style="font-size: 13px; color: var(--sc-text-secondary);">
            <span><i class="bi bi-geo-alt-fill"></i></span>
            <span>@Model.Location</span>
        </div>

        <div class="d-flex align-items-center gap-2 mb-3" style="font-size: 13px; color: var(--sc-text-secondary);">
            <span><i class="bi bi-clock"></i></span>
            <span>@Model.OpenTime.ToString("HH:mm") - @Model.CloseTime.ToString("HH:mm")</span>
        </div>

        <div style="height: 1px; background-color: rgba(255,255,255,0.05); margin-bottom: 14px;"></div>

        <div class="d-flex justify-content-between align-items-center">
            <!-- Stars & Rating -->
            <div class="d-flex align-items-center gap-1">
                <div class="d-flex gap-0.5">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var filled = Model.AverageRating.HasValue && i <= Math.Floor(Model.AverageRating.Value);
                        <span class="sc-star @(filled ? "sc-star-filled" : "")" style="font-size: 12px;"><i class="bi bi-star-fill"></i></span>
                    }
                </div>
                <span class="text-white font-inter" style="font-weight: 700; font-size: 13px;">@(Model.AverageRating.HasValue ? Model.AverageRating.Value.ToString("0.0") : "0.0")</span>
                <span class="text-sc-muted font-inter" style="font-size: 12px;">(@Model.ReviewCount)</span>
            </div>

            <!-- Price range -->
            <div class="d-flex align-items-baseline gap-0.5">
                <span class="font-inter text-sc-green" style="font-weight: 800; font-size: 16px;">
                    @(Model.MinPrice.HasValue ? Model.MinPrice.Value.ToString("N0") + "đ" : "---")
                </span>
                <span class="text-sc-muted" style="font-size: 11px;">/giờ</span>
            </div>
        </div>
    </div>
</article>
