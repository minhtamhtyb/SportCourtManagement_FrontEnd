<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportsCourt</title>
    
    <!-- CSS Bootstrap for utility classes (optional but layout relies on custom css) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sportcourt.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <!-- Premium Header Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background-color: #0D121F; border-bottom: 1px solid rgba(255,255,255,0.05); padding: 16px 0;">
            <div class="container px-4 px-lg-5">
                <a class="navbar-brand d-flex align-items-center gap-2 font-outfit" asp-controller="Courts" asp-action="Index" style="font-weight: 800; font-size: 22px; color: #ffffff; letter-spacing: -0.5px;">
                    <span style="background: linear-gradient(135deg, #4F6EF7 0%, #6B85F8 100%); width: 28px; height: 28px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; font-size: 14px;"><i class="bi bi-trophy-fill text-white"></i></span>
                    Sports<span style="color: #4F6EF7;">Court</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @{
                    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                    var isAdminOrStaff = userRole == "Admin" || userRole == "Staff";
                }
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-1">
                        @if (isAdminOrStaff)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold py-2 px-3 rounded" asp-controller="Bookings" asp-action="AdminIndex" style="font-size: 14px;"><i class="bi bi-shield-check me-1"></i>Duyệt Booking</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white hover-white py-2 px-3 rounded" asp-controller="Tournaments" asp-action="AdminIndex" style="font-size: 14px;"><i class="bi bi-trophy me-1"></i>Quản lý Giải đấu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white hover-white py-2 px-3 rounded" asp-controller="Promotions" asp-action="Index" style="font-size: 14px;"><i class="bi bi-gift me-1"></i>Quản lý Khuyến mãi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50 hover-white py-2 px-3 rounded" asp-controller="Courts" asp-action="Index" style="font-size: 14px;"><i class="bi bi-grid me-1"></i>Xem Danh Sách Sân</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white py-2 px-3 rounded" asp-controller="Courts" asp-action="Index" style="font-size: 14px; font-weight: 600;"><i class="bi bi-calendar-check me-1"></i>Đặt sân</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50 hover-white py-2 px-3 rounded" asp-controller="Tournaments" asp-action="PublicIndex" style="font-size: 14px; font-weight: 500;"><i class="bi bi-trophy me-1"></i>Giải đấu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold py-2 px-3 rounded" asp-controller="Tournaments" asp-action="Create" style="font-size: 14px;"><i class="bi bi-plus-circle-fill me-1"></i>Tổ chức giải đấu</a>
                            </li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white-50 hover-white py-2 px-3 rounded" asp-controller="Bookings" asp-action="MyBookings" style="font-size: 14px; font-weight: 500;"><i class="bi bi-clock-history me-1"></i>Lịch sử đặt sân</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white-50 hover-white py-2 px-3 rounded" asp-controller="Tournaments" asp-action="MyTournaments" style="font-size: 14px; font-weight: 500;"><i class="bi bi-award me-1"></i>Giải đấu của tôi</a>
                                </li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="badge bg-primary px-2 py-1 text-uppercase" style="font-size: 11px;">@userRole</span>
                            <span class="text-white-50 small me-2"><i class="bi bi-person-circle me-1"></i>@User.Identity.Name</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Đăng xuất"><i class="bi bi-box-arrow-right"></i></button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary fw-bold px-3" style="border-radius: 6px;">Đăng nhập</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-outline-light fw-bold px-3" style="border-radius: 6px;">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content Area -->
    <div style="padding-top: 76px; min-height: 80vh;">
        @RenderBody()
    </div>

    <!-- Premium Footer -->
    <footer class="py-5" style="background-color: #0D121F; border-top: 1px solid rgba(255,255,255,0.05); margin-top: 80px;">
        <div class="container px-4 px-lg-5">
            <div class="row g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <div class="d-flex align-items-center gap-2 font-outfit mb-3" style="font-weight: 800; font-size: 22px; color: #ffffff;">
                        <span style="background: linear-gradient(135deg, #4F6EF7 0%, #6B85F8 100%); width: 28px; height: 28px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; font-size: 14px;"><i class="bi bi-trophy-fill text-white"></i></span>
                        Sports<span style="color: #4F6EF7;">Court</span>
                    </div>
                    <p class="text-sc-muted text-sm" style="font-size: 13px; line-height: 1.6;">
                        Nền tảng đặt sân thể thao trực tuyến hàng đầu Việt Nam. Nhanh chóng, tiện lợi, minh bạch và an toàn.
                    </p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="text-white font-outfit mb-3" style="font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">Dịch vụ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 13px;">
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Tìm sân thể thao</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Sân Pickleball</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Sân Cầu lông</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Sân Bóng đá mini</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="text-white font-outfit mb-3" style="font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">Hỗ trợ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 13px;">
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Hướng dẫn đặt sân</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Chính sách hoàn tiền</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Điều khoản sử dụng</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="text-white font-outfit mb-3" style="font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">Liên hệ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2 text-sc-muted" style="font-size: 13px; line-height: 1.6;">
                        <li><i class="bi bi-geo-alt-fill me-1"></i> 123 Nguyễn Huệ, Q.1, TP.HCM</li>
                        <li><i class="bi bi-telephone-fill me-1"></i> 1900 1234 (Hỗ trợ 24/7)</li>
                        <li><i class="bi bi-envelope-fill me-1"></i> support@sportscourt.vn</li>
                        <li><i class="bi bi-clock-fill me-1"></i> 06:00 - 22:00 mỗi ngày</li>
                    </ul>
                </div>
            </div>
            <div class="pt-4 border-top border-secondary d-flex flex-col sm:flex-row justify-content-between align-items-center gap-3" style="border-top-color: rgba(255,255,255,0.05) !important;">
                <span class="text-sc-muted" style="font-size: 12px;">&copy; 2026 SportsCourt. Bản quyền thuộc về SportsCourt Vietnam.</span>
                <span class="text-sc-muted" style="font-size: 12px;">Xây dựng bởi Team PRN232 — FPT University</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
