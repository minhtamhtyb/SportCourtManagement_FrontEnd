<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportsCourt</title>
    
    <!-- CSS Bootstrap for utility classes (optional but layout relies on custom css) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sportcourt.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="adminFlashData" 
         data-success="@TempData["Success"]" 
         data-error="@TempData["Error"]" 
         style="display:none;"></div>
    <!-- Premium Header Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background-color: #0D121F; border-bottom: 1px solid rgba(255,255,255,0.05); padding: 16px 0;">
            <div class="container px-4 px-lg-5">
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var isHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);
                    var isCourts = string.Equals(currentController, "Courts", StringComparison.OrdinalIgnoreCase);
                    var isTournaments = string.Equals(currentController, "Tournaments", StringComparison.OrdinalIgnoreCase);
                    var isPromotions = string.Equals(currentController, "Promotions", StringComparison.OrdinalIgnoreCase);
                }
                <a class="navbar-brand d-flex align-items-center gap-2 font-outfit" asp-controller="Home" asp-action="Index" style="font-weight: 800; font-size: 22px; color: #ffffff; letter-spacing: -0.5px;">
                    <span style="background: linear-gradient(135deg, #4F6EF7 0%, #6B85F8 100%); width: 28px; height: 28px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; font-size: 14px;"><i class="bi bi-trophy-fill text-white"></i></span>
                    Sports<span style="color: #4F6EF7;">Court</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                        <li class="nav-item">
                            <a class="nav-link @(isHome ? "text-white active" : "text-white-50 hover-white") py-2 px-3 rounded" asp-controller="Home" asp-action="Index" style='font-size: 14px; font-weight: @(isHome ? "600" : "500"); @(isHome ? "background-color: rgba(255,255,255,0.03);" : "")'>Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isCourts ? "text-white active" : "text-white-50 hover-white") py-2 px-3 rounded" asp-controller="Courts" asp-action="Index" style='font-size: 14px; font-weight: @(isCourts ? "600" : "500"); @(isCourts ? "background-color: rgba(255,255,255,0.03);" : "")'>Danh sách sân</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isTournaments ? "text-white active" : "text-white-50 hover-white") py-2 px-3 rounded" asp-controller="Tournaments" asp-action="PublicIndex" style='font-size: 14px; font-weight: @(isTournaments ? "600" : "500"); @(isTournaments ? "background-color: rgba(255,255,255,0.03);" : "")'>Giải đấu</a>
                        </li>
                        <li class="nav-item">
                            @* <a class="nav-link @(isPromotions ? "text-white active" : "text-white-50 hover-white") py-2 px-3 rounded" asp-controller="Promotions" asp-action="Index" style='font-size: 14px; font-weight: @(isPromotions ? "600" : "500"); @(isPromotions ? "background-color: rgba(255,255,255,0.03);" : "")'>Khuyến mãi</a> *@
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="btn btn-link text-white-50 text-decoration-none hover-white dropdown-toggle p-0 d-flex align-items-center gap-2" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 14px; font-weight: 600; border: none; background: none;">
                                    <i class="bi bi-person-circle fs-5 text-sc-blue"></i>
                                    <span>Xin chào, <strong class="text-white">@User.Identity.Name</strong></span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-lg border-0 rounded-3 mt-2 p-2" aria-labelledby="userDropdown" style="background-color: #141B2D; border: 1px solid rgba(255,255,255,0.1) !important; min-width: 230px;">
                                    <li>
                                        <a class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-white-50 hover-white" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person-vcard text-sc-blue"></i> Hồ sơ cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-white-50 hover-white" asp-controller="Wallet" asp-action="Index">
                                            <i class="bi bi-wallet2 text-success"></i> Ví tiền của tôi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-white-50 hover-white" asp-controller="MyBookings" asp-action="Index">
                                            <i class="bi bi-calendar-check text-sc-blue"></i> Lịch sử đặt sân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-white-50 hover-white" asp-controller="Tournaments" asp-action="MyTournaments">
                                            <i class="bi bi-trophy text-warning"></i> Giải đấu của tôi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-white-50 hover-white" asp-controller="Tournaments" asp-action="Create">
                                            <i class="bi bi-plus-circle-fill text-success"></i> Đặt giải đấu mới
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Staff") || User.IsInRole("Coach"))
                                    {
                                        <li><hr class="dropdown-divider border-secondary my-1 opacity-25"></li>
                                        <li>
                                            <a class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-info fw-semibold" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                                <i class="bi bi-speedometer2"></i> Trang quản trị
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider border-secondary my-1 opacity-25"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item py-2 px-3 rounded d-flex align-items-center gap-2 text-danger w-100 border-0 bg-transparent">
                                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none hover-white" style="font-size: 14px; font-weight: 600;">Đăng nhập</a>
                            <a asp-controller="Account" asp-action="Register" class="sc-btn sc-btn-primary" style="padding: 8px 18px; font-size: 14px; border-radius: 8px; text-decoration: none;">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content Area -->
    <div style="padding-top: 76px; min-height: 80vh;">
        @RenderBody()
    </div>

    <!-- Premium Footer -->
    <footer class="py-5" style="background-color: #0D121F; border-top: 1px solid rgba(255,255,255,0.05); margin-top: 80px;">
        <div class="container px-4 px-lg-5">
            <div class="row g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <div class="d-flex align-items-center gap-2 font-outfit mb-3" style="font-weight: 800; font-size: 22px; color: #ffffff;">
                        <span style="background: linear-gradient(135deg, #4F6EF7 0%, #6B85F8 100%); width: 28px; height: 28px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; font-size: 14px;"><i class="bi bi-trophy-fill text-white"></i></span>
                        Sports<span style="color: #4F6EF7;">Court</span>
                    </div>
                    <p class="text-sc-muted text-sm" style="font-size: 13px; line-height: 1.6;">
                        Nền tảng đặt sân thể thao trực tuyến hàng đầu Việt Nam. Nhanh chóng, tiện lợi, minh bạch và an toàn.
                    </p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="text-white font-outfit mb-3" style="font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">Dịch vụ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 13px;">
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Tìm sân thể thao</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Sân Pickleball</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Sân Cầu lông</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Sân Bóng đá mini</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="text-white font-outfit mb-3" style="font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">Hỗ trợ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 13px;">
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Hướng dẫn đặt sân</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Chính sách hoàn tiền</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Điều khoản sử dụng</a></li>
                        <li><a href="#" class="text-sc-muted text-decoration-none hover-white">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="text-white font-outfit mb-3" style="font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">Liên hệ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2 text-sc-muted" style="font-size: 13px; line-height: 1.6;">
                        <li><i class="bi bi-geo-alt-fill me-1"></i> 123 Nguyễn Huệ, Q.1, TP.HCM</li>
                        <li><i class="bi bi-telephone-fill me-1"></i> 1900 1234 (Hỗ trợ 24/7)</li>
                        <li><i class="bi bi-envelope-fill me-1"></i> support@sportscourt.vn</li>
                        <li><i class="bi bi-clock-fill me-1"></i> 06:00 - 22:00 mỗi ngày</li>
                    </ul>
                </div>
            </div>
            <div class="pt-4 border-top border-secondary d-flex flex-col sm:flex-row justify-content-between align-items-center gap-3" style="border-top-color: rgba(255,255,255,0.05) !important;">
                <span class="text-sc-muted" style="font-size: 12px;">&copy; 2026 SportsCourt. Bản quyền thuộc về SportsCourt Vietnam.</span>
                <span class="text-sc-muted" style="font-size: 12px;">Xây dựng bởi Team PRN232 — FPT University</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
