@{
    var complexes = ViewBag.Complexes as List<SportCourtManagement_FrontEnd.Models.DTOs.CourtComplexDto>
        ?? new List<SportCourtManagement_FrontEnd.Models.DTOs.CourtComplexDto>();
    var sessionComplexId = ViewBag.CurrentComplexId as int? ?? 1;
    var currentComplex = complexes.FirstOrDefault(c => c.ComplexId == sessionComplexId) ?? complexes.FirstOrDefault();
    var currentComplexName = currentComplex?.ComplexName ?? "Sân Quận 1";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CourtManager | Kinetic Enterprise</title>
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Google Geist Font & Material Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Manager/manager-layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="overflow-hidden">
    <div class="d-flex h-100 w-100">
        <!-- Left Sidebar (240px fixed width) -->
        <aside class="sidebar">
            <div class="sidebar-logo px-4 d-flex align-items-center">
                <h1 class="m-0 fs-5 fw-bold text-primary" style="color: var(--primary) !important;">CourtManager</h1>
            </div>
            <nav class="flex-grow-1 py-3">
                <ul class="nav flex-column px-2 gap-1">
                    <li class="nav-item">
                        <a class="sidebar-link" href="/manager/dashboard">
                            <span class="material-symbols-outlined">dashboard</span>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sidebar-link" href="/manager/staff/shifts">
                            <span class="material-symbols-outlined">groups</span>
                            Nhân sự &amp; Ca trực
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sidebar-link" href="/manager/tasks">
                            <span class="material-symbols-outlined">assignment</span>
                            Quản lý Công việc
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sidebar-link" href="/manager/maintenance">
                            <span class="material-symbols-outlined">handyman</span>
                            Bảo trì sân
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sidebar-link" href="/Bookings/AdminIndex">
                            <span class="material-symbols-outlined">calendar_month</span>
                            Quản lý Đặt sân
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sidebar-link" href="/Tournaments/AdminIndex">
                            <span class="material-symbols-outlined">emoji_events</span>
                            Quản lý Giải đấu
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="p-3 border-top" style="border-top-color: var(--outline-variant) !important;">
                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link logout-link text-danger w-100"
                            style="background:none; border:none; cursor:pointer; text-align:left;">
                        <span class="material-symbols-outlined">logout</span>
                        Đăng xuất
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main Wrapper -->
        <div class="d-flex flex-column flex-grow-1 min-vw-0">
            <!-- Right Side Header (64px height) -->
            <header class="header px-4 d-flex align-items-center justify-content-between flex-shrink-0">
                <div class="d-flex align-items-center dropdown">
                    <div class="branch-selector d-flex align-items-center gap-2 px-3 py-2 rounded" style="cursor: pointer;" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="fs-7 fw-medium" style="color: var(--on-surface);">Chi nhánh đang chọn: <span class="fw-bold text-primary" style="color: var(--primary) !important;">@currentComplexName</span></span>
                        <span class="material-symbols-outlined text-muted text-lg">expand_more</span>
                    </div>
                    <ul class="dropdown-menu shadow border-0" style="border-radius: 12px; padding: 8px;">
                        @if (complexes.Any())
                        {
                            foreach (var c in complexes)
                            {
                                <li>
                                    <a class="dropdown-item rounded py-2 px-3 @(c.ComplexId == sessionComplexId ? "active text-white bg-primary" : "")" 
                                       href="javascript:void(0)" onclick="changeComplex(@c.ComplexId)">
                                        @c.ComplexName
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li><span class="dropdown-item-text text-muted">Không có chi nhánh</span></li>
                        }
                    </ul>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="text-end d-none d-sm-block">
                        <p class="m-0 fw-semibold" style="font-size: 14px; color: var(--on-surface);">@User.Identity?.Name</p>
                        <p class="m-0 text-uppercase tracking-wider text-muted" style="font-size: 10px; letter-spacing: 0.05em;">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                    </div>
                    <img alt="Manager Profile Picture" class="user-avatar rounded-circle object-fit-cover"
                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuA2F8HPt7wWLUahORbOOsCiz40UDrnOOYBu__26_jVUEjwrjrAgGUyitMx1ElfkLnFw7H_X_C1H5paESWMxHEGj6ERwpj7sd0n1sQ_vCRplNAd5jI_axazv2IdmbHMZikI331-NPoXgcYUOxYbPGzahf0yMXscMGz5i-i5vo2JA-N4UBWneywYeEoeX3_MdHjEla0B6q0OPUkCLvneGc2q3hESdPF-e5C_Qvn9QQV-vmpinkZMntFn9wGtgSBx9Q8TEWRRfuxhjCkA">
                </div>
            </header>
 
            <!-- Content Area -->
            <main class="flex-grow-1 overflow-auto p-0" style="background-color: var(--surface);">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set active link highlight based on current path
        const currentPath = window.location.pathname;
        let activeLink = null;

        document.querySelectorAll('.sidebar-link').forEach(link => {
            const href = link.getAttribute('href');
            if (!href || href === '/logout') return;
            
            let isMatch = false;
            if (currentPath === href) {
                isMatch = true;
            } else if (href === '/manager/dashboard' && currentPath === '/manager') {
                isMatch = true;
            } else if (href === '/manager/staff/shifts' && currentPath.startsWith('/manager/staff')) {
                isMatch = true;
            } else if (href !== '/manager/dashboard' && href !== '/' && currentPath.startsWith(href)) {
                isMatch = true;
            }
            
            if (isMatch) {
                activeLink = link;
            }
        });

        if (activeLink) {
            document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
            activeLink.classList.add('active');
        }

        function changeComplex(id) {
            const url = new URL(window.location.href);
            url.searchParams.set('complexId', id);
            window.location.href = url.href;
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
