@model SportCourtManagement_FrontEnd.Models.Bookings.BookingListViewModel
@{
  ViewData["Title"] = "Quản Lý Đơn Đặt Sân (Admin)";
}

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold text-dark mb-1"><i class="bi bi-gear-fill me-2 text-primary"></i>Quản Lý Đơn Đặt Sân</h2>
      <p class="text-muted mb-0">Hệ thống quản lý toàn bộ các giao dịch và đơn đặt lịch của sân thể thao</p>
    </div>
  </div>

  @if (TempData["SuccessMessage"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
      <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["ErrorMessage"] != null)
  {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }

  <!-- Advanced Filter Card -->
  <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light">
    <div class="card-body p-4">
      <form method="get" asp-action="AdminIndex" class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Từ khóa (Mã đơn, Tên KH...)</label>
          <input type="text" name="keyword" value="@Model.Keyword" class="form-control rounded-3" placeholder="Tìm kiếm nhanh..." />
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold text-secondary">Loại sân</label>
          <select name="courtTypeId" class="form-select rounded-3">
            <option value="">-- Tất cả --</option>
            @if (ViewBag.CourtTypes != null)
            {
              foreach (var ct in ViewBag.CourtTypes)
              {
                <option value="@ct.CourtTypeId" selected="@(Model.CourtTypeId == ct.CourtTypeId)">@ct.TypeName</option>
              }
            }
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold text-secondary">Từ ngày</label>
          <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control rounded-3" />
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold text-secondary">Đến ngày</label>
          <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control rounded-3" />
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Trạng thái đơn</label>
          <select name="status" class="form-select rounded-3">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Pending" selected="@(Model.Status == "Pending")">Chờ duyệt / Thanh toán</option>
            <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Đã duyệt (Confirmed)</option>
            <option value="Paid" selected="@(Model.Status == "Paid")">Đã thanh toán (Paid)</option>
            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã hủy</option>
          </select>
        </div>
        <div class="col-12 d-flex justify-content-end gap-2 mt-3">
          <a asp-action="AdminIndex" class="btn btn-outline-secondary px-4 rounded-3">Đặt lại</a>
          <button type="submit" class="btn btn-primary px-5 rounded-3 shadow-sm">Lọc danh sách</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Admin Bookings Table -->
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-dark text-white">
          <tr>
            <th class="py-3 px-4">ID / Mã CODE</th>
            <th class="py-3">Khách hàng</th>
            <th class="py-3">Sân / Khung giờ</th>
            <th class="py-3">Ngày đặt</th>
            <th class="py-3">Thành tiền</th>
            <th class="py-3">Khuyến mãi</th>
            <th class="py-3">Trạng thái</th>
            <th class="py-3 text-end px-4">Xử lý</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.PagedData.Items != null && Model.PagedData.Items.Count > 0)
          {
            foreach (var item in Model.PagedData.Items)
            {
              <tr>
                <td class="px-4">
                  <span class="fw-bold text-dark d-block">#@item.BookingId</span>
                  <small class="badge bg-light text-dark border">@item.BookingCode</small>
                </td>
                <td>
                  <span class="fw-semibold text-primary d-block">@item.CustomerName</span>
                  <small class="text-muted">@item.CustomerPhone</small>
                </td>
                <td>
                  <span class="fw-bold">@item.CourtName</span>
                  <small class="d-block text-muted">@item.SlotName</small>
                </td>
                <td>@item.BookingDate.ToString("dd/MM/yyyy")</td>
                <td><span class="text-danger fw-bold fs-6">@item.TotalAmount.ToString("N0")đ</span></td>
                <td>
                  @if (!string.IsNullOrEmpty(item.PromotionCode))
                  {
                    <span class="badge bg-success">@item.PromotionCode (-@item.DiscountAmount.ToString("N0")đ)</span>
                  }
                  else
                  {
                    <span class="text-muted">-</span>
                  }
                </td>
                <td>
                  @switch (item.Status)
                  {
                    case "Confirmed":
                      <span class="badge bg-primary px-3 py-2">Đã xác nhận</span>
                      break;
                    case "Paid":
                      <span class="badge bg-success px-3 py-2">Đã thanh toán</span>
                      break;
                    case "Pending":
                      <span class="badge bg-warning text-dark px-3 py-2">Chờ xử lý</span>
                      break;
                    case "Cancelled":
                      <span class="badge bg-danger px-3 py-2">Đã hủy</span>
                      break;
                    default:
                      <span class="badge bg-secondary px-3 py-2">@item.Status</span>
                      break;
                  }
                </td>
                <td class="text-end px-4">
                  @if (item.Status == "Pending")
                  {
                    <form asp-action="UpdateStatus" method="post" class="d-inline me-1">
                      <input type="hidden" name="id" value="@item.BookingId" />
                      <input type="hidden" name="status" value="Confirmed" />
                      <input type="hidden" name="returnUrl" value="@Url.Action("AdminIndex")" />
                      <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Duyệt</button>
                    </form>
                  }
                  @if (item.Status != "Cancelled")
                  {
                    <form asp-action="UpdateStatus" method="post" class="d-inline" onsubmit="return confirm('Xác nhận hủy đơn đặt sân này?');">
                      <input type="hidden" name="id" value="@item.BookingId" />
                      <input type="hidden" name="status" value="Cancelled" />
                      <input type="hidden" name="cancelReason" value="Quản trị viên hủy đơn" />
                      <input type="hidden" name="returnUrl" value="@Url.Action("AdminIndex")" />
                      <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Hủy</button>
                    </form>
                  }
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="8" class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Không có đơn đặt sân nào.
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    @if (Model.PagedData.TotalPages > 1)
    {
      <div class="card-footer bg-white py-3 px-4 d-flex justify-content-between align-items-center border-top">
        <span class="text-muted small">Trang @Model.PagedData.PageNumber / @Model.PagedData.TotalPages</span>
        <ul class="pagination mb-0">
          <li class="page-item @(Model.PagedData.PageNumber <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="AdminIndex" asp-route-page="@(Model.PagedData.PageNumber - 1)">Trước</a>
          </li>
          @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
          {
            <li class="page-item @(i == Model.PagedData.PageNumber ? "active" : "")">
              <a class="page-link" asp-action="AdminIndex" asp-route-page="@i">@i</a>
            </li>
          }
          <li class="page-item @(Model.PagedData.PageNumber >= Model.PagedData.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="AdminIndex" asp-route-page="@(Model.PagedData.PageNumber + 1)">Sau</a>
          </li>
        </ul>
      </div>
    }
  </div>
</div>
