@model SportCourtManagement_FrontEnd.Models.ViewModels.CreateBookingViewModel

@{
    ViewData["Title"] = "Đặt sân - " + Model.Court.CourtName;
}

<main class="sc-container py-4">
    <!-- Breadcrumb -->
    <nav class="sc-breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <a asp-controller="Courts" asp-action="Index">Tìm sân</a>
        <span>›</span>
        <a asp-controller="Courts" asp-action="Detail" asp-route-id="@Model.Court.CourtId">@Model.Court.CourtName</a>
        <span>›</span>
        <span class="text-white fw-medium">Đặt sân</span>
    </nav>

    <!-- STEP PROGRESS INDICATOR -->
    <div class="row mb-5 justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="d-flex align-items-center justify-content-between position-relative">
                <!-- Progress Line -->
                <div class="position-absolute w-100 start-0 top-50 translate-middle-y z-index-1" style="height: 2px; background-color: rgba(255,255,255,0.05);"></div>
                
                <!-- Step 1 -->
                <div class="d-flex flex-column align-items-center position-relative z-index-2 sc-indicator-completed">
                    <span class="d-flex align-items-center justify-content-center rounded-circle bg-dark border border-secondary" style="width: 32px; height: 32px; font-size: 14px;"><i class="bi bi-check-circle-fill text-success"></i></span>
                    <span class="text-sc-muted small mt-2 font-outfit" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">1. Chọn slot</span>
                </div>
                
                <!-- Step 2 -->
                <div id="indicator-step2" class="d-flex flex-column align-items-center position-relative z-index-2 sc-indicator-active">
                    <span class="d-flex align-items-center justify-content-center rounded-circle bg-dark border border-secondary" style="width: 32px; height: 32px; font-size: 14px;"><i class="bi bi-2-circle-fill"></i></span>
                    <span class="text-white small mt-2 font-outfit" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">2. Thiết lập</span>
                </div>
                
                <!-- Step 3 -->
                <div id="indicator-step3" class="d-flex flex-column align-items-center position-relative z-index-2">
                    <span class="d-flex align-items-center justify-content-center rounded-circle bg-dark border border-secondary" style="width: 32px; height: 32px; font-size: 14px;"><i class="bi bi-3-circle-fill"></i></span>
                    <span class="text-sc-muted small mt-2 font-outfit" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">3. Xác nhận</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden Fields for prices -->
    <input type="hidden" id="slot-price" value="@Model.SelectedSlot.Price" />
    <input type="hidden" id="original-date" value="@Model.BookingDate.ToString("yyyy-MM-dd")" />

    <form id="booking-form" asp-action="Create" asp-controller="Bookings" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="courtId" value="@Model.Court.CourtId" />
        <input type="hidden" name="slotId" value="@Model.SelectedSlot.SlotId" />
        <input type="hidden" name="date" value="@Model.BookingDate.ToString("yyyy-MM-dd")" />

        <div class="row g-4">
            <!-- LEFT COLUMN: Form Elements -->
            <div class="col-lg-8">
                
                <!-- STEP 2 CONTAINER: CONFIGURATION -->
                <div id="step2-container">
                    <div class="sc-card p-4 mb-4" style="background-color: #0D121F;">
                        <h4 class="font-outfit text-white mb-4" style="font-weight: 800; border-left: 4px solid var(--sc-blue); padding-left: 12px;">
                            Thiết Lập Đơn Đặt Sân
                        </h4>

                        <!-- Court Summary Row -->
                        <div class="d-flex align-items-center gap-3 p-3 rounded mb-4" style="background-color: rgba(255, 255, 255, 0.02); border: 1px solid var(--sc-border);">
                            <div style="width: 100px; height: 75px; border-radius: 8px; overflow: hidden; flex-shrink: 0;">
                                @if (!string.IsNullOrEmpty(Model.Court.ImageUrl))
                                {
                                    <img src="~/images/courts/@Model.Court.ImageUrl" alt="@Model.Court.CourtName" class="w-100 h-100 object-fit-cover" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-secondary text-white" style="font-size: 10px;">
                                        No Image
                                    </div>
                                }
                            </div>
                            <div>
                                <h5 class="text-white font-outfit mb-1" style="font-weight: 700;">@Model.Court.CourtName</h5>
                                <p class="text-sc-muted mb-1" style="font-size: 12px;"><i class="bi bi-geo-alt-fill me-1"></i> Vị trí: @Model.Court.Location</p>
                                <span class="sc-badge sc-badge-blue"><i class="bi bi-dribbble me-1"></i> @Model.Court.CourtType.TypeName</span>
                            </div>
                        </div>

                        <!-- Toggle Booking Mode: Single vs Recurring -->
                        <div class="mb-4 p-3 rounded-3" style="background: #141B2D; border: 1px solid var(--sc-border);">
                            <label class="text-sc-muted d-block font-inter mb-3" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Chế độ đặt sân</label>
                            <div class="d-flex align-items-center gap-4">
                                <label class="d-inline-flex align-items-center gap-2 text-white style-mode-label" style="cursor: pointer;">
                                    <input type="radio" name="isRecurring" value="false" checked style="accent-color: var(--sc-blue); width: 18px; height: 18px;" />
                                    <span style="font-size: 14px; font-weight: 600;">Đặt đơn lẻ</span>
                                </label>
                                <label class="d-inline-flex align-items-center gap-2 text-white style-mode-label" style="cursor: pointer;">
                                    <input type="radio" name="isRecurring" value="true" style="accent-color: var(--sc-blue); width: 18px; height: 18px;" />
                                    <span style="font-size: 14px; font-weight: 600;">Đặt định kỳ (Theo tuần)</span>
                                </label>
                            </div>
                        </div>

                        <!-- Single Booking Info -->
                        <div id="single-date-info" class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 rounded" style="background-color: #141B2D; border: 1px solid var(--sc-border);">
                                    <label class="text-sc-muted d-block font-inter mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Ngày đặt sân</label>
                                    <span class="text-white fw-bold" style="font-size: 15px;"><i class="bi bi-calendar3 me-2 text-sc-blue-light"></i> @Model.BookingDate.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 rounded" style="background-color: #141B2D; border: 1px solid var(--sc-border);">
                                    <label class="text-sc-muted d-block font-inter mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Khung giờ đã chọn</label>
                                    <span class="text-white fw-bold" style="font-size: 15px;"><i class="bi bi-clock me-2 text-sc-green"></i> @Model.SelectedSlot.SlotName (@Model.SelectedSlot.StartTime.ToString("hh\\:mm") - @Model.SelectedSlot.EndTime.ToString("hh\\:mm"))</span>
                                </div>
                            </div>
                        </div>

                        <!-- Recurring Booking Configuration Fields -->
                        <div id="recurring-fields" class="mb-4" style="display: none;">
                            <h5 class="font-outfit text-white mb-3" style="font-weight: 700; font-size: 16px;"><i class="bi bi-calendar-event me-1 text-sc-blue-light"></i> Cấu hình đặt lịch định kỳ</h5>
                            
                            <!-- Date Range -->
                            <div class="row g-3 mb-3">
                                <div class="col-sm-6">
                                    <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Từ ngày (Start Date)</label>
                                    <input type="date" id="start-date" name="startDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="sc-input" style="color-scheme: dark;" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Đến ngày (End Date)</label>
                                    <input type="date" id="end-date" name="endDate" value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="sc-input" style="color-scheme: dark;" />
                                </div>
                            </div>

                            <!-- Days selection presets -->
                            <div class="mb-3">
                                <label class="form-label text-sc-muted font-inter d-block" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Chọn nhanh lịch cố định</label>
                                <div class="d-flex gap-2">
                                    <button type="button" id="btn-246" class="sc-btn sc-btn-secondary py-1 px-3" style="font-size: 12px; border-radius: 8px;">Thứ 2 - 4 - 6</button>
                                    <button type="button" id="btn-357" class="sc-btn sc-btn-secondary py-1 px-3" style="font-size: 12px; border-radius: 8px;">Thứ 3 - 5 - 7</button>
                                </div>
                            </div>

                            <!-- Checkboxes for individual days of week -->
                            <div class="mb-3">
                                <label class="form-label text-sc-muted font-inter d-block" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Chọn các thứ trong tuần</label>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var day in new[] { 
                                        new { Id = 1, Name = "Thứ 2" },
                                        new { Id = 2, Name = "Thứ 3" },
                                        new { Id = 3, Name = "Thứ 4" },
                                        new { Id = 4, Name = "Thứ 5" },
                                        new { Id = 5, Name = "Thứ 6" },
                                        new { Id = 6, Name = "Thứ 7" },
                                        new { Id = 0, Name = "Chủ Nhật" }
                                    })
                                    {
                                        <label class="p-2 rounded border d-inline-flex align-items-center gap-2 text-white style-mode-label" style="background: rgba(255,255,255,0.01); border-color: rgba(255,255,255,0.05); cursor: pointer; font-size: 13px;">
                                            <input type="checkbox" name="daysOfWeek" value="@day.Id" id="day-@day.Id" class="day-checkbox" style="accent-color: var(--sc-blue);" />
                                            <span>@day.Name</span>
                                        </label>
                                    }
                                </div>
                            </div>

                            <!-- Preview list of dates calculated -->
                            <div id="recurring-dates-preview" class="p-3 rounded border" style="background-color: rgba(255, 255, 255, 0.01); border-color: rgba(255,255,255,0.05);">
                                <div class="text-sc-muted small text-center"><i class="bi bi-calendar3"></i> Hãy chọn ngày bắt đầu, ngày kết thúc và các thứ trong tuần để xem trước lịch.</div>
                            </div>
                        </div>

                        <!-- Services Add-ons -->
                        <div class="mb-4" id="services-section">
                            <h5 class="font-outfit text-white mb-3" style="font-weight: 700; font-size: 16px;"><i class="bi bi-box-seam me-1 text-sc-blue-light"></i> Dịch vụ phụ trợ (Tùy chọn)</h5>
                            <div class="row g-3">
                                <!-- Service 1: Rackets -->
                                <div class="col-sm-6">
                                    <div class="p-3 rounded d-flex align-items-center justify-content-between" style="background-color: rgba(255, 255, 255, 0.01); border: 1px solid var(--sc-border);">
                                        <div>
                                            <div class="text-white fw-bold" style="font-size: 14px;">Thuê vợt thể thao</div>
                                            <div class="text-sc-green fw-medium" style="font-size: 12px;">30.000đ / cái</div>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace" onclick="changeQty('racketQty', -1)">-</button>
                                            <input type="number" id="racketQty" name="racketQty" value="0" min="0" max="10" class="text-center bg-transparent border-0 text-white font-monospace" style="width: 30px; font-size: 14px;" readonly />
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace" onclick="changeQty('racketQty', 1)">+</button>
                                        </div>
                                    </div>
                                </div>
                                <!-- Service 2: Drinks -->
                                <div class="col-sm-6">
                                    <div class="p-3 rounded d-flex align-items-center justify-content-between" style="background-color: rgba(255, 255, 255, 0.01); border: 1px solid var(--sc-border);">
                                        <div>
                                            <div class="text-white fw-bold" style="font-size: 14px;">Nước bù khoáng (Pocari)</div>
                                            <div class="text-sc-green fw-medium" style="font-size: 12px;">15.000đ / chai</div>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace" onclick="changeQty('drinkQty', -1)">-</button>
                                            <input type="number" id="drinkQty" name="drinkQty" value="0" min="0" max="20" class="text-center bg-transparent border-0 text-white font-monospace" style="width: 30px; font-size: 14px;" readonly />
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace" onclick="changeQty('drinkQty', 1)">+</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Note & Promotion -->
                        <div class="mb-3">
                            <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Mã giảm giá (Nếu có)</label>
                            <div class="d-flex gap-2">
                                <input type="text" id="promo-input" name="promotionCode" class="sc-input" placeholder="Nhập mã ưu đãi (Ví dụ: DISCOUNT10)" style="max-width: 300px;" />
                                <button type="button" class="sc-btn sc-btn-secondary py-2" onclick="applyPromo()">Áp dụng</button>
                            </div>
                            <div id="promo-msg" class="form-text small mt-1" style="display:none;"></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Ghi chú đặt sân</label>
                            <textarea name="note" rows="3" class="sc-input" placeholder="Nhập ghi chú của bạn cho ban quản lý sân (VD: chuẩn bị thêm vợt thuê...)"></textarea>
                        </div>
                        
                        <!-- Next to step 3 button -->
                        <div class="mt-4 pt-3 border-top" style="border-top-color: rgba(255,255,255,0.05) !important;">
                            <button type="button" id="btn-next-step" class="sc-btn sc-btn-primary px-4 py-2.5 d-flex align-items-center gap-2">
                                Tiếp tục <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- STEP 3 CONTAINER: CONFIRMATION -->
                <div id="step3-container" style="display: none;">
                    <div class="sc-card p-4 mb-4" style="background-color: #0D121F;">
                        <h4 class="font-outfit text-white mb-4" style="font-weight: 800; border-left: 4px solid var(--sc-green); padding-left: 12px;">
                            Xác Nhận Đơn Đặt Sân
                        </h4>

                        <div class="p-4 rounded-3 border mb-4" style="background: rgba(255, 255, 255, 0.01); border-color: rgba(255,255,255,0.05);">
                            <h5 class="text-white font-outfit mb-3" style="font-size: 16px;"><i class="bi bi-info-circle text-sc-blue-light me-1"></i> Tóm tắt lịch đặt</h5>
                            
                            <div class="row g-3" style="font-size: 13.5px; line-height: 1.8;">
                                <div class="col-sm-6">
                                    <span class="text-sc-muted d-block">Sân thể thao:</span>
                                    <strong class="text-white">@Model.Court.CourtName</strong>
                                </div>
                                <div class="col-sm-6">
                                    <span class="text-sc-muted d-block">Khung giờ:</span>
                                    <strong class="text-white">@Model.SelectedSlot.SlotName (@Model.SelectedSlot.StartTime.ToString("hh\\:mm") - @Model.SelectedSlot.EndTime.ToString("hh\\:mm"))</strong>
                                </div>
                                <div class="col-sm-6">
                                    <span class="text-sc-muted d-block">Hình thức:</span>
                                    <strong id="confirm-type" class="text-sc-blue-light">Đơn lẻ</strong>
                                </div>
                                <div class="col-sm-6">
                                    <span class="text-sc-muted d-block">Thời gian hiệu lực:</span>
                                    <strong id="confirm-date-range" class="text-white"></strong>
                                </div>
                                <div class="col-sm-12" id="confirm-days-row" style="display: none;">
                                    <span class="text-sc-muted d-block">Các thứ lặp lại:</span>
                                    <strong id="confirm-days" class="text-white"></strong>
                                </div>
                            </div>
                        </div>

                        <!-- Date range availability preview with checkmarks -->
                        <div class="mb-4">
                            <h5 class="text-white font-outfit mb-3" style="font-size: 15px;"><i class="bi bi-calendar-check text-sc-green me-1"></i> Chi tiết các buổi đặt</h5>
                            <div id="step3-dates-preview">
                                <!-- Dynamically populated by booking-stepper.js -->
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-3 pt-3 border-top" style="border-top-color: rgba(255,255,255,0.05) !important;">
                            <button type="button" id="btn-prev-step" class="sc-btn sc-btn-secondary px-4 py-2.5">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại sửa
                            </button>
                            <button type="submit" class="sc-btn sc-btn-primary px-5 py-2.5 fw-bold d-flex align-items-center gap-2" style="background-color: var(--sc-green);">
                                <i class="bi bi-check-circle-fill"></i> Xác nhận đặt lịch
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN: Order Summary Box (Persisted in layout) -->
            <div class="col-lg-4">
                <div class="sc-booking-sidebar">
                    <div class="sc-card p-4" style="background-color: #0D121F;">
                        <h5 class="font-outfit text-white mb-3 pb-2 border-bottom" style="font-weight: 700; border-bottom-color: rgba(255,255,255,0.05) !important;">
                            Tóm Tắt Đơn Đặt Sân
                        </h5>

                        <!-- Price breakdown -->
                        <div class="space-y-3 mb-4" style="font-size: 13.5px; line-height: 1.8;">
                            <div class="d-flex justify-content-between">
                                <span class="text-sc-muted">Tiền sân<span id="sessions-count-lbl"></span>:</span>
                                <span id="court-total-lbl" class="text-white fw-semibold">@Model.SelectedSlot.Price.ToString("N0")đ</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-sc-muted">Tiền dịch vụ thêm:</span>
                                <span id="services-total-lbl" class="text-white fw-semibold">0đ</span>
                            </div>
                            <div class="d-flex justify-content-between text-sc-amber" id="discount-row" style="display: none;">
                                <span>Khuyến mãi áp dụng:</span>
                                <span id="discount-total-lbl">-0đ</span>
                            </div>
                            <hr style="border-color: rgba(255,255,255,0.05);" />
                            <div class="d-flex justify-content-between align-items-baseline">
                                <span class="text-white fw-bold">Tổng thanh toán:</span>
                                <span id="grand-total-lbl" class="font-outfit text-sc-green fw-black" style="font-size: 22px; font-weight: 900;">@Model.SelectedSlot.Price.ToString("N0")đ</span>
                            </div>
                        </div>

                        <!-- Policy Warning -->
                        <div class="p-3 mb-4 rounded" style="background-color: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.15); font-size: 12px; line-height: 1.5;">
                            <span class="text-sc-red fw-bold d-block mb-1"><i class="bi bi-info-circle-fill me-1"></i> Lưu ý hủy lịch</span>
                            <span class="text-sc-muted">Dịch vụ này không hỗ trợ hoàn tiền hoặc thay đổi khung giờ chơi sau khi đã thanh toán thành công.</span>
                        </div>

                        <!-- Info display only in step 2 -->
                        <div class="p-3 rounded text-sc-muted text-center" style="background: #141B2D; font-size: 12px; border: 1px solid var(--sc-border);">
                            <i class="bi bi-shield-lock-fill text-sc-blue-light me-1"></i> Bảng tính giá trị tạm tính. Bạn có thể thay đổi các tham số ở phần thiết lập.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</main>

@section Scripts {
    <script src="~/js/booking-stepper.js" asp-append-version="true"></script>
}
