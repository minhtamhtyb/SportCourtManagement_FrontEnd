@model SportCourtManagement_FrontEnd.Models.Bookings.BookingListViewModel
@{
  ViewData["Title"] = "Lịch Sử Đặt Sân Của Tôi";
}

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold text-primary mb-1"><i class="bi bi-calendar-check-fill me-2"></i>Lịch Sử Đặt Sân</h2>
      <p class="text-muted mb-0">Quản lý và theo dõi trạng thái các đơn đặt sân của bạn</p>
    </div>
    <a asp-controller="Courts" asp-action="Index" class="btn btn-outline-primary px-4 py-2 rounded-pill shadow-sm">
      <i class="bi bi-search me-1"></i> Đặt sân ngay
    </a>
  </div>

  @if (TempData["SuccessMessage"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["ErrorMessage"] != null)
  {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }

  <!-- Filter Card -->
  <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light">
    <div class="card-body p-4">
      <form method="get" asp-action="MyBookings" class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Từ khóa</label>
          <input type="text" name="keyword" value="@Model.Keyword" class="form-control rounded-3" placeholder="Mã đơn..." />
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Từ ngày</label>
          <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control rounded-3" />
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Đến ngày</label>
          <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control rounded-3" />
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Trạng thái</label>
          <select name="status" class="form-select rounded-3">
            <option value="">-- Tất cả --</option>
            <option value="Pending" selected="@(Model.Status == "Pending")">Chờ xác nhận</option>
            <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Đã xác nhận</option>
            <option value="Paid" selected="@(Model.Status == "Paid")">Đã thanh toán</option>
            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã hủy</option>
          </select>
        </div>
        <div class="col-12 d-flex justify-content-end gap-2 mt-3">
          <a asp-action="MyBookings" class="btn btn-outline-secondary px-4 rounded-3">Đặt lại</a>
          <button type="submit" class="btn btn-primary px-4 rounded-3 shadow-sm">Tìm kiếm</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Bookings List Table -->
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-primary text-white">
          <tr>
            <th class="py-3 px-4">Mã Đơn</th>
            <th class="py-3">Sân đấu</th>
            <th class="py-3">Khung giờ & Ngày</th>
            <th class="py-3">Tổng tiền</th>
            <th class="py-3">Khuyến mãi</th>
            <th class="py-3">Trạng thái</th>
            <th class="py-3 text-end px-4">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.PagedData.Items != null && Model.PagedData.Items.Count > 0)
          {
            foreach (var item in Model.PagedData.Items)
            {
              <tr>
                <td class="px-4 fw-bold text-primary">#@item.BookingCode</td>
                <td class="fw-semibold">@item.CourtName</td>
                <td>
                  <span class="d-block fw-bold text-dark">@item.SlotName</span>
                  <small class="text-muted"><i class="bi bi-calendar me-1"></i>@item.BookingDate.ToString("dd/MM/yyyy")</small>
                </td>
                <td><span class="text-danger fw-bold fs-6">@item.TotalAmount.ToString("N0")đ</span></td>
                <td>
                  @if (!string.IsNullOrEmpty(item.PromotionCode))
                  {
                    <span class="badge bg-success">@item.PromotionCode</span>
                  }
                  else
                  {
                    <span class="text-muted">-</span>
                  }
                </td>
                <td>
                  @switch (item.Status)
                  {
                    case "Confirmed" or "Paid":
                      <span class="badge bg-success px-3 py-2 rounded-pill">@item.Status</span>
                      break;
                    case "Pending":
                      <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ xử lý</span>
                      break;
                    case "Cancelled":
                      <span class="badge bg-danger px-3 py-2 rounded-pill">Đã hủy</span>
                      break;
                    default:
                      <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Status</span>
                      break;
                  }
                </td>
                <td class="text-end px-4">
                  @if (item.Status == "Pending")
                  {
                    <form asp-action="UpdateStatus" method="post" class="d-inline" onsubmit="return confirm('Bạn có muốn hủy đơn đặt sân này không?');">
                      <input type="hidden" name="id" value="@item.BookingId" />
                      <input type="hidden" name="status" value="Cancelled" />
                      <input type="hidden" name="cancelReason" value="Khách hàng tự hủy" />
                      <input type="hidden" name="returnUrl" value="@Url.Action("MyBookings")" />
                      <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Hủy đơn</button>
                    </form>
                  }
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                Bạn chưa có đơn đặt sân nào phù hợp với bộ lọc.
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    @if (Model.PagedData.TotalPages > 1)
    {
      <div class="card-footer bg-white py-3 px-4 d-flex justify-content-between align-items-center border-top">
        <span class="text-muted small">Hiển thị trang @Model.PagedData.PageNumber / @Model.PagedData.TotalPages</span>
        <ul class="pagination mb-0">
          <li class="page-item @(Model.PagedData.PageNumber <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="MyBookings" asp-route-page="@(Model.PagedData.PageNumber - 1)">Trước</a>
          </li>
          @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
          {
            <li class="page-item @(i == Model.PagedData.PageNumber ? "active" : "")">
              <a class="page-link" asp-action="MyBookings" asp-route-page="@i">@i</a>
            </li>
          }
          <li class="page-item @(Model.PagedData.PageNumber >= Model.PagedData.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="MyBookings" asp-route-page="@(Model.PagedData.PageNumber + 1)">Sau</a>
          </li>
        </ul>
      </div>
    }
  </div>
</div>
