@model SportCourtManagement_FrontEnd.Models.Api.PagedResult<SportCourtManagement_FrontEnd.Models.Reviews.ReviewDto>

@if (Model.Items == null || Model.Items.Count == 0)
{
    <div class="text-center py-5 text-sc-muted sc-card" style="background-color: rgba(255,255,255,0.01);">
        <i class="bi bi-chat-dots me-1"></i> Chưa có đánh giá nào cho sân đấu này.
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var review in Model.Items)
        {
            <div class="sc-review-item">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(review.UserAvatarUrl))
                        {
                            <img src="@review.UserAvatarUrl" alt="@review.UserFullName" class="sc-avatar object-fit-cover" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="sc-avatar text-white fw-bold" style="background: linear-gradient(135deg, #4F6EF7 0%, #8B5CF6 100%); border-radius: 50%; width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;">
                                @(string.IsNullOrEmpty(review.UserFullName) ? "U" : review.UserFullName.Substring(0, 1).ToUpper())
                            </div>
                        }
                        <div>
                            <h6 class="text-white mb-1" style="font-weight: 600; font-size: 14px;">@review.UserFullName</h6>
                            <div class="d-flex align-items-center gap-1.5" style="font-size: 12px;">
                                <div class="d-flex">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="sc-star @(i <= review.Rating ? "sc-star-filled" : "")" style="font-size: 12px;"><i class="bi bi-star-fill"></i></span>
                                    }
                                </div>
                                <span class="text-sc-muted">•</span>
                                <span class="text-sc-muted">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <p class="text-sc-primary mb-0" style="font-size: 13.5px; line-height: 1.6; white-space: pre-line;">
                    @review.Comment
                </p>

                @if (!string.IsNullOrEmpty(review.ImageUrl))
                {
                    <div class="mt-3">
                        <img src="@review.ImageUrl" alt="Ảnh đính kèm" class="rounded" style="max-width: 150px; max-height: 150px; object-fit: cover;" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(review.AdminReply))
                {
                    <div class="mt-3 p-3 rounded" style="background-color: rgba(255,255,255,0.02); border-left: 3px solid var(--sc-blue);">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-white font-outfit" style="font-weight: 700; font-size: 13px;"><i class="bi bi-shield-check me-1"></i> Quản trị viên phản hồi</span>
                            @if (review.RepliedAt.HasValue)
                            {
                                <span class="text-sc-muted" style="font-size: 11px;">@review.RepliedAt.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </div>
                        <p class="text-sc-muted mb-0" style="font-size: 13px; line-height: 1.5;">
                            @review.AdminReply
                        </p>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Review Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center mt-4">
            <ul class="pagination gap-1.5">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    var isActive = Model.PageNumber == i;
                    <li class="page-item @(isActive ? "active" : "")">
                        <button type="button" class="sc-btn @(isActive ? "sc-btn-primary" : "sc-btn-secondary") py-1.5 px-3" style="font-size: 12px; border-radius: 6px;" onclick="loadReviewsPage(@Model.Items[0].CourtId, @i)">
                            @i
                        </button>
                    </li>
                }
            </ul>
        </nav>
    }
}
