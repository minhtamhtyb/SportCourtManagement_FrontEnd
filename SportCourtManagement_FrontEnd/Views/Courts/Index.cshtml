@model SportCourtManagement_FrontEnd.Models.ViewModels.CourtSearchViewModel

@{
    ViewData["Title"] = "Tìm kiếm sân đấu";
}

<!-- Page Header Bar -->
<div class="w-100" style="background-color: #0D121F; border-bottom: 1px solid rgba(255,255,255,0.05); margin-top: 1px; padding: 27px 0;">
    <div class="sc-container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h1 class="font-outfit text-white mb-1" style="font-weight: 800; font-size: 24px; letter-spacing: -0.4px;">
                    Tìm kiếm sân đấu
                </h1>
                <p class="text-sc-muted mb-0" style="font-size: 13px;">
                    Lọc theo loại hình sân, khoảng giá và xếp hạng đánh giá để tìm sân đấu ưng ý nhất
                </p>
            </div>
            <span class="sc-badge sc-badge-green" style="padding: 6px 14px;">
                <i class="bi bi-circle-fill me-1" style="font-size: 8px; color: var(--sc-green);"></i> @Model.CourtsResult.TotalCount+ Sân đấu sẵn sàng
            </span>
        </div>
    </div>
</div>

<!-- Main Search Layout -->
<div class="sc-container py-5">
    <form id="search-form" method="get" action="@Url.Action("Index", "Courts")">
        <div class="row g-4">
            <!-- Left Sidebar (Filters) -->
            <aside class="col-lg-3">
                <div class="sc-card p-4" style="background-color: #0D121F;">
                    <div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom" style="border-bottom-color: rgba(255,255,255,0.05) !important;">
                        <span class="font-outfit text-white" style="font-weight: 700; font-size: 14px;"><i class="bi bi-sliders me-1"></i> Bộ lọc</span>
                        <a href="@Url.Action("Index", "Courts")" class="sc-btn sc-btn-secondary py-1 px-3" style="font-size: 12px; border-radius: 999px;">Xóa tất cả</a>
                    </div>

                    <!-- Filter by Sport Type -->
                    <div class="mb-4 pb-4 border-bottom" style="border-bottom-color: rgba(255,255,255,0.05) !important;">
                        <p class="text-sc-muted font-inter uppercase tracking-wide mb-3" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                            Loại sân
                        </p>
                        <div class="d-flex flex-column gap-2">
                            @foreach (var type in Model.CourtTypes)
                            {
                                var isChecked = Model.SearchParams.CourtTypeId == type.CourtTypeId;
                                <label class="d-flex justify-content-between align-items-center px-2 py-2 rounded style-label-hover" style="cursor: pointer; transition: background-color 0.2s;">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" name="CourtTypeId" value="@type.CourtTypeId" @(isChecked ? "checked" : "") style="accent-color: var(--sc-blue); cursor: pointer;" />
                                        <span class="text-sc-primary font-inter" style="font-size: 13px;">@type.TypeName</span>
                                    </div>
                                    <span class="px-2 py-0.5 rounded-pill text-sc-muted font-inter" style="font-size: 11px; background-color: #141B2D;">
                                        @type.CourtCount
                                    </span>
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Filter by Date & Time Slot -->
                    <div class="mb-4 pb-4 border-bottom" style="border-bottom-color: rgba(255,255,255,0.05) !important;">
                        <p class="text-sc-muted font-inter uppercase tracking-wide mb-3" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                            Lịch chơi trống
                        </p>
                        <div class="mb-3">
                            <label class="text-sc-muted font-inter uppercase mb-2 d-block" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">Ngày chơi</label>
                            <input type="date" name="Date" value="@(Model.SearchParams.Date.HasValue ? Model.SearchParams.Date.Value.ToString("yyyy-MM-dd") : "")" class="sc-input py-2" style="color-scheme: dark;" />
                        </div>
                        <div>
                            <label class="text-sc-muted font-inter uppercase mb-2 d-block" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">Khung giờ</label>
                            <select name="TimeSlotId" class="sc-input py-2">
                                <option value="">Tất cả khung giờ</option>
                                <option value="1" selected="@(Model.SearchParams.TimeSlotId == 1 ? "selected" : null)">Ca 1 (07:00 - 09:00)</option>
                                <option value="2" selected="@(Model.SearchParams.TimeSlotId == 2 ? "selected" : null)">Ca 2 (09:00 - 11:00)</option>
                                <option value="3" selected="@(Model.SearchParams.TimeSlotId == 3 ? "selected" : null)">Ca 3 (14:00 - 16:00)</option>
                                <option value="4" selected="@(Model.SearchParams.TimeSlotId == 4 ? "selected" : null)">Ca 4 (16:00 - 18:00)</option>
                                <option value="5" selected="@(Model.SearchParams.TimeSlotId == 5 ? "selected" : null)">Ca Vàng (18:00 - 20:00)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Filter by Price Range -->
                    <div class="mb-4 pb-4 border-bottom" style="border-bottom-color: rgba(255,255,255,0.05) !important;">
                        <p class="text-sc-muted font-inter uppercase tracking-wide mb-3" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                            Khoảng giá / giờ
                        </p>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="text-sc-muted font-inter uppercase mb-2 d-block" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">Từ (đ)</label>
                                <input type="number" name="MinPrice" value="@Model.SearchParams.MinPrice" placeholder="0" class="sc-input" />
                            </div>
                            <div class="col-6">
                                <label class="text-sc-muted font-inter uppercase mb-2 d-block" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">Đến (đ)</label>
                                <input type="number" name="MaxPrice" value="@Model.SearchParams.MaxPrice" placeholder="500000" class="sc-input" />
                            </div>
                        </div>
                    </div>

                    <!-- Filter by Status -->
                    <div class="mb-4 pb-4 border-bottom" style="border-bottom-color: rgba(255,255,255,0.05) !important;">
                        <p class="text-sc-muted font-inter uppercase tracking-wide mb-3" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                            Trạng thái
                        </p>
                        <div class="d-flex flex-column gap-2">
                            <label class="d-flex align-items-center gap-2 px-2 py-2 rounded" style="cursor: pointer;">
                                <input type="radio" name="Status" value="" @(string.IsNullOrEmpty(Model.SearchParams.Status) ? "checked" : "") style="accent-color: var(--sc-blue);" />
                                <span class="text-sc-primary font-inter" style="font-size: 13px;">Tất cả</span>
                            </label>
                            <label class="d-flex align-items-center gap-2 px-2 py-2 rounded" style="cursor: pointer;">
                                <input type="radio" name="Status" value="Available" @(Model.SearchParams.Status == "Available" ? "checked" : "") style="accent-color: var(--sc-blue);" />
                                <span class="text-sc-primary font-inter" style="font-size: 13px;">Sân còn trống</span>
                            </label>
                        </div>
                    </div>

                    <!-- Apply Filters Button -->
                    <button type="submit" class="sc-btn sc-btn-primary w-100 py-3">
                        <i class="bi bi-check-circle me-1"></i> Áp dụng bộ lọc
                    </button>
                </div>
            </aside>

            <!-- Right Content Area (Search and Listings) -->
            <div class="col-lg-9">
                <!-- Search Bar -->
                <div class="position-relative mb-4">
                    <span class="position-absolute top-50 translate-middle-y start-0 ps-3 text-sc-muted" style="font-size: 15px;"><i class="bi bi-search"></i></span>
                    <input type="text" name="SearchTerm" value="@Model.SearchParams.SearchTerm" placeholder="Tìm theo tên sân, địa điểm, mã sân..." class="sc-input w-100 py-3" style="padding-left: 45px !important;" />
                </div>

                <!-- Sort & Toolbar -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <p class="text-sc-muted mb-0" style="font-size: 13px;">
                        Tìm thấy <span class="text-sc-green font-bold">@Model.CourtsResult.TotalCount</span> sân đấu
                    </p>
                    
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-sc-muted" style="font-size: 13px; white-space: nowrap;">Sắp xếp:</span>
                        <select name="SortBy" class="sc-input py-2" style="width: auto; cursor: pointer;" onchange="this.form.submit()">
                            <!option value="" @(string.IsNullOrEmpty(Model.SearchParams.SortBy) ? "selected" : null)>Mặc định</!option>
                            <!option value="rating" @(Model.SearchParams.SortBy == "rating" ? "selected" : null)><i class="bi bi-star-fill"></i> Đánh giá cao nhất</!option>
                            <!option value="price" @(Model.SearchParams.SortBy == "price" ? "selected" : null)><i class="bi bi-tag"></i> Giá thấp nhất</!option>
                        </select>
                        <!-- Hidden input to maintain page numbers -->
                        <input type="hidden" name="PageNumber" value="1" />
                    </div>
                </div>

                <!-- Court Cards Grid -->
                @if (Model.CourtsResult.Items.Count == 0)
                {
                    <div class="text-center py-5 sc-card d-flex flex-column align-items-center justify-content-center" style="background-color: #0D121F;">
                        <span class="fs-1 mb-3"><i class="bi bi-search"></i></span>
                        <h4 class="font-outfit text-white mb-2" style="font-weight: 700;">Không tìm thấy sân</h4>
                        <p class="text-sc-muted" style="font-size: 13px;">Hãy thử điều chỉnh bộ lọc hoặc từ khóa tìm kiếm khác</p>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var court in Model.CourtsResult.Items)
                        {
                            <div class="col-md-6 col-xl-4 d-flex align-items-stretch">
                                @await Html.PartialAsync("_CourtCard", court)
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    @if (Model.CourtsResult.TotalPages > 1)
                    {
                        <nav class="d-flex justify-content-center mt-5">
                            <ul class="pagination gap-2">
                                @for (int i = 1; i <= Model.CourtsResult.TotalPages; i++)
                                {
                                    var isActive = Model.CourtsResult.PageNumber == i;
                                    <li class="page-item @(isActive ? "active" : "")">
                                        <button type="button" class="sc-btn @(isActive ? "sc-btn-primary" : "sc-btn-secondary") px-3 py-2" style="border-radius: 8px;" onclick="changePage(@i)">
                                            @i
                                        </button>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </form>
</div>

<style>
    .style-label-hover:hover {
        background-color: rgba(255, 255, 255, 0.02);
    }
</style>

@section Scripts {
    <script>
        function changePage(pageNumber) {
            const form = document.getElementById("search-form");
            form.querySelector("input[name='PageNumber']").value = pageNumber;
            form.submit();
        }
    </script>
}
