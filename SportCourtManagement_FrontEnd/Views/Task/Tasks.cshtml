@model SportCourtManagement_FrontEnd.Models.Manager.TaskViewModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Quản lý công việc | ProCourt";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/tasks.css" asp-append-version="true" />
}

<div class="tasks-container">

    <!-- Module Header -->
    <div class="module-header">
        <div class="module-title">
            <h3>Quản lý công việc</h3>
            <p>Phân công, giám sát và duyệt nghiệm thu các công việc vận hành tại cơ sở.</p>
        </div>
        <div class="header-actions">
            <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                <span class="material-symbols-outlined">add</span>
                Tạo công việc
            </button>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="summary-stats">
        <div class="stat-card glass-panel">
            <div class="stat-icon orange">
                <span class="material-symbols-outlined">assignment_late</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Chờ thực hiện</p>
                <span class="stat-value orange">@Model.PendingCount</span>
                <p class="stat-sub">Pending</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon sky">
                <span class="material-symbols-outlined">pending</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Đang làm</p>
                <span class="stat-value sky">@Model.InProgressCount</span>
                <p class="stat-sub">In Progress</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon emerald">
                <span class="material-symbols-outlined">fact_check</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Chờ nghiệm thu</p>
                <span class="stat-value emerald">@Model.CompletedCount</span>
                <p class="stat-sub">Completed</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon gold">
                <span class="material-symbols-outlined">task_alt</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Đã duyệt</p>
                <span class="stat-value gold">@Model.ApprovedCount</span>
                <p class="stat-sub">Approved</p>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar-container">
        <div class="toolbar-filters">
            <div class="search-input-wrapper">
                <span class="material-symbols-outlined">search</span>
                <input type="text" id="searchInput" placeholder="Tìm theo tiêu đề, mô tả..." />
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">filter_list</span>
                <select id="statusFilter">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Pending">Pending (Chờ làm)</option>
                    <option value="InProgress">In Progress (Đang làm)</option>
                    <option value="Completed">Completed (Chờ nghiệm thu)</option>
                    <option value="Approved">Approved (Đã duyệt)</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">sell</span>
                <select id="categoryFilter">
                    <option value="">Tất cả danh mục</option>
                    <option value="Cleanup">Cleanup (Dọn dẹp)</option>
                    <option value="ServicePrep">ServicePrep (Chuẩn bị dịch vụ)</option>
                    <option value="Repair">Repair (Sửa chữa)</option>
                    <option value="Complaint">Complaint (Khiếu nại)</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">priority_high</span>
                <select id="priorityFilter">
                    <option value="">Tất cả độ ưu tiên</option>
                    <option value="Urgent">Urgent (Khẩn cấp)</option>
                    <option value="High">High (Cao)</option>
                    <option value="Medium">Medium (Trung bình)</option>
                    <option value="Low">Low (Thấp)</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Tasks Table -->
    <div class="table-panel glass-panel">
        <table class="tasks-table">
            <thead>
                <tr>
                    <th>Công việc</th>
                    <th>Danh mục</th>
                    <th>Độ ưu tiên</th>
                    <th>Hạn hoàn thành</th>
                    <th>Trạng thái</th>
                    <th>Nhân viên thực hiện</th>
                    <th>Nghiệm thu</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Tasks == null || Model.Tasks.Items.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            <div class="d-flex flex-column align-items-center gap-2">
                                <span class="material-symbols-outlined fs-2">assignment_late</span>
                                <span>Không tìm thấy công việc nào.</span>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var task in Model.Tasks.Items)
                    {
                        var staff = task.AssignedStaffId.HasValue 
                            ? Model.Staffs.FirstOrDefault(s => s.UserId == task.AssignedStaffId.Value) 
                            : null;
                        var avatarUrl = staff?.AvatarUrl ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuA2F8HPt7wWLUahORbOOsCiz40UDrnOOYBu__26_jVUEjwrjrAgGUyitMx1ElfkLnFw7H_X_C1H5paESWMxHEGj6ERwpj7sd0n1sQ_vCRplNAd5jI_axazv2IdmbHMZikI331-NPoXgcYUOxYbPGzahf0yMXscMGz5i-i5vo2JA-N4UBWneywYeEoeX3_MdHjEla0B6q0OPUkCLvneGc2q3hESdPF-e5C_Qvn9QQV-vmpinkZMntFn9wGtgSBx9Q8TEWRRfuxhjCkA";
                        
                        <tr data-id="@task.TaskId"
                            data-title="@task.Title"
                            data-description="@task.Description"
                            data-category="@task.Category"
                            data-priority="@task.Priority"
                            data-duedate="@task.DueDate.ToString("yyyy-MM-ddTHH:mm")"
                            data-status="@task.Status"
                            data-staff-id="@task.AssignedStaffId"
                            data-staff-name="@(task.AssignedStaffName ?? "")">
                            <td>
                                <div class="task-cell">
                                    <div class="task-icon">
                                        <span class="material-symbols-outlined">assignment</span>
                                    </div>
                                    <div>
                                        <p class="task-title">@task.Title</p>
                                        <p class="task-desc" title="@task.Description">@task.Description</p>
                                    </div>
                                </div>
                            </td>
                            <td><span class="category-badge @task.Category.ToLower()">@task.Category</span></td>
                            <td><span class="priority-badge @task.Priority.ToLower()">@task.Priority</span></td>
                            <td>
                                <p class="due-date">@task.DueDate.ToString("dd/MM/yyyy HH:mm")</p>
                            </td>
                            <td>
                                <span class="status-badge @(task.Status == "InProgress" ? "in-progress" : task.Status.ToLower())">@task.Status</span>
                            </td>
                            <td>
                                @if (task.AssignedStaffId.HasValue)
                                {
                                    <div class="assigned-cell">
                                        <div class="assigned-avatar">
                                            <img alt="@task.AssignedStaffName" src="@avatarUrl" />
                                        </div>
                                        <span class="assigned-name">@task.AssignedStaffName</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size: 13px;">Chưa phân công</span>
                                }
                            </td>
                            <td class="completed-cell">
                                @if (task.CompletedAt.HasValue)
                                {
                                    <p class="completed-time">@task.CompletedAt.Value.ToString("dd/MM HH:mm")</p>
                                }
                                else
                                {
                                    <span>–</span>
                                }
                            </td>
                            <td>
                                <div class="actions-cell">
                                    @if (task.Status == "Completed")
                                    {
                                        <button class="action-icon-btn verify" title="Duyệt / Từ chối">
                                            <span class="material-symbols-outlined">how_to_reg</span>
                                        </button>
                                    }
                                    <button class="action-icon-btn edit" title="Chỉnh sửa">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                    @if (task.Status != "Approved")
                                    {
                                        <button class="action-icon-btn delete" title="Xóa">
                                            <span class="material-symbols-outlined">delete</span>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-panel">
        <p class="pagination-info"></p>
        <div class="pagination-buttons">
            <button class="pagination-btn" disabled>
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="pagination-btn active">1</button>
            <button class="pagination-btn" disabled>
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    </div>

</div>

<!-- Create Task Modal -->
<div class="modal fade" id="createTaskModal" tabindex="-1" aria-labelledby="createTaskLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content tasks-modal-content">
            <form asp-controller="Task" asp-action="CreateTask" method="post" id="createTaskForm">
                <div class="modal-header tasks-modal-header">
                    <h5 class="modal-title" id="createTaskLabel">
                        <span class="material-symbols-outlined">assignment_ind</span>
                        Tạo công việc mới
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="modal-form-grid">
                        <div class="form-group form-group-full">
                            <label class="form-label-custom">Tiêu đề công việc</label>
                            <input type="text" class="form-input-custom" name="Title" id="createTitle" placeholder="Nhập tiêu đề công việc..." required />
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Danh mục</label>
                            <select class="form-input-custom" name="Category" id="createCategory" required>
                                <option value="Cleanup">Cleanup – Dọn dẹp</option>
                                <option value="ServicePrep">ServicePrep – Chuẩn bị dịch vụ</option>
                                <option value="Repair">Repair – Sửa chữa</option>
                                <option value="Complaint">Complaint – Phản hồi khiếu nại</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Độ ưu tiên</label>
                            <select class="form-input-custom" name="Priority" id="createPriority" required>
                                <option value="Urgent">Urgent – Khẩn cấp</option>
                                <option value="High" selected>High – Cao</option>
                                <option value="Medium">Medium – Trung bình</option>
                                <option value="Low">Low – Thấp</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Nhân viên thực hiện</label>
                            <select class="form-input-custom" name="AssignedStaffId" id="createAssignedStaffId">
                                <option value="">-- Chưa phân công --</option>
                                @foreach (var staff in Model.Staffs)
                                {
                                    <option value="@staff.UserId">@staff.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Hạn hoàn thành (Due Date)</label>
                            <input type="datetime-local" class="form-input-custom" name="DueDate" id="createDueDate" required />
                        </div>
                        <div class="form-group form-group-full">
                            <label class="form-label-custom">Mô tả công việc (Description)</label>
                            <textarea class="form-input-custom" name="Description" id="createDescription" rows="3" maxlength="500" placeholder="Mô tả chi tiết công việc cần làm..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer tasks-modal-footer">
                    <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-primary-custom">
                        <span class="material-symbols-outlined">check</span>
                        Tạo công việc
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Task Modal -->
