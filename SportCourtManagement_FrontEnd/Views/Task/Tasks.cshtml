<!-- Create Task Modal -->
<div class="modal fade" id="createTaskModal" tabindex="-1" aria-labelledby="createTaskLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content tasks-modal-content">
            <form asp-controller="Task" asp-action="CreateTask" method="post" id="createTaskForm">
                <div class="modal-header tasks-modal-header">
                    <h5 class="modal-title" id="createTaskLabel">
                        <span class="material-symbols-outlined">assignment_ind</span>
                        Tạo công việc mới
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="modal-form-grid">
                        <div class="form-group form-group-full">
                            <label class="form-label-custom">Tiêu đề công việc</label>
                            <input type="text" class="form-input-custom" name="Title" id="createTitle" placeholder="Nhập tiêu đề công việc..." required />
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Danh mục</label>
                            <select class="form-input-custom" name="Category" id="createCategory" required>
                                <option value="Cleanup">Cleanup – Dọn dẹp</option>
                                <option value="ServicePrep">ServicePrep – Chuẩn bị dịch vụ</option>
                                <option value="Repair">Repair – Sửa chữa</option>
                                <option value="Complaint">Complaint – Phản hồi khiếu nại</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Độ ưu tiên</label>
                            <select class="form-input-custom" name="Priority" id="createPriority" required>
                                <option value="Urgent">Urgent – Khẩn cấp</option>
                                <option value="High" selected>High – Cao</option>
                                <option value="Medium">Medium – Trung bình</option>
                                <option value="Low">Low – Thấp</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Nhân viên thực hiện</label>
                            <select class="form-input-custom" name="AssignedStaffId" id="createAssignedStaffId">
                                <option value="">-- Chưa phân công --</option>
                                <option value="1">Nguyen Van A</option>
                                <option value="2">Tran Thi B</option>
                                <option value="3">Le Van C</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Hạn hoàn thành (Due Date)</label>
                            <input type="datetime-local" class="form-input-custom" name="DueDate" id="createDueDate" required />
                        </div>
                        <div class="form-group form-group-full">
                            <label class="form-label-custom">Mô tả công việc (Description)</label>
                            <textarea class="form-input-custom" name="Description" id="createDescription" rows="3" maxlength="500" placeholder="Mô tả chi tiết công việc cần làm..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer tasks-modal-footer">
                    <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-primary-custom">
                        <span class="material-symbols-outlined">check</span>
                        Tạo công việc
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

