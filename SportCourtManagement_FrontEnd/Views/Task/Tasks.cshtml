
@{
    ViewData["Title"] = "Quản lý công việc | ProCourt";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Manager/tasks.css" asp-append-version="true" />
}

<div class="tasks-container">

    <!-- Module Header -->
    <div class="module-header">
        <div class="module-title">
            <h3>Quản lý công việc</h3>
            <p>Phân công, giám sát và duyệt nghiệm thu các công việc vận hành tại cơ sở.</p>
        </div>
        <div class="header-actions">
            <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                <span class="material-symbols-outlined">add</span>
                Tạo công việc
            </button>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="summary-stats">
        <div class="stat-card glass-panel">
            <div class="stat-icon orange">
                <span class="material-symbols-outlined">assignment_late</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Chờ thực hiện</p>
                <span class="stat-value orange">1</span>
                <p class="stat-sub">Pending</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon sky">
                <span class="material-symbols-outlined">pending</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Đang làm</p>
                <span class="stat-value sky">1</span>
                <p class="stat-sub">In Progress</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon emerald">
                <span class="material-symbols-outlined">fact_check</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Chờ nghiệm thu</p>
                <span class="stat-value emerald">1</span>
                <p class="stat-sub">Completed</p>
            </div>
        </div>
        <div class="stat-card glass-panel">
            <div class="stat-icon gold">
                <span class="material-symbols-outlined">task_alt</span>
            </div>
            <div class="stat-body">
                <p class="stat-label">Đã duyệt</p>
                <span class="stat-value gold">1</span>
                <p class="stat-sub">Approved</p>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar-container">
        <div class="toolbar-filters">
            <div class="search-input-wrapper">
                <span class="material-symbols-outlined">search</span>
                <input type="text" id="searchInput" placeholder="Tìm theo tiêu đề, mô tả..." />
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">filter_list</span>
                <select id="statusFilter">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Pending">Pending (Chờ làm)</option>
                    <option value="InProgress">In Progress (Đang làm)</option>
                    <option value="Completed">Completed (Chờ nghiệm thu)</option>
                    <option value="Approved">Approved (Đã duyệt)</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">sell</span>
                <select id="categoryFilter">
                    <option value="">Tất cả danh mục</option>
                    <option value="Cleanup">Cleanup (Dọn dẹp)</option>
                    <option value="ServicePrep">ServicePrep (Chuẩn bị dịch vụ)</option>
                    <option value="Repair">Repair (Sửa chữa)</option>
                    <option value="Complaint">Complaint (Khiếu nại)</option>
                </select>
            </div>
            <div class="filter-box">
                <span class="material-symbols-outlined">priority_high</span>
                <select id="priorityFilter">
                    <option value="">Tất cả độ ưu tiên</option>
                    <option value="Urgent">Urgent (Khẩn cấp)</option>
                    <option value="High">High (Cao)</option>
                    <option value="Medium">Medium (Trung bình)</option>
                    <option value="Low">Low (Thấp)</option>
                </select>
            </div>
        </div>
    </div>

