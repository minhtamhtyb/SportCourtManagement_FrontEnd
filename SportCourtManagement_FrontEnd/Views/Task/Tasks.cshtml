<!-- Verify Task Modal -->
<div class="modal fade" id="verifyTaskModal" tabindex="-1" aria-labelledby="verifyTaskLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content tasks-modal-content">
            <form asp-controller="Task" asp-action="VerifyTask" method="post" id="verifyTaskForm">
                <input type="hidden" name="TaskId" id="verifyTaskId" />
                <div class="modal-header tasks-modal-header">
                    <h5 class="modal-title" id="verifyTaskLabel">
                        <span class="material-symbols-outlined">how_to_reg</span>
                        Duyệt nghiệm thu công việc
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div style="display: flex; flex-direction: column; gap: 15px;">
                        <div class="form-group">
                            <label class="form-label-custom">Quyết định nghiệm thu</label>
                            <div style="display: flex; gap: 20px; margin-top: 6px;">
                                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; color: var(--on-surface);">
                                    <input type="radio" name="IsApproved" value="true" checked style="accent-color: var(--primary);" />
                                    <span class="material-symbols-outlined" style="color: var(--emerald-400); font-size: 18px;">check_circle</span>
                                    Duyệt nghiệm thu (Approved)
                                </label>
                                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; color: var(--on-surface);">
                                    <input type="radio" name="IsApproved" value="false" style="accent-color: var(--primary);" />
                                    <span class="material-symbols-outlined" style="color: var(--rose-400); font-size: 18px;">cancel</span>
                                    Từ chối (Cần sửa lại)
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label-custom">Ghi chú nghiệm thu / Lý do từ chối (Note)</label>
                            <textarea class="form-input-custom" name="Note" id="verifyNote" rows="3" maxlength="500" placeholder="Nhập ghi chú chi tiết kết quả nghiệm thu..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer tasks-modal-footer">
                    <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-primary-custom">
                        <span class="material-symbols-outlined">send</span>
                        Gửi kết quả
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Task Modal -->
<div class="modal fade" id="deleteTaskModal" tabindex="-1" aria-labelledby="deleteTaskLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content tasks-modal-content">
            <form asp-controller="Task" asp-action="DeleteTask" method="post" id="deleteTaskForm">
                <div class="modal-header tasks-modal-header" style="border-bottom: none; padding-bottom: 0;">
                    <h5 class="modal-title" id="deleteTaskLabel" style="color: var(--rose-400);">
                        <span class="material-symbols-outlined" style="color: var(--rose-400);">warning</span>
                        Xác nhận xoá công việc
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding-top: 10px;">
                    <p>Bạn có chắc chắn muốn xoá công việc <strong id="deleteTaskTitleDisplay"></strong>?</p>
                    <input type="hidden" id="deleteTaskId" name="TaskId" />
                </div>
                <div class="modal-footer tasks-modal-footer" style="border-top: none; padding-top: 0;">
                    <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-primary-custom" style="background-color: var(--rose-500); color: white;">
                        <span class="material-symbols-outlined">delete</span>
                        Xoá
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toast Helper
        function showToast(message, type = 'success') {
            document.querySelectorAll('.toast-notification').forEach(t => t.remove());
            const toast = document.createElement('div');
            toast.className = `toast-notification ${type}`;
            const icon = type === 'error' ? 'error' : (type === 'info' ? 'info' : 'check_circle');
            toast.innerHTML = `<span class="material-symbols-outlined">${icon}</span><div>${message}</div>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <text>showToast('@Html.Raw(TempData["SuccessMessage"])', 'success');</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>showToast('@Html.Raw(TempData["ErrorMessage"])', 'error');</text>
        }

        // Search & Filter Logic
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const categoryFilter = document.getElementById('categoryFilter');
        const priorityFilter = document.getElementById('priorityFilter');
        const tableRows = document.querySelectorAll('.tasks-table tbody tr');

        function filterTable() {
            const query = searchInput.value.toLowerCase().trim();
            const status = statusFilter.value;
            const category = categoryFilter.value;
            const priority = priorityFilter.value;

            tableRows.forEach(row => {
                if (row.cells.length === 1 && row.cells[0].colSpan > 1) return; // Skip empty row

                const title = row.dataset.title ? row.dataset.title.toLowerCase() : '';
                const desc = row.dataset.description ? row.dataset.description.toLowerCase() : '';
                const rowStatus = row.dataset.status || '';
                const rowCategory = row.dataset.category || '';
                const rowPriority = row.dataset.priority || '';

                const matchesSearch = title.includes(query) || desc.includes(query);
                const matchesStatus = !status || rowStatus === status;
                const matchesCategory = !category || rowCategory === category;
                const matchesPriority = !priority || rowPriority === priority;

                if (matchesSearch && matchesStatus && matchesCategory && matchesPriority) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
            updatePaginationInfo();
        }

        searchInput.addEventListener('input', filterTable);
        statusFilter.addEventListener('change', filterTable);
        categoryFilter.addEventListener('change', filterTable);
        priorityFilter.addEventListener('change', filterTable);

        function updatePaginationInfo() {
            const activeRows = document.querySelectorAll('.tasks-table tbody tr:not([style*="display: none"])');
            const totalRows = document.querySelectorAll('.tasks-table tbody tr');

            const isNoData = totalRows.length === 1 && totalRows[0].cells[0].colSpan > 1;
            const activeCount = isNoData ? 0 : activeRows.length;
            const totalCount = isNoData ? 0 : totalRows.length;

            document.querySelector('.pagination-info').textContent = `Hiển thị 1 - ${activeCount} của ${totalCount} công việc`;
        }

        updatePaginationInfo();

        // Event Delegation for row actions
        document.querySelector('.tasks-table tbody').addEventListener('click', function(e) {
            const btnEdit = e.target.closest('.action-icon-btn.edit');
            const btnVerify = e.target.closest('.action-icon-btn.verify');
            const btnDelete = e.target.closest('.action-icon-btn.delete');
            const row = e.target.closest('tr');

            if (!row || (row.cells.length === 1 && row.cells[0].colSpan > 1)) return;

            if (btnEdit) {
                document.getElementById('editTaskId').value = row.dataset.id;
                document.getElementById('editTitle').value = row.dataset.title;
                document.getElementById('editCategory').value = row.dataset.category;
                document.getElementById('editPriority').value = row.dataset.priority;
                document.getElementById('editDueDate').value = row.dataset.duedate;
                document.getElementById('editAssignedStaffId').value = row.dataset.staffId || '';
                document.getElementById('editDescription').value = row.dataset.description;

                const editModal = new bootstrap.Modal(document.getElementById('editTaskModal'));
                editModal.show();
            }

            if (btnVerify) {
                document.getElementById('verifyTaskId').value = row.dataset.id;
                document.getElementById('verifyNote').value = '';
                document.querySelector('input[name="IsApproved"][value="true"]').checked = true;

                const verifyModal = new bootstrap.Modal(document.getElementById('verifyTaskModal'));
                verifyModal.show();
            }

            if (btnDelete) {
                document.getElementById('deleteTaskId').value = row.dataset.id;
                document.getElementById('deleteTaskTitleDisplay').textContent = row.dataset.title;

                const deleteModal = new bootstrap.Modal(document.getElementById('deleteTaskModal'));
                deleteModal.show();
            }
        });
    </script>
}
