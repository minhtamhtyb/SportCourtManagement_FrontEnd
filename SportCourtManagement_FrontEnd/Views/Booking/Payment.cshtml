@model List<SportCourtManagement_FrontEnd.Models.Bookings.SingularBookingResponseDto>

@{
    var firstBooking = Model.FirstOrDefault() ?? new SportCourtManagement_FrontEnd.Models.Bookings.SingularBookingResponseDto();
    ViewData["Title"] = "Thanh toán đơn hàng";
    var qrCode = ViewBag.QrCode as SportCourtManagement_FrontEnd.Models.Bookings.SePayQrCodeDto;
    var totalAmount = ViewBag.TotalAmount as decimal? ?? Model.Sum(b => b.TotalAmount);
    var bookingCodesStr = ViewBag.BookingCodes as string ?? string.Join(",", Model.Select(b => b.BookingCode));
}

<main class="sc-container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="sc-card p-0" style="background-color: #0D121F; border: 1px solid rgba(79, 110, 247, 0.2); box-shadow: 0 8px 32px rgba(0,0,0,0.4); overflow: hidden;">

                <!-- Header Gradient Banner -->
                <div class="text-center py-4 px-4" style="background: linear-gradient(135deg, rgba(79, 110, 247, 0.15) 0%, rgba(16, 185, 129, 0.08) 100%); border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: rgba(245, 158, 11, 0.1); border: 2px solid rgba(245, 158, 11, 0.3);">
                        <i class="bi bi-wallet2 text-warning" style="font-size: 28px;"></i>
                    </div>
                    <h3 class="text-white font-outfit fw-bold mb-1">Thanh Toán Đặt Sân</h3>
                    <p class="text-sc-muted mb-0 small">Quét mã QR dưới đây để hoàn tất thanh toán cho các đơn đặt sân</p>
                </div>

                <div class="p-4">
                    <!-- Booking Code Badges -->
                    <div class="text-center mb-4 d-flex flex-wrap justify-content-center gap-2">
                        @foreach (var booking in Model)
                        {
                            <span class="d-inline-flex align-items-center gap-1 px-3 py-2 rounded-pill" style="background: rgba(79, 110, 247, 0.1); border: 1px solid rgba(79, 110, 247, 0.3); font-size: 12px;">
                                <i class="bi bi-hash text-sc-blue-light"></i>
                                <span class="text-white fw-bold font-monospace">@booking.BookingCode</span>
                            </span>
                        }
                    </div>

                    <!-- Bookings Details List -->
                    <div class="p-3 rounded mb-4" style="background-color: #141B2D; border: 1px solid var(--sc-border); font-size: 13.5px;">
                        <h6 class="text-white font-outfit mb-3" style="font-weight: 700;">
                            <i class="bi bi-receipt me-1 text-sc-blue-light"></i> Chi tiết đơn hàng (@Model.Count)
                        </h6>

                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var booking = Model[i];
                            <div class="mb-3 @(i > 0 ? "pt-3 border-top" : "")" style="@(i > 0 ? "border-top-color: rgba(255, 255, 255, 0.05) !important;" : "")">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-sc-blue-light fw-bold">#@booking.BookingCode</span>
                                    <span class="text-sc-green fw-bold">@booking.TotalAmount.ToString("N0")đ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1" style="font-size: 12.5px;">
                                    <span class="text-sc-muted">Sân đấu:</span>
                                    <span class="text-white">@booking.CourtName</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1" style="font-size: 12.5px;">
                                    <span class="text-sc-muted">Ngày:</span>
                                    <span class="text-white">@booking.BookingDate.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1" style="font-size: 12.5px;">
                                    <span class="text-sc-muted">Khung giờ:</span>
                                    <span class="text-white">@booking.SlotName (@booking.StartTime.ToString(@"hh\:mm") - @booking.EndTime.ToString(@"hh\:mm"))</span>
                                </div>

                                @if (booking.BookingServices.Any())
                                {
                                    <div class="mt-1 ps-2 border-start" style="border-start-color: rgba(255,255,255,0.1) !important; font-size: 12px;">
                                        <span class="text-sc-muted">Dịch vụ phụ trợ:</span>
                                        @foreach (var svc in booking.BookingServices)
                                        {
                                            <div class="d-flex justify-content-between text-sc-muted">
                                                <span>• @svc.ServiceName x@svc.Quantity</span>
                                                <span>@svc.TotalPrice.ToString("N0")đ</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        <hr style="border-color: rgba(255,255,255,0.05); margin: 12px 0;" />
                        <div class="d-flex justify-content-between align-items-baseline mt-3 pt-2">
                            <span class="text-white fw-bold" style="font-size: 15px;">Tổng cộng:</span>
                            <span class="font-outfit text-sc-green fw-black" style="font-size: 26px; font-weight: 900;">@totalAmount.ToString("N0")đ</span>
                        </div>
                    </div>

                    <!-- QR Code Section -->
                    @if (qrCode != null)
                    {
                        <div class="text-center mb-4">
                            <h6 class="text-white font-outfit mb-3" style="font-weight: 700;">
                                <i class="bi bi-qr-code me-1 text-sc-blue-light"></i> Quét mã QR để thanh toán (Đơn đầu tiên)
                            </h6>
                            <div class="d-inline-block p-3 rounded-3 mb-3" style="background: #ffffff; border-radius: 16px !important;">
                                <img src="@qrCode.QrCodeUrl" alt="QR Code thanh toán" style="width: 220px; height: 220px;" />
                            </div>
                            <div class="text-sc-muted" style="font-size: 12px; line-height: 1.6;">
                                <div><strong class="text-white">Ngân hàng:</strong> @qrCode.BankBin</div>
                                <div><strong class="text-white">STK:</strong> <span class="font-monospace">@qrCode.AccountNumber</span></div>
                                <div><strong class="text-white">Chủ TK:</strong> @qrCode.AccountName</div>
                                <div><strong class="text-white">Nội dung CK:</strong> <span class="text-sc-amber font-monospace fw-bold">@qrCode.BookingCode</span></div>
                            </div>
                            <div class="small text-sc-amber mt-2" style="font-size: 11px;">
                                <i class="bi bi-exclamation-circle-fill"></i> SePay sẽ quét giao dịch chuyển khoản với nội dung là mã đặt sân để tự động kích hoạt.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mb-4 p-4 rounded-3" style="background: rgba(245, 158, 11, 0.05); border: 1px solid rgba(245, 158, 11, 0.15);">
                            <i class="bi bi-exclamation-triangle text-warning" style="font-size: 32px;"></i>
                            <p class="text-sc-muted mt-2 mb-0" style="font-size: 13px;">Không thể tạo mã QR thanh toán. Vui lòng sử dụng nút mô phỏng bên dưới.</p>
                        </div>
                    }

                    <!-- Timer Warning -->
                    <div class="alert d-flex align-items-center gap-2 py-3 px-4 rounded-3 mb-4" style="background: rgba(239, 68, 68, 0.06); border: 1px solid rgba(239, 68, 68, 0.15); color: #FCA5A5; font-size: 13px;">
                        <i class="bi bi-clock-history" style="font-size: 18px;"></i>
                        <div>
                            <strong>Lưu ý:</strong> Đơn đặt sân sẽ tự động hủy sau <strong>5 phút</strong> nếu không được thanh toán.
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex flex-column gap-3">

                        <a asp-controller="Booking" asp-action="Index" class="sc-btn sc-btn-secondary w-100 py-3 font-outfit text-center d-block text-decoration-none" style="font-size: 14px; border-radius: 12px;">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại đặt sân
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <style>
        .sc-card:hover {
            transform: none !important;
        }
    </style>

    <script>
        $(document).ready(function () {
            var bookingCodes = '@bookingCodesStr';
            if (bookingCodes) {
                // Gửi request kiểm tra mỗi 3 giây
                var checkInterval = setInterval(function () {
                    $.ajax({
                        url: '/Booking/CheckStatus',
                        type: 'GET',
                        data: { bookingCodes: bookingCodes },
                        success: function (response) {
                            if (response.success && response.allPaid) {
                                clearInterval(checkInterval);
                                // Chuyển hướng sang trang đặt sân thành công
                                window.location.href = '/Booking/Success?bookingCodes=' + encodeURIComponent(bookingCodes);
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error("Lỗi kiểm tra trạng thái:", error);
                        }
                    });
                }, 3000); // 3 giây
            }
        });
    </script>
}
