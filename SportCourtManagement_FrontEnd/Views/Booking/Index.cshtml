@model SportCourtManagement_FrontEnd.Models.ViewModels.SingularBookingViewModel

@{
    ViewData["Title"] = "Đặt Sân Thể Thao";
}

<main class="sc-container py-4">
    <!-- Breadcrumb -->
    <nav class="sc-breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <a asp-controller="Courts" asp-action="Index">Tìm sân</a>
        <span>›</span>
        <span class="text-white fw-medium">Đặt sân</span>
    </nav>

    <!-- Page Title -->
    <div class="mb-5">
        <h2 class="font-outfit text-white mb-2" style="font-weight: 900; letter-spacing: -0.5px;">
            <i class="bi bi-calendar-check me-2" style="color: var(--sc-blue-light);"></i>Đặt Sân Thể Thao
        </h2>
        <p class="text-sc-muted mb-0" style="font-size: 14px;">Chọn sân, khung giờ và dịch vụ phụ trợ để hoàn tất đơn đặt sân của bạn.</p>
    </div>

    <!-- Error / Success Messages -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert d-flex align-items-center gap-2 mb-4 py-3 px-4 rounded-3" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); color: #FCA5A5;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

        <div class="row g-4">
            <!-- LEFT COLUMN: Form -->
            <div class="col-lg-8">
                <!-- Nav Tabs for Single vs Recurring Booking -->
                <ul class="nav nav-pills mb-4 gap-2" id="booking-type-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active px-4 py-2 text-white fw-bold rounded-3" id="tab-single-btn" data-bs-toggle="pill" data-bs-target="#tab-single" type="button" role="tab" style="background-color: var(--sc-blue);">
                            <i class="bi bi-calendar-event me-2"></i>Đặt Sân Đơn Lẻ
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4 py-2 text-white fw-bold rounded-3" id="tab-recurring-btn" data-bs-toggle="pill" data-bs-target="#tab-recurring" type="button" role="tab" style="background-color: rgba(255,255,255,0.05); border: 1px solid var(--sc-border);">
                            <i class="bi bi-arrow-repeat me-2 text-sc-amber"></i>Đặt Sân Định Kỳ (Theo Tuần)
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="booking-tab-content">
                    <!-- TAB 1: SINGLE BOOKING (SINGLE SLOT) -->
                    <div class="tab-pane fade show active" id="tab-single" role="tabpanel">
                        <form id="booking-form" asp-controller="Booking" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <div class="sc-card p-4" style="background-color: #0D121F;">
                    <h4 class="font-outfit text-white mb-4" style="font-weight: 800; border-left: 4px solid var(--sc-blue); padding-left: 12px;">
                        Thiết Lập Đơn Đặt Sân Lẻ
                    </h4>

                    <!-- Court Selection -->
                    <div class="mb-4">
                        <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-building me-1 text-sc-blue-light"></i>Chọn sân thể thao <span class="text-danger">*</span>
                        </label>
                        <select name="courtId" id="court-select" class="sc-input" required style="color-scheme: dark;">
                            <option value="">-- Chọn sân --</option>
                            @foreach (var court in Model.Courts)
                            {
                                if (Model.SelectedCourtId.HasValue && Model.SelectedCourtId.Value == court.CourtId)
                                {
                                    <option value="@court.CourtId" selected="selected"
                                            data-name="@court.CourtName"
                                            data-type="@court.CourtTypeName"
                                            data-location="@court.Location"
                                            data-image="@court.ImageUrl"
                                            data-price="@court.PricePerHour">
                                        @court.CourtName — @court.CourtTypeName (@(court.Location ?? "N/A"))
                                    </option>
                                }
                                else
                                {
                                    <option value="@court.CourtId"
                                            data-name="@court.CourtName"
                                            data-type="@court.CourtTypeName"
                                            data-location="@court.Location"
                                            data-image="@court.ImageUrl"
                                            data-price="@court.PricePerHour">
                                        @court.CourtName — @court.CourtTypeName (@(court.Location ?? "N/A"))
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Court Preview Card (shown when court is selected) -->
                    <div id="court-preview" class="d-none mb-4">
                        <div class="d-flex align-items-center gap-3 p-3 rounded" style="background-color: rgba(255, 255, 255, 0.02); border: 1px solid var(--sc-border);">
                            <div style="width: 80px; height: 60px; border-radius: 8px; overflow: hidden; flex-shrink: 0; background: #1e293b;">
                                <img id="court-preview-img" src="" alt="" class="w-100 h-100 object-fit-cover" style="display:none;" />
                                <div id="court-preview-noimg" class="w-100 h-100 d-flex align-items-center justify-content-center text-sc-muted" style="font-size: 20px;">
                                    <i class="bi bi-dribbble"></i>
                                </div>
                            </div>
                            <div>
                                <h6 id="court-preview-name" class="text-white font-outfit mb-0" style="font-weight: 700; font-size: 15px;"></h6>
                                <small id="court-preview-meta" class="text-sc-muted" style="font-size: 12px;"></small>
                            </div>
                        </div>
                    </div>

                    <!-- Date Selection -->
                    <div class="mb-4">
                        <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-calendar3 me-1 text-sc-blue-light"></i>Ngày đặt sân <span class="text-danger">*</span>
                        </label>
                        <input type="date" name="bookingDate" id="booking-date" class="sc-input" required
                               value="@(Model.SelectedDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               style="color-scheme: dark; max-width: 300px;" />
                    </div>

                    <!-- Timeline Slot Selection -->
                    <div class="mb-4">
                        <label class="form-label text-sc-muted font-inter d-block" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-clock me-1 text-sc-green"></i>Chọn khung giờ <span class="text-danger">*</span>
                        </label>

                        <!-- Instructions -->
                        <div class="mb-3 d-flex flex-wrap align-items-center gap-3" style="font-size: 12px;">
                            <span class="d-inline-flex align-items-center gap-1 text-sc-muted">
                                <span style="width: 12px; height: 12px; border-radius: 3px; background: linear-gradient(135deg, #10B981, #059669); display: inline-block;"></span> Trống
                            </span>
                            <span class="d-inline-flex align-items-center gap-1 text-sc-muted">
                                <span style="width: 12px; height: 12px; border-radius: 3px; background: #1a1a2e; border: 1px solid #333; display: inline-block;"></span> Đã đặt
                            </span>
                            <span class="d-inline-flex align-items-center gap-1 text-sc-muted">
                                <span style="width: 12px; height: 12px; border-radius: 3px; background: linear-gradient(135deg, #F59E0B, #D97706); display: inline-block;"></span> Bảo trì
                            </span>
                            <span class="d-inline-flex align-items-center gap-1 text-sc-muted">
                                <span style="width: 12px; height: 12px; border-radius: 3px; background: linear-gradient(135deg, #3B82F6, #2563EB); display: inline-block;"></span> Đã chọn
                            </span>
                            <span class="ms-auto text-sc-muted fst-italic" style="font-size: 11px;">
                                <i class="bi bi-info-circle me-1"></i>Bấm chọn slot bắt đầu, sau đó bấm slot kết thúc
                            </span>
                        </div>

                        <!-- Timeline Container -->
                        <div id="slot-timeline-container">
                            <!-- Placeholder when no court/date selected -->
                            <div id="slot-timeline-placeholder" class="text-center py-4 rounded-3" style="background: rgba(255,255,255,0.01); border: 1px dashed rgba(255,255,255,0.1);">
                                <i class="bi bi-calendar2-event text-sc-muted" style="font-size: 28px;"></i>
                                <p class="text-sc-muted mt-2 mb-0" style="font-size: 13px;">Vui lòng chọn sân và ngày để xem khung giờ trống.</p>
                            </div>

                            <!-- Loading spinner -->
                            <div id="slot-timeline-loading" class="text-center py-4" style="display: none;">
                                <div class="spinner-border spinner-border-sm text-sc-blue-light" role="status"></div>
                                <span class="text-sc-muted ms-2" style="font-size: 13px;">Đang tải khung giờ...</span>
                            </div>

                            <!-- Timeline bar (dynamically rendered) -->
                            <div id="slot-timeline" style="display: none;"></div>
                        </div>

                        <!-- Hidden inputs for selected slot IDs (dynamically managed by JS) -->
                        <div id="slot-hidden-inputs"></div>

                        <!-- Selection info -->
                        <div id="slot-selection-info" class="mt-2" style="display: none;">
                            <div class="d-flex align-items-center gap-2 p-2 px-3 rounded-2" style="background: rgba(59, 130, 246, 0.08); border: 1px solid rgba(59, 130, 246, 0.2); font-size: 13px;">
                                <i class="bi bi-check2-circle text-sc-blue-light"></i>
                                <span class="text-white">Đã chọn: <strong id="slot-selection-text"></strong></span>
                                <button type="button" id="btn-clear-slots" class="btn btn-sm ms-auto py-0 px-2" style="font-size: 11px; color: #FCA5A5; border: 1px solid rgba(239,68,68,0.3); border-radius: 4px;">
                                    <i class="bi bi-x-lg me-1"></i>Xoá
                                </button>
                            </div>
                        </div>

                        <div id="slot-error" class="text-danger small mt-1" style="display:none;">Vui lòng chọn ít nhất một khung giờ.</div>
                        <div id="slot-booked-warning" class="mt-2" style="display: none;">
                            <div class="d-flex align-items-center gap-2 p-2 px-3 rounded-2" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); font-size: 12px; color: #FCA5A5;">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span>Không thể chọn vùng giờ này vì có slot đã được đặt hoặc đang bảo trì ở giữa.</span>
                            </div>
                        </div>
                    </div>

                    <!-- Dynamic Services Add-ons -->
                    <div class="mb-4">
                        <h5 class="font-outfit text-white mb-3" style="font-weight: 700; font-size: 16px;">
                            <i class="bi bi-box-seam me-1 text-sc-blue-light"></i> Dịch vụ phụ trợ (Tùy chọn)
                        </h5>
                        <div id="services-container">
                            @if (Model.Services.Any())
                            {
                                <div class="row g-3">
                                    @foreach (var service in Model.Services)
                                    {
                                        <div class="col-sm-6">
                                            <div class="p-3 rounded d-flex align-items-center justify-content-between" style="background-color: rgba(255, 255, 255, 0.01); border: 1px solid var(--sc-border);">
                                                <div>
                                                    <div class="text-white fw-bold" style="font-size: 14px;">@service.ServiceName</div>
                                                    <div class="text-sc-green fw-medium" style="font-size: 12px;">@service.Price.ToString("N0")đ / @(service.Unit ?? "đơn vị")</div>
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace service-qty-btn" data-sid="@service.ServiceId" data-delta="-1">-</button>
                                                    <input type="number" name="serviceQuantities[@service.ServiceId]" id="svc-@service.ServiceId"
                                                           value="0" min="0" max="@(service.StockQty > 0 ? Math.Min(service.StockQty, 20) : 20)"
                                                           data-price="@service.Price"
                                                           class="text-center bg-transparent border-0 text-white font-monospace service-qty-input"
                                                           style="width: 40px; font-size: 14px;" readonly />
                                                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace service-qty-btn" data-sid="@service.ServiceId" data-delta="1">+</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="p-3 text-center rounded text-sc-muted" style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--sc-border); font-size: 13px;">
                                    <i class="bi bi-box-seam me-2 text-sc-amber"></i>Chưa có dịch vụ đi kèm
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Promo Code -->
                    <div class="mb-4">
                        <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                            <i class="bi bi-tag me-1 text-sc-amber"></i>Mã giảm giá (Nếu có)
                        </label>
                        <div class="d-flex gap-2">
                            <input type="text" name="promoCode" id="promo-input" class="sc-input" placeholder="Nhập mã ưu đãi (Ví dụ: DISCOUNT10)" style="max-width: 320px;" />
                            <button type="button" id="btn-apply-promo" class="sc-btn sc-btn-secondary py-2 px-3" style="font-size: 13px;">Áp dụng</button>
                        </div>
                        <div id="promo-msg" class="form-text small mt-1" style="display:none;"></div>
                    </div>

                    <!-- Submit Button -->
                    <div class="mt-4 pt-3 border-top" style="border-top-color: rgba(255,255,255,0.05) !important;">
                        <button type="submit" id="btn-submit" class="sc-btn sc-btn-primary px-5 py-3 d-flex align-items-center gap-2 fw-bold" style="font-size: 15px; background: linear-gradient(135deg, #10B981 0%, #059669 100%); border: none;">
                            <i class="bi bi-check-circle-fill"></i> Xác nhận đặt sân lẻ
                        </button>
                    </div>
                </div>
            </form>
        </div> <!-- END TAB 1 -->

                <!-- TAB 2: RECURRING BOOKING (ĐẶT ĐỊNH KỲ) -->
                <div class="tab-pane fade" id="tab-recurring" role="tabpanel">
                    <form id="recurring-booking-form" asp-controller="Booking" asp-action="CreateRecurring" method="post">
                        @Html.AntiForgeryToken()
                        <div class="sc-card p-4" style="background-color: #0D121F;">
                            <h4 class="font-outfit text-white mb-4" style="font-weight: 800; border-left: 4px solid var(--sc-amber); padding-left: 12px;">
                                Thiết Lập Đặt Sân Định Kỳ (Theo Tuần)
                            </h4>

                            <!-- Court Selection -->
                            <div class="mb-4">
                                <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                                    <i class="bi bi-building me-1 text-sc-blue-light"></i>Chọn sân thể thao <span class="text-danger">*</span>
                                </label>
                                <select name="courtId" id="rec-court-select" class="sc-input" required style="color-scheme: dark;">
                                    <option value="">-- Chọn sân --</option>
                                    @foreach (var court in Model.Courts)
                                    {
                                        if (Model.SelectedCourtId.HasValue && Model.SelectedCourtId.Value == court.CourtId)
                                        {
                                            <option value="@court.CourtId" selected="selected" data-price="@court.PricePerHour">@court.CourtName — @court.CourtTypeName</option>
                                        }
                                        else
                                        {
                                            <option value="@court.CourtId" data-price="@court.PricePerHour">@court.CourtName — @court.CourtTypeName</option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- Time Slot Selection for Recurring Booking -->
                            <div class="mb-4">
                                <label class="form-label text-sc-muted font-inter d-block" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                                    <i class="bi bi-clock me-1 text-sc-amber"></i>Chọn các khung giờ định kỳ <span class="text-danger">*</span>
                                </label>
                                <div class="mb-2 text-sc-muted small">
                                    <i class="bi bi-info-circle me-1"></i>Bấm chọn slot bắt đầu, sau đó bấm chọn slot kết thúc để chọn dải khung giờ.
                                </div>

                                <div id="rec-slot-timeline-container">
                                    <div id="rec-slot-timeline-placeholder" class="text-center py-3 rounded-3" style="background: rgba(255,255,255,0.01); border: 1px dashed rgba(255,255,255,0.1);">
                                        <i class="bi bi-calendar2-event text-sc-muted" style="font-size: 24px;"></i>
                                        <p class="text-sc-muted mt-1 mb-0" style="font-size: 12px;">Vui lòng chọn sân để hiển thị danh sách khung giờ.</p>
                                    </div>
                                    <div id="rec-slot-timeline-loading" class="text-center py-3" style="display: none;">
                                        <div class="spinner-border spinner-border-sm text-sc-amber" role="status"></div>
                                        <span class="text-sc-muted ms-2" style="font-size: 13px;">Đang tải khung giờ...</span>
                                    </div>
                                    <div id="rec-slot-timeline" style="display: none;"></div>
                                </div>

                                <div id="rec-slot-hidden-inputs"></div>

                                <div id="rec-slot-selection-info" class="mt-2" style="display: none;">
                                    <div class="d-flex align-items-center gap-2 p-2 px-3 rounded-2" style="background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2); font-size: 13px;">
                                        <i class="bi bi-check2-circle text-sc-amber"></i>
                                        <span class="text-white">Đã chọn: <strong id="rec-slot-selection-text"></strong></span>
                                        <button type="button" id="btn-rec-clear-slots" class="btn btn-sm ms-auto py-0 px-2" style="font-size: 11px; color: #FCA5A5; border: 1px solid rgba(239,68,68,0.3); border-radius: 4px;">
                                            <i class="bi bi-x-lg me-1"></i>Xoá
                                        </button>
                                    </div>
                                </div>
                                <div id="rec-slot-error" class="text-danger small mt-1" style="display:none;">Vui lòng chọn ít nhất một khung giờ định kỳ.</div>
                            </div>

                            <!-- Start Date & End Date -->
                            <div class="row g-3 mb-4">
                                <div class="col-sm-6">
                                    <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                                        <i class="bi bi-calendar-event me-1 text-sc-blue-light"></i>Ngày bắt đầu <span class="text-danger">*</span>
                                    </label>
                                    <input type="date" name="startDate" id="rec-start-date" class="sc-input" required
                                           value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" style="color-scheme: dark;" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                                        <i class="bi bi-calendar-check me-1 text-sc-amber"></i>Ngày kết thúc <span class="text-danger">*</span>
                                    </label>
                                    <input type="date" name="endDate" id="rec-end-date" class="sc-input" required
                                           value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" min="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")" style="color-scheme: dark;" />
                                </div>
                            </div>

                            <!-- Days of Week checkboxes -->
                            <div class="mb-4">
                                <label class="form-label text-sc-muted font-inter d-block" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                                    <i class="bi bi-calendar-week me-1 text-sc-green"></i>Chọn các ngày cố định trong tuần <span class="text-danger">*</span>
                                </label>
                                <div class="d-flex flex-wrap gap-2">
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="1" id="day-t2" checked>
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-t2">Thứ 2</label>
                                    </div>
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="2" id="day-t3">
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-t3">Thứ 3</label>
                                    </div>
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="3" id="day-t4" checked>
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-t4">Thứ 4</label>
                                    </div>
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="4" id="day-t5">
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-t5">Thứ 5</label>
                                    </div>
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="5" id="day-t6" checked>
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-t6">Thứ 6</label>
                                    </div>
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="6" id="day-t7">
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-t7">Thứ 7</label>
                                    </div>
                                    <div class="form-check form-check-inline bg-dark p-2 px-3 rounded" style="border: 1px solid var(--sc-border);">
                                        <input class="form-check-input" type="checkbox" name="daysOfWeek" value="0" id="day-cn">
                                        <label class="form-check-label text-white fw-bold ms-1" for="day-cn">Chủ Nhật</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Note -->
                            <div class="mb-4">
                                <label class="form-label text-sc-muted font-inter" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">
                                    <i class="bi bi-chat-left-text me-1"></i>Ghi chú cho ban quản lý
                                </label>
                                <input type="text" name="note" class="sc-input" placeholder="Ghi chú yêu cầu bổ sung nếu có" />
                            </div>

                            <button type="submit" class="sc-btn sc-btn-primary px-5 py-3 fw-bold w-100" style="background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); border: none;">
                                <i class="bi bi-arrow-repeat me-2"></i>Đăng Ký Đặt Sân Định Kỳ
                            </button>
                        </div>
                    </form>
                </div> <!-- END TAB 2 -->
                </div> <!-- END TAB CONTENT -->
            </div>

            <!-- RIGHT COLUMN: Order Summary -->
            <div class="col-lg-4">
                <div class="sc-booking-sidebar" style="position: sticky; top: 100px;">
                    <div class="sc-card p-4" style="background-color: #0D121F;">
                        <h5 class="font-outfit text-white mb-3 pb-2 border-bottom" style="font-weight: 700; border-bottom-color: rgba(255,255,255,0.05) !important;">
                            <i class="bi bi-receipt me-1 text-sc-blue-light"></i> Tóm Tắt Đơn Đặt Sân
                        </h5>

                        <!-- Dynamic Court Info -->
                        <div id="summary-court-section" class="mb-3" style="display: none;">
                            <div class="d-flex justify-content-between mb-1" style="font-size: 13px;">
                                <span class="text-sc-muted">Sân:</span>
                                <span id="summary-court" class="text-white fw-semibold">—</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 13px;">
                                <span class="text-sc-muted">Ngày:</span>
                                <span id="summary-date" class="text-white fw-semibold">—</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 13px;">
                                <span class="text-sc-muted">Khung giờ:</span>
                                <span id="summary-slot" class="text-white fw-semibold text-end" style="max-width: 60%;">—</span>
                            </div>
                        </div>

                        <hr style="border-color: rgba(255,255,255,0.05);" />

                        <!-- Price breakdown -->
                        <div class="mb-4" style="font-size: 13.5px; line-height: 1.8;">
                            <div class="d-flex justify-content-between">
                                <span class="text-sc-muted">Tiền sân (ước tính):</span>
                                <span id="summary-court-price" class="text-white fw-semibold">—</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-sc-muted">Tiền dịch vụ thêm:</span>
                                <span id="summary-service-price" class="text-white fw-semibold">0đ</span>
                            </div>
                            <div class="d-flex justify-content-between text-sc-amber" id="summary-promo-row" style="display: none;">
                                <span>Mã giảm giá:</span>
                                <span id="summary-promo-code">—</span>
                            </div>
                            <hr style="border-color: rgba(255,255,255,0.05);" />
                            <div class="d-flex justify-content-between align-items-baseline">
                                <span class="text-white fw-bold">Tạm tính:</span>
                                <span id="summary-total" class="font-outfit text-sc-green fw-black" style="font-size: 22px; font-weight: 900;">—</span>
                            </div>
                        </div>

                        <!-- Note -->
                        <div class="p-3 rounded text-sc-muted text-center" style="background: #141B2D; font-size: 12px; border: 1px solid var(--sc-border);">
                            <i class="bi bi-info-circle-fill text-sc-blue-light me-1"></i>
                            Giá cuối cùng sẽ được tính chính xác bởi hệ thống khi bạn xác nhận đặt sân.
                        </div>
                    </div>

                    <!-- Policy -->
                    <div class="mt-3 p-3 rounded" style="background-color: rgba(239, 68, 68, 0.04); border: 1px solid rgba(239, 68, 68, 0.12); font-size: 12px; line-height: 1.5;">
                        <span class="text-sc-red fw-bold d-block mb-1"><i class="bi bi-info-circle-fill me-1"></i> Lưu ý</span>
                        <span class="text-sc-muted">Booking sẽ được giữ tạm trong 5 phút. Nếu không thanh toán trong thời gian này, đơn đặt sân sẽ tự động hủy.</span>
                    </div>
                </div>
            </div>
        </div>
</main>

@section Scripts {
    <style>
        /* ===== TIMELINE BAR STYLES ===== */
        .slot-timeline-bar {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            padding: 4px 0;
        }

        .slot-segment {
            flex: 1 1 120px;
            max-width: 180px;
            min-width: 110px;
            padding: 12px 10px;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            user-select: none;
        }

        .slot-segment::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: 10px;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        /* Available */
        .slot-segment.slot-available {
            background: rgba(16, 185, 129, 0.06);
            border: 1.5px solid rgba(16, 185, 129, 0.25);
        }
        .slot-segment.slot-available:hover {
            background: rgba(16, 185, 129, 0.12);
            border-color: rgba(16, 185, 129, 0.5);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.15);
        }

        /* Booked */
        .slot-segment.slot-booked {
            background: #0a0a14;
            border: 1.5px solid #1a1a2e;
            cursor: not-allowed;
            opacity: 0.6;
        }
        .slot-segment.slot-booked .slot-time,
        .slot-segment.slot-booked .slot-name {
            color: #444 !important;
            text-decoration: line-through;
        }
        .slot-segment.slot-booked .slot-status-badge {
            background: rgba(239, 68, 68, 0.15);
            color: #EF4444;
        }

        /* Maintenance */
        .slot-segment.slot-maintenance {
            background: rgba(245, 158, 11, 0.05);
            border: 1.5px solid rgba(245, 158, 11, 0.2);
            cursor: not-allowed;
            opacity: 0.7;
        }
        .slot-segment.slot-maintenance .slot-status-badge {
            background: rgba(245, 158, 11, 0.15);
            color: #F59E0B;
        }

        /* Selected (start or end) */
        .slot-segment.slot-selected {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(37, 99, 235, 0.2));
            border-color: rgba(59, 130, 246, 0.6);
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.2), inset 0 0 15px rgba(59, 130, 246, 0.05);
            transform: translateY(-2px);
        }
        .slot-segment.slot-selected .slot-status-badge {
            background: rgba(59, 130, 246, 0.2);
            color: #60A5FA;
        }

        /* In-range (between start and end) */
        .slot-segment.slot-in-range {
            background: rgba(59, 130, 246, 0.08);
            border-color: rgba(59, 130, 246, 0.35);
            box-shadow: 0 0 10px rgba(59, 130, 246, 0.1);
        }
        .slot-segment.slot-in-range .slot-status-badge {
            background: rgba(59, 130, 246, 0.15);
            color: #93C5FD;
        }

        /* Start marker */
        .slot-segment.slot-start::after {
            content: 'BẮT ĐẦU';
            position: absolute;
            top: 3px;
            right: 5px;
            font-size: 8px;
            font-weight: 800;
            color: #60A5FA;
            letter-spacing: 0.5px;
        }

        /* End marker */
        .slot-segment.slot-end::after {
            content: 'KẾT THÚC';
            position: absolute;
            top: 3px;
            right: 5px;
            font-size: 8px;
            font-weight: 800;
            color: #60A5FA;
            letter-spacing: 0.5px;
        }

        /* Inner elements */
        .slot-time {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 14px;
            color: #E2E8F0;
            line-height: 1.2;
        }
        .slot-name {
            font-size: 10px;
            color: #64748B;
            margin-top: 2px;
        }
        .slot-price {
            font-size: 11px;
            font-weight: 600;
            color: #10B981;
            margin-top: 4px;
        }
        .slot-status-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 5px;
        }

        /* Pulse animation for selected slots */
        .slot-segment.slot-selected {
            animation: slotPulse 2s ease-in-out infinite;
        }
        @@keyframes slotPulse {
            0%, 100% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.2), inset 0 0 15px rgba(59, 130, 246, 0.05); }
            50% { box-shadow: 0 0 30px rgba(59, 130, 246, 0.35), inset 0 0 20px rgba(59, 130, 246, 0.1); }
        }

        /* Responsive */
        @@media (max-width: 576px) {
            .slot-segment {
                flex: 1 1 90px;
                min-width: 90px;
                max-width: none;
                padding: 10px 6px;
            }
            .slot-time { font-size: 12px; }
            .slot-segment.slot-start::after,
            .slot-segment.slot-end::after { font-size: 7px; }
        }
    </style>
    <script>
        $(document).ready(function () {
            const courtSelect = $('#court-select');
            const dateInput = $('#booking-date');

            // --- State ---
            let slotsData = [];        // Array of slot objects from AJAX
            let selectionStart = null; // slotId of the start selection
            let selectionEnd = null;   // slotId of the end selection
            let selectedSlotIds = [];  // Array of selected slotIds

            // --- Court Preview ---
            function updateCourtPreview() {
                const opt = courtSelect.find(':selected');
                if (!opt.val()) {
                    $('#court-preview').addClass('d-none');
                    $('#summary-court-section').hide();
                    return;
                }
                const name = opt.data('name');
                const type = opt.data('type');
                const location = opt.data('location') || 'N/A';
                const image = opt.data('image');

                $('#court-preview-name').text(name);
                $('#court-preview-meta').html(`<i class="bi bi-dribbble me-1"></i>${type} &middot; <i class="bi bi-geo-alt me-1"></i>${location}`);

                if (image) {
                    $('#court-preview-img').attr('src', `/images/courts/${image}`).show();
                    $('#court-preview-noimg').hide();
                } else {
                    $('#court-preview-img').hide();
                    $('#court-preview-noimg').show();
                }

                $('#court-preview').removeClass('d-none');
                $('#summary-court').text(name);
                $('#summary-court-section').show();
            }

            courtSelect.on('change', function () {
                updateCourtPreview();
                loadSlotAvailability();
                loadCourtServices();
            });
            updateCourtPreview();

            // Load Services by Court ID
            function loadCourtServices() {
                const courtId = courtSelect.val();
                const container = $('#services-container');

                if (!courtId) {
                    container.html(`
                        <div class="p-3 text-center rounded text-sc-muted" style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--sc-border); font-size: 13px;">
                            <i class="bi bi-box-seam me-2 text-sc-amber"></i>Chưa có dịch vụ đi kèm
                        </div>
                    `);
                    return;
                }

                $.ajax({
                    url: '/Booking/GetCourtServices',
                    type: 'GET',
                    data: { courtId: courtId },
                    success: function (res) {
                        if (res.success && res.services && res.services.length > 0) {
                            let html = '<div class="row g-3">';
                            res.services.forEach(function (svc) {
                                html += `
                                    <div class="col-sm-6">
                                        <div class="p-3 rounded d-flex align-items-center justify-content-between" style="background-color: rgba(255, 255, 255, 0.01); border: 1px solid var(--sc-border);">
                                            <div>
                                                <div class="text-white fw-bold" style="font-size: 14px;">${svc.serviceName}</div>
                                                <div class="text-sc-green fw-medium" style="font-size: 12px;">${Number(svc.price).toLocaleString('vi-VN')}đ / ${svc.unit || 'đơn vị'}</div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace service-qty-btn" data-sid="${svc.serviceId}" data-delta="-1">-</button>
                                                <input type="number" name="serviceQuantities[${svc.serviceId}]" id="svc-${svc.serviceId}"
                                                       value="0" min="0" max="${svc.stockQty > 0 ? Math.min(svc.stockQty, 20) : 20}"
                                                       data-price="${svc.price}"
                                                       class="text-center bg-transparent border-0 text-white font-monospace service-qty-input"
                                                       style="width: 40px; font-size: 14px;" readonly />
                                                <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded font-monospace service-qty-btn" data-sid="${svc.serviceId}" data-delta="1">+</button>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            });
                            html += '</div>';
                            container.html(html);
                        } else {
                            container.html(`
                                <div class="p-3 text-center rounded text-sc-muted" style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--sc-border); font-size: 13px;">
                                    <i class="bi bi-box-seam me-2 text-sc-amber"></i>Chưa có dịch vụ đi kèm
                                </div>
                            `);
                        }
                    },
                    error: function () {
                        container.html(`
                            <div class="p-3 text-center rounded text-sc-muted" style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--sc-border); font-size: 13px;">
                                <i class="bi bi-box-seam me-2 text-sc-amber"></i>Chưa có dịch vụ đi kèm
                            </div>
                        `);
                    }
                });
            }

            // --- Date Summary ---
            function updateDateSummary() {
                const dateVal = dateInput.val();
                if (dateVal) {
                    const d = new Date(dateVal);
                    const formatted = d.toLocaleDateString('vi-VN', { weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric' });
                    $('#summary-date').text(formatted);
                } else {
                    $('#summary-date').text('—');
                }
            }
            dateInput.on('change', function () {
                updateDateSummary();
                loadSlotAvailability();
            });
            updateDateSummary();

            // ============================
            // AJAX: Load Slot Availability
            // ============================
            function loadSlotAvailability() {
                const courtId = courtSelect.val();
                const dateVal = dateInput.val();

                // Reset selection
                clearSelection();

                if (!courtId || !dateVal) {
                    $('#slot-timeline-placeholder').show();
                    $('#slot-timeline-loading').hide();
                    $('#slot-timeline').hide();
                    return;
                }

                // Show loading
                $('#slot-timeline-placeholder').hide();
                $('#slot-timeline-loading').show();
                $('#slot-timeline').hide();

                $.ajax({
                    url: '/Booking/GetSlotAvailability',
                    type: 'GET',
                    data: { courtId: courtId, date: dateVal },
                    success: function (response) {
                        $('#slot-timeline-loading').hide();
                        if (response.success && response.slots && response.slots.length > 0) {
                            slotsData = response.slots;
                            renderTimeline();
                            $('#slot-timeline').show();
                        } else {
                            $('#slot-timeline-placeholder').show();
                            $('#slot-timeline-placeholder').html(
                                '<i class="bi bi-inbox text-sc-muted" style="font-size: 28px;"></i>' +
                                '<p class="text-sc-muted mt-2 mb-0" style="font-size: 13px;">Không có khung giờ nào cho ngày này.</p>'
                            );
                        }
                    },
                    error: function () {
                        $('#slot-timeline-loading').hide();
                        $('#slot-timeline-placeholder').show().html(
                            '<i class="bi bi-wifi-off text-sc-muted" style="font-size: 28px;"></i>' +
                            '<p class="text-sc-muted mt-2 mb-0" style="font-size: 13px;">Không thể kết nối tới server. Vui lòng thử lại.</p>'
                        );
                    }
                });
            }

            // ============================
            // Render Timeline Bar
            // ============================
            function renderTimeline() {
                const container = $('#slot-timeline');
                container.empty();

                const bar = $('<div class="slot-timeline-bar"></div>');

                slotsData.forEach(function (slot) {
                    const isAvailable = slot.status === 'Available';
                    const isBooked = slot.status === 'Booked';
                    const isMaintenance = slot.status === 'Maintenance';

                    let statusClass = 'slot-available';
                    let statusText = 'Trống';
                    let statusBadgeStyle = 'background: rgba(16,185,129,0.12); color: #10B981;';

                    if (isBooked) {
                        statusClass = 'slot-booked';
                        statusText = 'Đã đặt';
                        statusBadgeStyle = 'background: rgba(239,68,68,0.15); color: #EF4444;';
                    } else if (isMaintenance) {
                        statusClass = 'slot-maintenance';
                        statusText = 'Bảo trì';
                        statusBadgeStyle = 'background: rgba(245,158,11,0.15); color: #F59E0B;';
                    }

                    const priceDisplay = isAvailable
                        ? Number(slot.price).toLocaleString('vi-VN') + 'đ'
                        : '';

                    const segment = $(`
                        <div class="slot-segment ${statusClass}"
                             data-slot-id="${slot.slotId}"
                             data-slot-name="${slot.slotName}"
                             data-start-time="${slot.startTime}"
                             data-end-time="${slot.endTime}"
                             data-price="${slot.price}"
                             data-status="${slot.status}">
                            <div class="slot-time">${slot.startTime} - ${slot.endTime}</div>
                            <div class="slot-name">${slot.slotName}</div>
                            ${priceDisplay ? `<div class="slot-price">${priceDisplay}</div>` : ''}
                            <span class="slot-status-badge" style="${statusBadgeStyle}">${statusText}</span>
                        </div>
                    `);

                    // Click handler only for available slots
                    if (isAvailable) {
                        segment.on('click', function () {
                            handleSlotClick(slot.slotId);
                        });
                    }

                    bar.append(segment);
                });

                container.append(bar);
            }

            // ============================
            // Slot Click Logic (Start / End)
            // ============================
            function handleSlotClick(clickedSlotId) {
                const clickedIndex = slotsData.findIndex(s => s.slotId === clickedSlotId);
                if (clickedIndex === -1) return;

                // If nothing selected yet → set start
                if (selectionStart === null) {
                    selectionStart = clickedSlotId;
                    selectionEnd = null;
                    selectedSlotIds = [clickedSlotId];
                    updateTimelineHighlights();
                    updateHiddenInputs();
                    updateSlotSummary();
                    $('#slot-booked-warning').hide();
                    return;
                }

                // If start is already set and clicking the same slot → select just that one
                if (selectionStart === clickedSlotId && selectionEnd === null) {
                    // Already selected as single slot, clicking again resets
                    clearSelection();
                    return;
                }

                // If both start and end are set → reset and start new selection
                if (selectionEnd !== null) {
                    selectionStart = clickedSlotId;
                    selectionEnd = null;
                    selectedSlotIds = [clickedSlotId];
                    updateTimelineHighlights();
                    updateHiddenInputs();
                    updateSlotSummary();
                    $('#slot-booked-warning').hide();
                    return;
                }

                // Start is set, now setting end
                const startIndex = slotsData.findIndex(s => s.slotId === selectionStart);
                let fromIdx = Math.min(startIndex, clickedIndex);
                let toIdx = Math.max(startIndex, clickedIndex);

                // Check if any slot in the range is booked/maintenance
                let hasBlocker = false;
                for (let i = fromIdx; i <= toIdx; i++) {
                    if (slotsData[i].status !== 'Available') {
                        hasBlocker = true;
                        break;
                    }
                }

                if (hasBlocker) {
                    // Show warning, don't select
                    $('#slot-booked-warning').show();
                    setTimeout(() => $('#slot-booked-warning').fadeOut(300), 3000);
                    return;
                }

                // Valid range — select all in between
                if (startIndex <= clickedIndex) {
                    selectionStart = slotsData[fromIdx].slotId;
                    selectionEnd = slotsData[toIdx].slotId;
                } else {
                    selectionStart = slotsData[fromIdx].slotId;
                    selectionEnd = slotsData[toIdx].slotId;
                }

                selectedSlotIds = [];
                for (let i = fromIdx; i <= toIdx; i++) {
                    selectedSlotIds.push(slotsData[i].slotId);
                }

                updateTimelineHighlights();
                updateHiddenInputs();
                updateSlotSummary();
                $('#slot-booked-warning').hide();
            }

            // ============================
            // Clear Selection
            // ============================
            function clearSelection() {
                selectionStart = null;
                selectionEnd = null;
                selectedSlotIds = [];
                updateTimelineHighlights();
                updateHiddenInputs();
                updateSlotSummary();
                $('#slot-booked-warning').hide();
                $('#slot-selection-info').hide();
            }

            $('#btn-clear-slots').on('click', clearSelection);

            // ============================
            // Update Timeline Highlights
            // ============================
            function updateTimelineHighlights() {
                $('.slot-segment').each(function () {
                    const $el = $(this);
                    const slotId = parseInt($el.data('slot-id'));
                    const status = $el.data('status');

                    // Remove selection classes
                    $el.removeClass('slot-selected slot-in-range slot-start slot-end');

                    if (status !== 'Available') return; // Don't touch booked/maintenance

                    if (selectedSlotIds.includes(slotId)) {
                        if (slotId === selectionStart && selectionEnd !== null) {
                            $el.addClass('slot-selected slot-start');
                        } else if (slotId === selectionEnd) {
                            $el.addClass('slot-selected slot-end');
                        } else if (slotId === selectionStart && selectionEnd === null) {
                            $el.addClass('slot-selected slot-start');
                        } else {
                            $el.addClass('slot-in-range');
                        }
                    }
                });
            }

            // ============================
            // Hidden Inputs for form submit
            // ============================
            function updateHiddenInputs() {
                const container = $('#slot-hidden-inputs');
                container.empty();
                selectedSlotIds.forEach(function (id) {
                    container.append(`<input type="hidden" name="slotIds" value="${id}" />`);
                });
            }

            // ============================
            // Update Slot Summary (right panel)
            // ============================
            function updateSlotSummary() {
                if (selectedSlotIds.length === 0) {
                    $('#summary-slot').text('—');
                    $('#slot-selection-info').hide();
                    updateSummary();
                    return;
                }

                // Build summary text
                const selectedSlots = slotsData.filter(s => selectedSlotIds.includes(s.slotId));
                if (selectedSlots.length === 1) {
                    const s = selectedSlots[0];
                    $('#summary-slot').html(`${s.startTime} - ${s.endTime}`);
                    $('#slot-selection-text').text(`${s.slotName} (${s.startTime} - ${s.endTime})`);
                } else {
                    const first = selectedSlots[0];
                    const last = selectedSlots[selectedSlots.length - 1];
                    $('#summary-slot').html(`${first.startTime} → ${last.endTime} <small class="text-sc-muted">(${selectedSlots.length} slot)</small>`);
                    $('#slot-selection-text').text(`${first.startTime} → ${last.endTime} (${selectedSlots.length} slot)`);
                }

                $('#slot-selection-info').show();
                updateSummary();
            }

            // --- Service Quantity +/- Buttons ---
            $(document).on('click', '.service-qty-btn', function (e) {
                e.preventDefault();
                const sid = $(this).data('sid');
                const delta = parseInt($(this).data('delta'));
                const input = $('#svc-' + sid);
                if (input.length === 0) return;
                const minVal = parseInt(input.attr('min')) || 0;
                const maxVal = parseInt(input.attr('max')) || 20;
                let val = parseInt(input.val()) || 0;
                val = val + delta;
                if (val < minVal) val = minVal;
                if (val > maxVal) val = maxVal;
                input.val(val);
                updateSummary();
            });

            // --- Promo Code ---
            $('#btn-apply-promo').on('click', function () {
                const code = $('#promo-input').val().trim();
                if (code) {
                    $('#promo-msg').text('Mã "' + code + '" sẽ được áp dụng khi xác nhận.').css('color', '#10B981').show();
                    $('#summary-promo-row').show();
                    $('#summary-promo-code').text(code);
                } else {
                    $('#promo-msg').text('Vui lòng nhập mã giảm giá.').css('color', '#EF4444').show();
                    $('#summary-promo-row').hide();
                }
            });

            // --- Update Summary Totals ---
            function updateSummary() {
                let serviceTotal = 0;
                $('.service-qty-input').each(function () {
                    const qty = parseInt($(this).val()) || 0;
                    const price = parseFloat($(this).data('price')) || 0;
                    serviceTotal += qty * price;
                });
                $('#summary-service-price').text(serviceTotal > 0 ? serviceTotal.toLocaleString('vi-VN') + 'đ' : '0đ');

                // Court price from selected slots
                let courtTotal = 0;
                const selectedSlots = slotsData.filter(s => selectedSlotIds.includes(s.slotId));
                selectedSlots.forEach(function (s) {
                    courtTotal += s.price;
                });

                if (courtTotal > 0) {
                    let priceText = courtTotal.toLocaleString('vi-VN') + 'đ';
                    if (selectedSlots.length > 1) priceText += ` (x${selectedSlots.length} slot)`;
                    $('#summary-court-price').text(priceText);
                } else {
                    const courtPrice = parseFloat(courtSelect.find(':selected').data('price')) || 0;
                    $('#summary-court-price').text(courtPrice > 0 ? courtPrice.toLocaleString('vi-VN') + 'đ' : '—');
                }

                const total = courtTotal + serviceTotal;
                $('#summary-total').text(total > 0 ? total.toLocaleString('vi-VN') + 'đ' : '—');
            }

            updateSummary();

            // ==========================================
            // TAB 2: RECURRING BOOKING TIMELINE & SLOTS
            // ==========================================
            const recCourtSelect = $('#rec-court-select');
            const recStartDate = $('#rec-start-date');
            const recEndDate = $('#rec-end-date');

            let recSlotsData = [];
            let recSelectionStart = null;
            let recSelectionEnd = null;
            let recSelectedSlotIds = [];

            recCourtSelect.on('change', function () {
                loadRecSlotAvailability();
                updateRecSummary();
            });

            recStartDate.add(recEndDate).on('change', function () {
                loadRecSlotAvailability();
                updateRecSummary();
            });

            $('input[name="daysOfWeek"]').on('change', function () {
                updateRecSummary();
            });

            function loadRecSlotAvailability() {
                const courtId = recCourtSelect.val();
                const startVal = recStartDate.val() || new Date().toISOString().split('T')[0];

                clearRecSelection();

                if (!courtId) {
                    $('#rec-slot-timeline-placeholder').show();
                    $('#rec-slot-timeline-loading').hide();
                    $('#rec-slot-timeline').hide();
                    return;
                }

                $('#rec-slot-timeline-placeholder').hide();
                $('#rec-slot-timeline-loading').show();
                $('#rec-slot-timeline').hide();

                $.ajax({
                    url: '/Booking/GetSlotAvailability',
                    type: 'GET',
                    data: { courtId: courtId, date: startVal },
                    success: function (response) {
                        $('#rec-slot-timeline-loading').hide();
                        if (response.success && response.slots && response.slots.length > 0) {
                            recSlotsData = response.slots;
                            renderRecTimeline();
                            $('#rec-slot-timeline').show();
                        } else {
                            $('#rec-slot-timeline-placeholder').show().html(
                                '<i class="bi bi-inbox text-sc-muted" style="font-size: 24px;"></i>' +
                                '<p class="text-sc-muted mt-1 mb-0" style="font-size: 12px;">Không có khung giờ nào cho sân này.</p>'
                            );
                        }
                    },
                    error: function () {
                        $('#rec-slot-timeline-loading').hide();
                        $('#rec-slot-timeline-placeholder').show().html(
                            '<i class="bi bi-wifi-off text-sc-muted" style="font-size: 24px;"></i>' +
                            '<p class="text-sc-muted mt-1 mb-0" style="font-size: 12px;">Lỗi kết nối máy chủ.</p>'
                        );
                    }
                });
            }

            function renderRecTimeline() {
                const container = $('#rec-slot-timeline');
                container.empty();
                const bar = $('<div class="slot-timeline-bar"></div>');

                recSlotsData.forEach(function (slot) {
                    const priceDisplay = Number(slot.price).toLocaleString('vi-VN') + 'đ';

                    const segment = $(`
                        <div class="slot-segment slot-available"
                             data-slot-id="${slot.slotId}"
                             data-slot-name="${slot.slotName}"
                             data-start-time="${slot.startTime}"
                             data-end-time="${slot.endTime}"
                             data-price="${slot.price}">
                            <div class="slot-time">${slot.startTime} - ${slot.endTime}</div>
                            <div class="slot-name">${slot.slotName}</div>
                            <div class="slot-price">${priceDisplay}</div>
                            <span class="slot-status-badge" style="background: rgba(245,158,11,0.15); color: #F59E0B;">Định kỳ</span>
                        </div>
                    `);

                    segment.on('click', function () {
                        handleRecSlotClick(slot.slotId);
                    });

                    bar.append(segment);
                });

                container.append(bar);
            }

            function handleRecSlotClick(clickedSlotId) {
                const clickedIndex = recSlotsData.findIndex(s => s.slotId === clickedSlotId);
                if (clickedIndex === -1) return;

                if (recSelectionStart === null) {
                    recSelectionStart = clickedSlotId;
                    recSelectionEnd = null;
                    recSelectedSlotIds = [clickedSlotId];
                } else if (recSelectionStart === clickedSlotId && recSelectionEnd === null) {
                    clearRecSelection();
                    return;
                } else if (recSelectionEnd !== null) {
                    recSelectionStart = clickedSlotId;
                    recSelectionEnd = null;
                    recSelectedSlotIds = [clickedSlotId];
                } else {
                    const startIndex = recSlotsData.findIndex(s => s.slotId === recSelectionStart);
                    let fromIdx = Math.min(startIndex, clickedIndex);
                    let toIdx = Math.max(startIndex, clickedIndex);

                    recSelectionStart = recSlotsData[fromIdx].slotId;
                    recSelectionEnd = recSlotsData[toIdx].slotId;

                    recSelectedSlotIds = [];
                    for (let i = fromIdx; i <= toIdx; i++) {
                        recSelectedSlotIds.push(recSlotsData[i].slotId);
                    }
                }

                updateRecTimelineHighlights();
                updateRecHiddenInputs();
                updateRecSlotSummary();
            }

            function clearRecSelection() {
                recSelectionStart = null;
                recSelectionEnd = null;
                recSelectedSlotIds = [];
                updateRecTimelineHighlights();
                updateRecHiddenInputs();
                updateRecSlotSummary();
                $('#rec-slot-selection-info').hide();
            }

            $('#btn-rec-clear-slots').on('click', clearRecSelection);

            function updateRecTimelineHighlights() {
                $('#rec-slot-timeline .slot-segment').each(function () {
                    const $el = $(this);
                    const slotId = parseInt($el.data('slot-id'));

                    $el.removeClass('slot-selected slot-in-range slot-start slot-end');

                    if (recSelectedSlotIds.includes(slotId)) {
                        if (slotId === recSelectionStart && recSelectionEnd !== null) {
                            $el.addClass('slot-selected slot-start');
                        } else if (slotId === recSelectionEnd) {
                            $el.addClass('slot-selected slot-end');
                        } else if (slotId === recSelectionStart && recSelectionEnd === null) {
                            $el.addClass('slot-selected slot-start');
                        } else {
                            $el.addClass('slot-in-range');
                        }
                    }
                });
            }

            function updateRecHiddenInputs() {
                const container = $('#rec-slot-hidden-inputs');
                container.empty();
                recSelectedSlotIds.forEach(function (id) {
                    container.append(`<input type="hidden" name="slotIds" value="${id}" />`);
                });
            }

            function updateRecSlotSummary() {
                if (recSelectedSlotIds.length === 0) {
                    $('#rec-slot-selection-info').hide();
                    updateRecSummary();
                    return;
                }

                const selectedSlots = recSlotsData.filter(s => recSelectedSlotIds.includes(s.slotId));
                if (selectedSlots.length === 1) {
                    const s = selectedSlots[0];
                    $('#rec-slot-selection-text').text(`${s.slotName} (${s.startTime} - ${s.endTime})`);
                } else {
                    const first = selectedSlots[0];
                    const last = selectedSlots[selectedSlots.length - 1];
                    $('#rec-slot-selection-text').text(`${first.startTime} → ${last.endTime} (${selectedSlots.length} slot)`);
                }

                $('#rec-slot-selection-info').show();
                updateRecSummary();
            }

            function updateRecSummary() {
                const activeTab = $('#booking-type-tabs .nav-link.active').attr('id');
                if (activeTab === 'tab-recurring-btn') {
                    // Update right column for recurring booking
                    const courtName = recCourtSelect.find(':selected').text().split('—')[0].trim();
                    $('#summary-court').text(courtName && courtName !== '-- Chọn sân --' ? courtName : '—');
                    
                    const startVal = recStartDate.val();
                    const endVal = recEndDate.val();
                    if (startVal && endVal) {
                        $('#summary-date').text(`${formatDateVN(startVal)} - ${formatDateVN(endVal)}`);
                    } else {
                        $('#summary-date').text('—');
                    }

                    // Calculate total sessions
                    let sessionCount = 0;
                    if (startVal && endVal) {
                        const start = new Date(startVal);
                        const end = new Date(endVal);
                        const daysOfWeek = [];
                        $('input[name="daysOfWeek"]:checked').each(function () {
                            daysOfWeek.push(parseInt($(this).val()));
                        });

                        let curr = new Date(start);
                        while (curr <= end) {
                            if (daysOfWeek.includes(curr.getDay())) {
                                sessionCount++;
                            }
                            curr.setDate(curr.getDate() + 1);
                        }
                    }

                    // Calculate court price from selected slots
                    let slotTotalPerSession = 0;
                    const selectedSlots = recSlotsData.filter(s => recSelectedSlotIds.includes(s.slotId));
                    selectedSlots.forEach(s => slotTotalPerSession += s.price);

                    const totalCourtPrice = slotTotalPerSession * sessionCount;
                    if (totalCourtPrice > 0) {
                        $('#summary-court-price').text(`${totalCourtPrice.toLocaleString('vi-VN')}đ (${sessionCount} buổi x ${selectedSlots.length} slot)`);
                        $('#summary-total').text(`${totalCourtPrice.toLocaleString('vi-VN')}đ`);
                    } else {
                        $('#summary-court-price').text('—');
                        $('#summary-total').text('—');
                    }

                    if (selectedSlots.length > 0) {
                        const first = selectedSlots[0];
                        const last = selectedSlots[selectedSlots.length - 1];
                        $('#summary-slot').html(`${first.startTime} → ${last.endTime} (${selectedSlots.length} slot)`);
                    } else {
                        $('#summary-slot').text('—');
                    }
                    $('#summary-service-price').text('0đ');
                }
            }

            function formatDateVN(dateStr) {
                if (!dateStr) return '';
                const parts = dateStr.split('-');
                if (parts.length === 3) return `${parts[2]}/${parts[1]}`;
                return dateStr;
            }

            // Tab switch listener to recalculate summary
            $('#booking-type-tabs button').on('shown.bs.tab', function (e) {
                if (e.target.id === 'tab-recurring-btn') {
                    if (recCourtSelect.val()) loadRecSlotAvailability();
                    updateRecSummary();
                } else {
                    updateSummary();
                }
            });

            $('#recurring-booking-form').on('submit', function (e) {
                if (recSelectedSlotIds.length === 0) {
                    e.preventDefault();
                    $('#rec-slot-error').show();
                    return false;
                }
                $('#rec-slot-error').hide();
                return true;
            });

            // --- Form Validation ---
            $('#booking-form').on('submit', function (e) {
                if (selectedSlotIds.length === 0) {
                    e.preventDefault();
                    $('#slot-error').show();
                    return false;
                }
                $('#slot-error').hide();
                return true;
            });

            // --- Auto-load slots if court and date are pre-selected ---
            if (courtSelect.val() && dateInput.val()) {
                loadSlotAvailability();
            }
            if (recCourtSelect.val()) {
                loadRecSlotAvailability();
                updateRecSummary();
            }
        });
    </script>
}
