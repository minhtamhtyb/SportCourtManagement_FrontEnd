@model SportCourtManagement_FrontEnd.Models.Tournaments.TournamentDto
@{
  ViewData["Title"] = $"Chi Tiết Giải Đấu #{Model.TournamentId} - Admin";
  bool isPending = Model.Status == "Pending";
  bool isCancelled = Model.Status == "Cancelled";
}

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <a asp-action="AdminIndex" class="btn btn-sm btn-outline-light rounded-pill mb-2">
        <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách Admin
      </a>
      <h2 class="fw-bold text-white mb-1 d-flex align-items-center gap-2">
        <i class="bi bi-trophy-fill text-warning"></i> @Model.TournamentName
        <span class="badge bg-primary fs-6">#@Model.TournamentId</span>
      </h2>
      <p class="text-light mb-0">Người tổ chức: <strong class="text-warning">@Model.CustomerName</strong> | Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    <!-- Action Buttons for Admin -->
    <div class="d-flex gap-2">
      @if (isPending)
      {
        <form asp-action="UpdateStatus" method="post" class="d-inline">
          <input type="hidden" name="id" value="@Model.TournamentId" />
          <input type="hidden" name="status" value="Confirmed" />
          <input type="hidden" name="returnUrl" value="@Url.Action("AdminDetail", new { id = Model.TournamentId })" />
          <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm fw-bold">
            <i class="bi bi-check-circle-fill me-1"></i>Duyệt Giải Đấu
          </button>
        </form>
      }
      @if (!isCancelled)
      {
        <form asp-action="UpdateStatus" method="post" class="d-inline" onsubmit="return confirm('Xác nhận hủy giải đấu này?');">
          <input type="hidden" name="id" value="@Model.TournamentId" />
          <input type="hidden" name="status" value="Cancelled" />
          <input type="hidden" name="cancelReason" value="Quản trị viên từ chối/hủy từ trang chi tiết" />
          <input type="hidden" name="returnUrl" value="@Url.Action("AdminDetail", new { id = Model.TournamentId })" />
          <button type="submit" class="btn btn-outline-danger px-4 rounded-pill fw-bold">
            <i class="bi bi-x-circle-fill me-1"></i>Hủy Giải
          </button>
        </form>
      }
    </div>
  </div>

  @if (TempData["SuccessMessage"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
      <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["ErrorMessage"] != null)
  {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }

  <!-- Stat Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm rounded-4 p-3 bg-light text-dark h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 fs-3">
            <i class="bi bi-calendar-check-fill"></i>
          </div>
          <div>
            <small class="text-muted d-block fw-semibold">SỐ LỊCH ĐẶT CON</small>
            <h3 class="fw-bold mb-0">@Model.Bookings.Count <span class="fs-6 fw-normal text-muted">ca đặt</span></h3>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm rounded-4 p-3 bg-light text-dark h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-success bg-opacity-10 text-success p-3 rounded-3 fs-3">
            <i class="bi bi-cash-stack"></i>
          </div>
          <div>
            <small class="text-muted d-block fw-semibold">TỔNG CHI PHÍ</small>
            <h3 class="fw-bold mb-0 text-danger">@Model.TotalAmount.ToString("N0")đ</h3>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm rounded-4 p-3 bg-light text-dark h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-info bg-opacity-10 text-info p-3 rounded-3 fs-3">
            <i class="bi bi-info-circle-fill"></i>
          </div>
          <div>
            <small class="text-muted d-block fw-semibold">TRẠNG THÁI HIỆN TẠI</small>
            <div class="mt-1">
              @switch (Model.Status)
              {
                case "Confirmed":
                  <span class="badge bg-primary px-3 py-2 fs-6">Đã duyệt</span>
                  break;
                case "Paid":
                  <span class="badge bg-success px-3 py-2 fs-6">Đã thanh toán</span>
                  break;
                case "Pending":
                  <span class="badge bg-warning text-dark px-3 py-2 fs-6">Chờ duyệt</span>
                  break;
                case "Cancelled":
                  <span class="badge bg-danger px-3 py-2 fs-6">Đã hủy</span>
                  break;
                default:
                  <span class="badge bg-secondary px-3 py-2 fs-6">@Model.Status</span>
                  break;
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Description Box -->
  @if (!string.IsNullOrEmpty(Model.Description))
  {
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white text-dark">
      <div class="card-body p-4">
        <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-card-text me-2"></i>Mô tả giải đấu / Ghi chú từ người tổ chức</h6>
        <p class="mb-0 text-dark">@Model.Description</p>
      </div>
    </div>
  }

  <!-- Bookings Table -->
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="card-header py-3 px-4 d-flex justify-content-between align-items-center">
      <h5 class="mb-0 fw-bold text-white">Danh Sách Lịch Đặt Sân Chi Tiết - (Số đơn: @Model.Bookings.Count)</h5>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light text-secondary">
          <tr>
            <th class="py-3 px-4">Mã Booking</th>
            <th class="py-3">Sân thi đấu</th>
            <th class="py-3">Ca / Khung giờ</th>
            <th class="py-3">Ngày thi đấu</th>
            <th class="py-3">Dịch vụ đi kèm</th>
            <th class="py-3">Thành tiền</th>
            <th class="py-3">Trạng thái</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Bookings != null && Model.Bookings.Count > 0)
          {
            foreach (var b in Model.Bookings)
            {
              <tr>
                <td class="px-4 fw-bold text-primary">#@b.BookingCode</td>
                <td class="fw-bold text-dark">@b.CourtName</td>
                <td>
                  <span class="badge bg-light text-dark border px-3 py-2">
                    <i class="bi bi-clock me-1 text-primary"></i>@b.SlotName (@b.StartTime - @b.EndTime)
                  </span>
                </td>
                <td class="fw-semibold">@b.BookingDate.ToString("dd/MM/yyyy")</td>
                <td>
                  @if (b.Services != null && b.Services.Count > 0)
                  {
                    <div class="d-flex flex-wrap gap-1">
                      @foreach (var s in b.Services)
                      {
                        <span class="badge bg-secondary bg-opacity-10 text-dark border">
                          @s.ServiceName ( Số Lượng: @s.Quantity)
                        </span>
                      }
                    </div>
                  }
                  else
                  {
                    <span class="text-muted small">Không sử dụng</span>
                  }
                </td>
                <td class="fw-bold text-danger">@b.TotalAmount.ToString("N0")đ</td>
                <td>
                  <span class="badge bg-secondary px-3 py-1">@b.Status</span>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="7" class="text-center py-4 text-muted">
                Không có lịch đặt sân nào trong giải đấu này.
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>
