@model SportCourtManagement_FrontEnd.Models.Tournaments.TournamentListViewModel
@{
  ViewData["Title"] = "Giải Đấu Đăng Ký Của Tôi";
}

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold text-primary mb-1"><i class="bi bi-award-fill me-2"></i>Giải Đấu Đăng Ký Của Tôi</h2>
      <p class="text-muted mb-0">Quản lý và theo dõi tiến độ phê duyệt các giải đấu do bạn tổ chức</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-semibold">
      <i class="bi bi-plus-circle me-1"></i> Đăng ký giải đấu mới
    </a>
  </div>

  @if (TempData["SuccessMessage"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
      <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["ErrorMessage"] != null)
  {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }

  <!-- Filter Card -->
  <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light">
    <div class="card-body p-4">
      <form method="get" asp-action="MyTournaments" class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="form-label fw-semibold text-secondary">Tên giải đấu</label>
          <input type="text" name="keyword" value="@Model.Keyword" class="form-control rounded-3" placeholder="Tìm kiếm giải đấu..." />
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Trạng thái</label>
          <select name="status" class="form-select rounded-3">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Pending" selected="@(Model.Status == "Pending")">Chờ xác nhận</option>
            <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Đã phê duyệt</option>
            <option value="Paid" selected="@(Model.Status == "Paid")">Đã thanh toán</option>
            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã hủy</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold text-secondary">Ngày tổ chức</label>
          <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control rounded-3" />
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100 rounded-3 shadow-sm">Tìm kiếm</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Tournaments List -->
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-primary text-white">
          <tr>
            <th class="py-3 px-4">Mã Giải</th>
            <th class="py-3">Tên Giải Đấu</th>
            <th class="py-3">Ngày Đăng Ký</th>
            <th class="py-3">Số Lượng Sân</th>
            <th class="py-3">Chi Phí Dự Kiến</th>
            <th class="py-3">Trạng Thái</th>
            <th class="py-3 text-center">Thao Tác</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.PagedData.Items != null && Model.PagedData.Items.Count > 0)
          {
            foreach (var item in Model.PagedData.Items)
            {
              <tr>
                <td class="px-4 fw-bold text-primary">#@item.TournamentId</td>
                <td>
                  <span class="fw-bold d-block fs-6">@item.TournamentName</span>
                  <small class="text-muted">@(item.Description ?? "Không có mô tả")</small>
                </td>
                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                <td><span class="badge bg-info text-dark px-3 py-2">@item.Bookings.Count booking con</span></td>
                <td><span class="text-danger fw-bold fs-6">@item.TotalAmount.ToString("N0")đ</span></td>
                <td>
                  @switch (item.Status)
                  {
                    case "Confirmed" or "Paid":
                      <span class="badge bg-success px-3 py-2 rounded-pill">Đã duyệt</span>
                      break;
                    case "Pending":
                      <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ phê duyệt</span>
                      break;
                    case "Cancelled":
                      <span class="badge bg-danger px-3 py-2 rounded-pill">Bị từ chối/hủy</span>
                      break;
                    default:
                      <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Status</span>
                      break;
                  }
                </td>
                <td class="text-center">
                  <a asp-action="MyDetail" asp-route-id="@item.TournamentId" class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1 fw-semibold shadow-sm">
                    <i class="bi bi-eye-fill me-1"></i>Xem chi tiết
                  </a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-award fs-1 d-block mb-2"></i>
                Bạn chưa đăng ký tổ chức giải đấu nào.
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    @if (Model.PagedData.TotalPages > 1)
    {
      <div class="card-footer bg-white py-3 px-4 d-flex justify-content-between align-items-center border-top">
        <span class="text-muted small">Hiển thị trang @Model.PagedData.PageNumber / @Model.PagedData.TotalPages</span>
        <ul class="pagination mb-0">
          <li class="page-item @(Model.PagedData.PageNumber <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="MyTournaments" asp-route-page="@(Model.PagedData.PageNumber - 1)">Trước</a>
          </li>
          @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
          {
            <li class="page-item @(i == Model.PagedData.PageNumber ? "active" : "")">
              <a class="page-link" asp-action="MyTournaments" asp-route-page="@i">@i</a>
            </li>
          }
          <li class="page-item @(Model.PagedData.PageNumber >= Model.PagedData.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="MyTournaments" asp-route-page="@(Model.PagedData.PageNumber + 1)">Sau</a>
          </li>
        </ul>
      </div>
    }
  </div>
</div>
