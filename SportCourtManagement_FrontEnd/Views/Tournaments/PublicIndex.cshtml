@model SportCourtManagement_FrontEnd.Models.Tournaments.PublicTournamentListViewModel
@{
  ViewData["Title"] = "Các Giải Đấu Sắp Diễn Ra";
}

<!-- Hero Banner -->
<div class="bg-dark text-white py-5 mb-5 shadow" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
  <div class="container py-3 text-center">
    <h1 class="display-4 fw-bold mb-3"><i class="bi bi-trophy-fill text-warning me-3"></i>Lịch Thi Đấu & Giải Đấu Công Khai</h1>
    <p class="lead mb-4 mx-auto" style="max-width: 700px;">Cập nhật lịch thi đấu, giao lưu thể thao và các giải đấu lớn nhỏ đang tổ chức tại các cụm sân của chúng tôi.</p>
    
    <form method="get" asp-action="PublicIndex" class="d-flex justify-content-center">
      <div class="input-group input-group-lg shadow-sm" style="max-width: 600px;">
        <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="Tìm tên giải đấu hoặc ban tổ chức..." />
        <button type="submit" class="btn btn-warning fw-bold px-4">Tìm kiếm <i class="bi bi-search ms-1"></i></button>
      </div>
    </form>
  </div>
</div>

<div class="container pb-5">
  <div class="row g-4">
    @if (Model.PagedData.Items != null && Model.PagedData.Items.Count > 0)
    {
      foreach (var item in Model.PagedData.Items)
      {
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-all">
            <div class="card-header bg-primary text-white p-4 d-flex justify-content-between align-items-center">
              <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold"><i class="bi bi-star-fill me-1"></i>Giải đấu</span>
              <small class="text-white-50">@item.CreatedAt.ToString("dd/MM/yyyy")</small>
            </div>
            <div class="card-body p-4 d-flex flex-column">
              <h4 class="card-title fw-bold text-dark mb-2">@item.TournamentName</h4>
              <p class="text-muted small mb-3 flex-grow-1">@(item.Description ?? "Giải đấu thể thao giao lưu, kính mời các vận động viên và khán giả tham gia cổ vũ.")</p>
              
              <div class="border-top pt-3 mt-auto">
                <div class="d-flex align-items-center justify-content-between mb-2">
                  <span class="text-secondary small"><i class="bi bi-person-fill me-1"></i>BTC:</span>
                  <span class="fw-semibold text-primary">@item.OrganizerName</span>
                </div>
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <span class="text-secondary small"><i class="bi bi-geo-alt-fill me-1"></i>Quy mô:</span>
                  <span class="badge bg-light text-dark border">@item.Courts.Count sân thi đấu</span>
                </div>
                
                <a asp-action="PublicDetail" asp-route-id="@item.TournamentId" class="btn btn-outline-primary w-100 rounded-pill fw-semibold py-2">
                  Xem chi tiết lịch thi đấu <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      }
    }
    else
    {
      <div class="col-12 text-center py-5">
        <div class="card border-0 shadow-sm rounded-4 p-5 bg-light">
          <i class="bi bi-calendar2-x fs-1 text-muted mb-3"></i>
          <h4 class="fw-bold text-secondary">Hiện chưa có giải đấu công khai nào</h4>
          <p class="text-muted">Bạn muốn đăng ký tổ chức giải đấu? Hãy đặt lịch ngay hôm nay.</p>
          <div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 mt-2">Đăng ký tổ chức giải đấu</a>
          </div>
        </div>
      </div>
    }
  </div>

  @if (Model.PagedData.TotalPages > 1)
  {
    <div class="d-flex justify-content-center mt-5">
      <ul class="pagination pagination-lg">
        <li class="page-item @(Model.PagedData.PageNumber <= 1 ? "disabled" : "")">
          <a class="page-link rounded-start-pill px-4" asp-action="PublicIndex" asp-route-page="@(Model.PagedData.PageNumber - 1)">Trang trước</a>
        </li>
        @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
        {
          <li class="page-item @(i == Model.PagedData.PageNumber ? "active" : "")">
            <a class="page-link" asp-action="PublicIndex" asp-route-page="@i">@i</a>
          </li>
        }
        <li class="page-item @(Model.PagedData.PageNumber >= Model.PagedData.TotalPages ? "disabled" : "")">
          <a class="page-link rounded-end-pill px-4" asp-action="PublicIndex" asp-route-page="@(Model.PagedData.PageNumber + 1)">Trang sau</a>
        </li>
      </ul>
    </div>
  }
</div>
