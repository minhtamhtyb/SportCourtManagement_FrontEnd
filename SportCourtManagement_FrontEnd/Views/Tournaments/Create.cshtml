@model SportCourtManagement_FrontEnd.Models.Tournaments.CreateTournamentFormDto
@{
  ViewData["Title"] = "Đăng Ký Tổ Chức Giải Đấu";
}

<style>
  :root {
    --primary-gradient: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
    --accent-gradient: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    --glass-bg: rgba(255, 255, 255, 0.95);
    --glass-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  body {
    background-color: #f8fafc;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .hero-tournament-header {
    background: var(--primary-gradient);
    color: #ffffff;
    padding: 3rem 2.5rem;
    border-radius: 1.5rem 1.5rem 0 0;
    position: relative;
    overflow: hidden;
  }

  .hero-tournament-header::after {
    content: "";
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .filter-tab-btn {
    border: 1px solid #cbd5e1;
    background: #ffffff;
    color: #334155;
    font-weight: 600;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .filter-tab-btn:hover, .filter-tab-btn.active {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
  }

  .court-card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1.5px solid #e2e8f0 !important;
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
  }

  .court-card:hover {
    border-color: #3b82f6 !important;
    transform: translateY(-3px);
    box-shadow: var(--glass-shadow);
  }

  .court-card.conflict-highlight {
    border-color: #ef4444 !important;
    background-color: #fef2f2 !important;
    animation: pulse-border 1.5s infinite;
  }

  @@keyframes pulse-border {
    0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
    100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
  }

  .sticky-summary {
    position: sticky;
    top: 100px;
    z-index: 10;
  }

  .slot-label {
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .slot-label:hover {
    transform: scale(1.05);
  }

  .slot-checkbox:checked + .slot-label {
    background: #2563eb !important;
    color: #ffffff !important;
    border-color: #2563eb !important;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.3);
  }

  .slot-label.conflict-slot {
    background: #ef4444 !important;
    color: #ffffff !important;
    border-color: #dc2626 !important;
  }
</style>

<div class="container py-4">
  <!-- Conflict Alert Banner (Hidden by default) -->
  <div id="conflictAlertBanner" class="alert alert-danger rounded-4 shadow-lg mb-4 d-none border-danger border-2 d-flex align-items-center justify-content-between p-4" role="alert">
    <div>
      <h5 class="fw-bold mb-1 text-danger"><i class="bi bi-exclamation-octagon-fill me-2 fs-4"></i>Phát hiện ca thi đấu bị trùng hoặc hết hạn giữ chỗ!</h5>
      <p id="conflictAlertMessage" class="mb-0 small text-dark fw-semibold"></p>
    </div>
    <button type="button" class="btn-close" onclick="hideConflictBanner()"></button>
  </div>

  <form id="tournamentForm" onsubmit="return false;">
    @Html.AntiForgeryToken()
    <div class="row g-4">
      <!-- Left Column: Main Form -->
      <div class="col-lg-8">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
          <!-- Rich Gradient Header -->
          <div class="hero-tournament-header">
            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold mb-3 small shadow-sm">
              <i class="bi bi-star-fill me-1"></i> Dành cho Ban Tổ Chức
            </span>
            <h2 class="mb-2 fw-black text-white"><i class="bi bi-trophy-fill me-2 text-warning"></i>Đăng Ký Tổ Chức Giải Đấu Thể Thao</h2>
            <p class="mb-0 text-white-50 fs-6">Đặt lịch đồng loạt nhiều sân đấu, khung giờ và dịch vụ đi kèm với quy trình giữ chỗ thời gian thực</p>
          </div>
          
          <div class="card-body p-4 p-md-5">
            <!-- 1. Basic Info Section -->
            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-1-circle-fill text-primary me-2"></i>Thông Tin Chung</h5>
            <div class="row g-3 mb-4">
              <div class="col-md-7">
                <label asp-for="TournamentName" class="form-label fw-semibold text-dark">Tên giải đấu <span class="text-danger">*</span></label>
                <input asp-for="TournamentName" class="form-control rounded-3 py-2 shadow-sm" id="inputTournamentName" placeholder="VD: Giải Cầu Lông Mở Rộng 2026..." required />
                <span asp-validation-for="TournamentName" class="text-danger small"></span>
              </div>
              <div class="col-md-5">
                <label asp-for="BookingDate" class="form-label fw-semibold text-dark">Ngày khai mạc <span class="text-danger">*</span></label>
                <input asp-for="BookingDate" type="date" class="form-control rounded-3 py-2 shadow-sm" id="inputBookingDate" value="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")" required />
                <span asp-validation-for="BookingDate" class="text-danger small"></span>
              </div>
              <div class="col-12">
                <label asp-for="Description" class="form-label fw-semibold text-dark">Mô tả và quy mô giải đấu</label>
                <textarea asp-for="Description" id="inputDescription" class="form-control rounded-3 shadow-sm" rows="2" placeholder="Giới thiệu thể lệ, số lượng vận động viên dự kiến..."></textarea>
              </div>
            </div>

            <!-- 2. Court & Slot Selection Section -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
              <h5 class="fw-bold text-dark mb-0"><i class="bi bi-2-circle-fill text-primary me-2"></i>Chọn Sân & Khung Giờ</h5>
              <span class="text-muted small"><i class="bi bi-hand-index-thumb me-1"></i>Bấm nút để lọc theo bộ môn</span>
            </div>

            <!-- Court Type Filter Bar -->
            <div class="d-flex flex-wrap gap-2 mb-3" id="courtTypeFilters">
              <button type="button" class="btn btn-sm rounded-pill filter-tab-btn active px-3 py-1.5" data-filter="all">
                <i class="bi bi-grid-fill me-1"></i> Tất Cả
              </button>
              @if (ViewBag.CourtTypes != null)
              {
                var seenTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                foreach (var ct in ViewBag.CourtTypes)
                {
                  string normTab = ct.TypeName;
                  if (normTab.Contains("Cầu Lông", StringComparison.OrdinalIgnoreCase)) normTab = "Sân Cầu Lông";
                  else if (normTab.Contains("Bóng Rổ", StringComparison.OrdinalIgnoreCase)) normTab = "Sân Bóng Rổ";
                  else if (normTab.Contains("Tennis", StringComparison.OrdinalIgnoreCase)) normTab = "Sân Tennis";
                  else if (normTab.Contains("Pickleball", StringComparison.OrdinalIgnoreCase)) normTab = "Sân Pickleball";
                  else if (normTab.Contains("Bóng Đá", StringComparison.OrdinalIgnoreCase)) normTab = "Sân Bóng Đá Mini";

                  if (!seenTypes.Contains(normTab))
                  {
                    seenTypes.Add(normTab);
                    <button type="button" class="btn btn-sm rounded-pill filter-tab-btn px-3 py-1.5" data-filter="@normTab">
                      @normTab
                    </button>
                  }
                }
              }
            </div>

            <div class="alert alert-info bg-info-subtle border-info-subtle rounded-3 mb-4 small text-dark shadow-sm">
              <i class="bi bi-shield-check text-primary me-2 fs-5"></i><strong>Bảo vệ quyền lợi:</strong> Khi anh chọn ca, hệ thống sẽ tự động kiểm tra và khóa tạm thời (TTL 10 phút) ngay sau khi bấm xác nhận để tránh người khác đặt trùng.
            </div>

            <div class="mb-4" id="courtContainer">
              @if (ViewBag.Courts != null && ViewBag.Courts.Count > 0)
              {
                int index = 0;
                foreach (var c in ViewBag.Courts)
                {
                  string normCourtType = c.CourtTypeName ?? "";
                  if (normCourtType.Contains("Cầu Lông", StringComparison.OrdinalIgnoreCase)) normCourtType = "Sân Cầu Lông";
                  else if (normCourtType.Contains("Bóng Rổ", StringComparison.OrdinalIgnoreCase)) normCourtType = "Sân Bóng Rổ";
                  else if (normCourtType.Contains("Tennis", StringComparison.OrdinalIgnoreCase)) normCourtType = "Sân Tennis";
                  else if (normCourtType.Contains("Pickleball", StringComparison.OrdinalIgnoreCase)) normCourtType = "Sân Pickleball";
                  else if (normCourtType.Contains("Bóng Đá", StringComparison.OrdinalIgnoreCase)) normCourtType = "Sân Bóng Đá Mini";

                  <div class="card court-card rounded-4 mb-3 court-item" id="court_card_@c.CourtId" data-court-id="@c.CourtId" data-court-name="@c.CourtName" data-court-type="@normCourtType">
                    <div class="card-body p-3 p-md-4">
                      <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                        <div class="form-check mb-0">
                          <input class="form-check-input court-checkbox fs-5 mt-1" type="checkbox" value="@c.CourtId" id="court_@c.CourtId" data-court-id="@c.CourtId" data-court-name="@c.CourtName" data-court-type="@normCourtType" data-court-price="@((c.MinPrice ?? 150000m) * 2)">
                          <label class="form-check-label fw-bold fs-6 text-dark cursor-pointer ms-1" for="court_@c.CourtId">
                            @c.CourtName <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-2 small">@normCourtType</span>
                          </label>
                        </div>
                        <span class="text-success fw-bold small"><i class="bi bi-tag-fill me-1"></i>~@(((c.MinPrice ?? 150000m) * 2).ToString("N0"))đ/ca</span>
                      </div>

                      <div class="ps-md-4">
                        <label class="small fw-semibold text-secondary mb-2 d-block">Chọn các khung giờ thi đấu cho sân này:</label>
                        <div class="d-flex flex-wrap gap-2">
                          @if (ViewBag.TimeSlots != null && ViewBag.TimeSlots.Count > 0)
                          {
                            foreach (var s in ViewBag.TimeSlots)
                            {
                              <input type="checkbox" class="btn-check slot-checkbox" id="slot_@(s.SlotId)_@(c.CourtId)" value="@s.SlotId" data-court-id="@c.CourtId" data-slot-id="@s.SlotId" data-slot-name="@s.SlotName" autocomplete="off">
                              <label class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1.5 slot-label" id="label_slot_@(s.SlotId)_@(c.CourtId)" for="slot_@(s.SlotId)_@(c.CourtId)">
                                <i class="bi bi-clock me-1"></i>@s.SlotName
                              </label>
                            }
                          }
                          else
                          {
                            <input type="checkbox" class="btn-check slot-checkbox" id="slot_1_@c.CourtId" value="1" data-court-id="@c.CourtId" data-slot-id="1" data-slot-name="Sáng (07:00 - 09:00)">
                            <label class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1.5 slot-label" id="label_slot_1_@c.CourtId" for="slot_1_@c.CourtId">Sáng (07:00 - 09:00)</label>

                            <input type="checkbox" class="btn-check slot-checkbox" id="slot_2_@c.CourtId" value="2" data-court-id="@c.CourtId" data-slot-id="2" data-slot-name="Chiều (14:00 - 17:00)">
                            <label class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1.5 slot-label" id="label_slot_2_@c.CourtId" for="slot_2_@c.CourtId">Chiều (14:00 - 17:00)</label>

                            <input type="checkbox" class="btn-check slot-checkbox" id="slot_3_@c.CourtId" value="3" data-court-id="@c.CourtId" data-slot-id="3" data-slot-name="Tối (17:00 - 21:00)">
                            <label class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1.5 slot-label" id="label_slot_3_@c.CourtId" for="slot_3_@c.CourtId">Tối (17:00 - 21:00)</label>
                          }
                        </div>
                      </div>
                    </div>
                  </div>
                  index++;
                }
              }
              else
              {
                <div class="text-center py-5 bg-light rounded-4">
                  <i class="bi bi-exclamation-triangle-fill text-warning fs-1"></i>
                  <p class="text-dark fw-bold mt-3 mb-1">Hệ thống chưa có dữ liệu sân thi đấu.</p>
                  <p class="small text-muted mb-0">Vui lòng gọi API <code>POST /api/Seed/sample-data</code> trên Backend để khởi tạo ngay dữ liệu mẫu.</p>
                </div>
              }
            </div>

            <!-- 3. Services Section -->
            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-3-circle-fill text-primary me-2"></i>Dịch Vụ Phụ Trợ Đi Kèm (Tùy Chọn)</h5>
            <div class="bg-light p-4 rounded-4 mb-4 shadow-sm">
              <div class="d-flex flex-wrap gap-2 mb-3 pb-3 border-bottom">
                <span class="small text-muted align-self-center me-2"><i class="bi bi-funnel me-1"></i>Nhóm dịch vụ:</span>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill active svc-filter-btn" data-svc-filter="all">Tất Cả</button>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill svc-filter-btn" data-svc-filter="Thiết bị,Dụng cụ">Dụng Cụ Thi Đấu</button>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill svc-filter-btn" data-svc-filter="Giải khát">Nước Uống & Giải Khát</button>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill svc-filter-btn" data-svc-filter="Nhân sự,Sự kiện">Trọng Tài & Tổ Chức</button>
              </div>

              @if (ViewBag.Services != null && ViewBag.Services.Count > 0)
              {
                <div class="row g-3">
                  @foreach (var s in ViewBag.Services)
                  {
                    string sName = s.ServiceName ?? "";
                    string sCat = s.Category ?? "";
                    string sSport = "all";
                    if (sName.Contains("Cầu Lông", StringComparison.OrdinalIgnoreCase)) sSport = "Sân Cầu Lông";
                    else if (sName.Contains("Bóng Rổ", StringComparison.OrdinalIgnoreCase)) sSport = "Sân Bóng Rổ";
                    else if (sName.Contains("Tennis", StringComparison.OrdinalIgnoreCase)) sSport = "Sân Tennis";
                    else if (sName.Contains("Pickleball", StringComparison.OrdinalIgnoreCase)) sSport = "Sân Pickleball";
                    else if (sName.Contains("Bóng Đá", StringComparison.OrdinalIgnoreCase) || sName.Contains("Áo Bíp", StringComparison.OrdinalIgnoreCase)) sSport = "Sân Bóng Đá Mini";

                    <div class="col-md-6 service-item" data-sport-type="@sSport" data-category="@sCat">
                      <div class="card border rounded-3 bg-white p-3 h-100 d-flex flex-row justify-content-between align-items-center shadow-sm">
                        <div>
                          <div class="fw-bold text-dark">@s.ServiceName</div>
                          <div class="text-primary small fw-semibold">@s.Price.ToString("N0")đ / đơn vị (<span class="badge bg-secondary-subtle text-dark">@s.Category</span>)</div>
                        </div>
                        <div style="width: 110px;">
                          <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light fw-bold">SL</span>
                            <input type="number" class="form-control text-center fw-bold service-input" value="0" min="0" max="50" data-service-id="@s.ServiceId" data-service-name="@s.ServiceName" data-service-price="@s.Price" />
                          </div>
                        </div>
                      </div>
                    </div>
                  }
                </div>
              }
              else
              {
                <p class="text-muted text-center mb-0">Chưa có dịch vụ phụ trợ nào.</p>
              }
            </div>

            <!-- 4. Promotion & Notes -->
            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-4-circle-fill text-primary me-2"></i>Khuyến Mãi & Ghi Chú</h5>
            <div class="row g-3 mb-2">
              <div class="col-md-6">
                <label asp-for="PromotionCode" class="form-label fw-semibold text-dark">Mã ưu đãi (nếu có)</label>
                <input asp-for="PromotionCode" id="inputPromotionCode" class="form-control text-uppercase rounded-3 shadow-sm" placeholder="Nhập mã ưu đãi..." />
              </div>
              <div class="col-md-6">
                <label asp-for="Note" class="form-label fw-semibold text-dark">Ghi chú cho BQL sân</label>
                <input asp-for="Note" id="inputNote" class="form-control rounded-3 shadow-sm" placeholder="Yêu cầu hỗ trợ âm thanh, cờ phướn..." />
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Live Order Summary Box -->
      <div class="col-lg-4">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden sticky-summary">
          <div class="bg-dark text-white p-4">
            <h5 class="mb-0 fw-bold"><i class="bi bi-receipt-cutoff text-warning me-2"></i>Tóm Tắt Đăng Ký</h5>
            <p class="small text-white-50 mb-0 mt-1">Kiểm tra chi tiết sân & khung giờ trước khi xác nhận</p>
          </div>
          
          <div class="card-body p-4 bg-white">
            <div class="mb-3">
              <span class="text-muted small fw-semibold">TÊN GIẢI ĐẤU:</span>
              <div class="fw-bold text-dark fs-6" id="summaryTourName">Chưa nhập tên giải...</div>
            </div>
            
            <div class="mb-3 pb-3 border-bottom">
              <span class="text-muted small fw-semibold">NGÀY KHAI MẠC:</span>
              <div class="fw-semibold text-primary" id="summaryTourDate">@DateTime.Today.AddDays(7).ToString("dd/MM/yyyy")</div>
            </div>

            <!-- Selected Courts & Slots List -->
            <div class="mb-3">
              <span class="text-muted small fw-semibold d-block mb-2">SÂN & KHUNG GIỜ ĐÃ CHỌN:</span>
              <div id="summaryCourtsList">
                <div class="text-muted small fst-italic py-2 text-center bg-light rounded-3">Chưa có sân nào được chọn</div>
              </div>
            </div>

            <!-- Selected Services List -->
            <div class="mb-4 pb-3 border-bottom">
              <span class="text-muted small fw-semibold d-block mb-2">DỊCH VỤ PHỤ TRỢ:</span>
              <div id="summaryServicesList">
                <div class="text-muted small fst-italic py-1">Không sử dụng dịch vụ kèm</div>
              </div>
            </div>

            <!-- Summary totals -->
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="fw-bold text-dark">Số lượng sân/ca:</span>
              <span class="badge bg-primary rounded-pill fs-6 px-3 py-1" id="summaryCountBadge">0 ca</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-primary bg-opacity-10 rounded-3 border border-primary">
              <span class="fw-bold text-primary fs-6 mb-0">Tạm tính chi phí:</span>
              <span class="fw-black text-primary fs-4 mb-0" id="summaryTotalCost">0đ</span>
            </div>

            <div class="d-grid gap-2">
              <button type="button" id="btnSubmitTournament" class="btn btn-primary py-3 rounded-pill fw-bold shadow-lg d-flex align-items-center justify-content-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>Xác Nhận Đăng Ký
              </button>
              <a asp-action="MyTournaments" class="btn btn-light py-2 rounded-pill text-muted small fw-semibold text-center">Quay lại danh sách giải</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  <script>
    /** @@type {string} */
    let currentSportFilter = 'all';
    /** @@type {string} */
    let currentSvcCategory = 'all';

    document.addEventListener('DOMContentLoaded', initTournamentCreatePage);

    /**
     * Initializes the tournament creation page and binds all event listeners.
     */
    function initTournamentCreatePage() {
      setupDualFilters();
      setupCheckboxSync();
      setupSummaryListeners();
      setupFormSubmitListener();
      updateLiveSummary();
    }

    /**
     * Sets up click events for court type and service category buttons.
     */
    function setupDualFilters() {
      document.querySelectorAll('.filter-tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.filter-tab-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentSportFilter = btn.getAttribute('data-filter') || 'all';
          applyDualFilters();
        });
      });

      document.querySelectorAll('.svc-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.svc-filter-btn').forEach(b => {
            b.classList.remove('active', 'btn-secondary');
            b.classList.add('btn-outline-secondary');
          });
          btn.classList.remove('btn-outline-secondary');
          btn.classList.add('active', 'btn-secondary');
          currentSvcCategory = btn.getAttribute('data-svc-filter') || 'all';
          applyDualFilters();
        });
      });
    }

    /**
     * Filters court cards and service cards based on active sport and category.
     */
    function applyDualFilters() {
      document.querySelectorAll('.court-item').forEach(item => {
        const courtType = item.getAttribute('data-court-type');
        item.style.display = (currentSportFilter === 'all' || courtType === currentSportFilter) ? '' : 'none';
      });

      document.querySelectorAll('.service-item').forEach(item => {
        const sSport = item.getAttribute('data-sport-type') || 'all';
        const sCat = item.getAttribute('data-category') || '';
        const matchSport = (currentSportFilter === 'all' || sSport === 'all' || sSport === currentSportFilter);
        
        let matchCat = true;
        if (currentSvcCategory !== 'all') {
          const allowedCats = currentSvcCategory.split(',');
          matchCat = allowedCats.some(cat => sCat.toLowerCase().includes(cat.toLowerCase()));
        }
        item.style.display = (matchSport && matchCat) ? '' : 'none';
      });
    }

    /**
     * Syncs court checkboxes with slot checkboxes.
     */
    function setupCheckboxSync() {
      document.querySelectorAll('.slot-checkbox').forEach(slot => {
        slot.addEventListener('change', function () {
          const courtId = this.getAttribute('data-court-id');
          if (courtId) {
            const courtCheckbox = document.querySelector(`.court-checkbox[data-court-id="${courtId}"]`);
            if (courtCheckbox) {
              const anySlotChecked = document.querySelectorAll(`.slot-checkbox[data-court-id="${courtId}"]:checked`).length > 0;
              courtCheckbox.checked = anySlotChecked;
            }
          }
          updateLiveSummary();
        });
      });

      document.querySelectorAll('.court-checkbox').forEach(court => {
        court.addEventListener('change', function () {
          const courtId = this.getAttribute('data-court-id');
          if (!this.checked && courtId) {
            document.querySelectorAll(`.slot-checkbox[data-court-id="${courtId}"]`).forEach(s => s.checked = false);
          }
          updateLiveSummary();
        });
      });
    }

    /**
     * Binds input listeners for live summary updates.
     */
    function setupSummaryListeners() {
      const inputName = document.getElementById('inputTournamentName');
      const inputDate = document.getElementById('inputBookingDate');
      if (inputName) inputName.addEventListener('input', updateLiveSummary);
      if (inputDate) inputDate.addEventListener('change', updateLiveSummary);
      document.querySelectorAll('.service-input').forEach(si => si.addEventListener('input', updateLiveSummary));
    }

    /**
     * Recalculates selected slots count and estimated cost, updating summary DOM.
     */
    function updateLiveSummary() {
      const inputName = document.getElementById('inputTournamentName');
      const inputDate = document.getElementById('inputBookingDate');
      if (inputName) document.getElementById('summaryTourName').textContent = inputName.value || 'Chưa nhập tên giải...';
      if (inputDate && inputDate.value) {
        const parts = inputDate.value.split('-');
        document.getElementById('summaryTourDate').textContent = `${parts[2]}/${parts[1]}/${parts[0]}`;
      }

      let totalSlotsCount = 0;
      let estimatedCost = 0;
      let courtsHtml = '';

      document.querySelectorAll('.court-checkbox:checked').forEach(c => {
        const courtId = c.getAttribute('data-court-id');
        const courtName = c.getAttribute('data-court-name');
        const courtPrice = parseFloat(c.getAttribute('data-court-price')) || 300000;
        const checkedSlots = document.querySelectorAll(`.slot-checkbox[data-court-id="${courtId}"]:checked`);

        if (checkedSlots.length > 0) {
          let slotNames = [];
          checkedSlots.forEach(s => {
            slotNames.push(s.getAttribute('data-slot-name'));
            totalSlotsCount++;
            estimatedCost += courtPrice;
          });

          courtsHtml += `
            <div class="p-2 mb-2 bg-light rounded-3 border-start border-primary border-4 shadow-sm">
              <div class="fw-bold text-dark small">${courtName}</div>
              <div class="text-primary" style="font-size: 0.8rem;"><i class="bi bi-clock-history me-1"></i>${slotNames.join(', ')}</div>
            </div>
          `;
        }
      });

      const courtsContainer = document.getElementById('summaryCourtsList');
      if (courtsContainer) courtsContainer.innerHTML = courtsHtml || '<div class="text-muted small fst-italic py-2 text-center bg-light rounded-3">Chưa có sân nào được chọn</div>';

      let servicesHtml = '';
      document.querySelectorAll('.service-input').forEach(si => {
        const qty = parseInt(si.value) || 0;
        if (qty > 0) {
          const sName = si.getAttribute('data-service-name');
          const sPrice = parseFloat(si.getAttribute('data-service-price')) || 0;
          estimatedCost += (qty * sPrice);
          servicesHtml += `<div class="d-flex justify-content-between small py-1"><span class="text-dark">${sName}</span><span class="fw-bold text-primary">x${qty}</span></div>`;
        }
      });

      const servicesContainer = document.getElementById('summaryServicesList');
      if (servicesContainer) servicesContainer.innerHTML = servicesHtml || '<div class="text-muted small fst-italic py-1">Không sử dụng dịch vụ kèm</div>';

      const countBadge = document.getElementById('summaryCountBadge');
      const totalEl = document.getElementById('summaryTotalCost');
      if (countBadge) countBadge.textContent = `${totalSlotsCount} ca`;
      if (totalEl) totalEl.textContent = estimatedCost.toLocaleString('vi-VN') + 'đ';
    }

    /**
     * Binds click listener to the submit button.
     */
    function setupFormSubmitListener() {
      const btnSubmit = document.getElementById('btnSubmitTournament');
      if (btnSubmit) {
        btnSubmit.addEventListener('click', handleFormSubmit);
      }
    }

    /**
     * Handles tournament registration submission via AJAX Fetch API.
     * @@param {Event} e The click event.
     */
    async function handleFormSubmit(e) {
      e.preventDefault();
      hideConflictBanner();

      const inputName = document.getElementById('inputTournamentName');
      const inputDate = document.getElementById('inputBookingDate');
      if (!inputName || !inputName.value.trim() || !inputDate || !inputDate.value) {
        alert('Vui lòng nhập đầy đủ tên giải đấu và ngày khai mạc!');
        if (inputName) inputName.focus();
        return;
      }

      const payload = buildTournamentPayload();
      if (payload.courtSelections.length === 0) {
        alert('Vui lòng chọn ít nhất 1 sân thi đấu và 1 khung giờ tương ứng!');
        return;
      }

      await submitTournamentAjax(payload);
    }

    /**
     * Collects form selections into a clean JSON payload matching CreateTournamentFormDto.
     * @@returns {Object} The formatted payload object.
     */
    function buildTournamentPayload() {
      const inputName = document.getElementById('inputTournamentName');
      const inputDate = document.getElementById('inputBookingDate');
      const inputPromo = document.getElementById('inputPromotionCode');
      const inputNote = document.getElementById('inputNote');

      const courtSelections = [];
      document.querySelectorAll('.court-checkbox:checked').forEach(cBox => {
        const courtId = parseInt(cBox.getAttribute('data-court-id')) || 0;
        const checkedSlots = document.querySelectorAll(`.slot-checkbox[data-court-id="${courtId}"]:checked`);
        if (checkedSlots.length > 0) {
          const slotIds = Array.from(checkedSlots).map(s => parseInt(s.value));
          courtSelections.push({ courtId: courtId, slotIds: slotIds });
        }
      });

      const services = [];
      document.querySelectorAll('.service-input').forEach(sInp => {
        const qty = parseInt(sInp.value) || 0;
        if (qty > 0) {
          const serviceId = parseInt(sInp.getAttribute('data-service-id')) || 0;
          services.push({ serviceId: serviceId, quantity: qty });
        }
      });

      return {
        tournamentName: inputName ? inputName.value.trim() : '',
        description: document.getElementById('inputDescription') ? document.getElementById('inputDescription').value.trim() : '',
        bookingDate: inputDate ? inputDate.value : '',
        promotionCode: inputPromo ? inputPromo.value.trim() : null,
        note: inputNote ? inputNote.value.trim() : null,
        courtSelections: courtSelections,
        services: services
      };
    }

    /**
     * Sends payload via fetch API to CreateJson endpoint.
     * @@param {Object} payload The tournament payload object.
     */
    async function submitTournamentAjax(payload) {
      const btnSubmit = document.getElementById('btnSubmitTournament');
      const originalText = btnSubmit ? btnSubmit.innerHTML : 'Xác Nhận Đăng Ký';
      if (btnSubmit) {
        btnSubmit.disabled = true;
        btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang khóa ca & giữ chỗ...';
      }

      try {
        const response = await fetch('/Tournaments/CreateJson', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getAntiForgeryToken()
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();
        if (response.ok && result.success) {
          window.location.href = result.redirectUrl;
        } else if (response.status === 409 || !result.success) {
          handleBookingConflict(result.message || 'Khung giờ chọn đã bị trùng hoặc giữ chỗ.');
        } else {
          alert(result.message || 'Đã xảy ra lỗi không xác định.');
        }
      } catch (error) {
        console.error('AJAX Error:', error);
        alert('Không kết nối được đến máy chủ. Vui lòng kiểm tra lại mạng!');
      } finally {
        if (btnSubmit) {
          btnSubmit.disabled = false;
          btnSubmit.innerHTML = originalText;
        }
      }
    }

    /**
     * Retrieves CSRF token from hidden form input.
     * @@returns {string} The anti-forgery token value.
     */
    function getAntiForgeryToken() {
      const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
      return tokenInput ? tokenInput.value : '';
    }

    /**
     * Handles 409 Conflict without reloading page and highlights conflicting courts/slots in red.
     * @@param {string} errorMessage The conflict error message from server.
     */
    function handleBookingConflict(errorMessage) {
      const banner = document.getElementById('conflictAlertBanner');
      const msgEl = document.getElementById('conflictAlertMessage');
      if (banner && msgEl) {
        msgEl.textContent = errorMessage;
        banner.classList.remove('d-none');
        banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      document.querySelectorAll('.court-card').forEach(card => {
        const courtName = card.getAttribute('data-court-name') || '';
        if (errorMessage.includes(courtName)) {
          card.classList.add('conflict-highlight');
          card.querySelectorAll('.slot-checkbox').forEach(slot => {
            const slotName = slot.getAttribute('data-slot-name') || '';
            if (errorMessage.includes(slotName)) {
              const label = document.getElementById(`label_slot_${slot.value}_${card.getAttribute('data-court-id')}`);
              if (label) label.classList.add('conflict-slot');
            }
          });
        }
      });
    }

    /**
     * Hides the conflict banner and removes red highlights.
     */
    function hideConflictBanner() {
      const banner = document.getElementById('conflictAlertBanner');
      if (banner) banner.classList.add('d-none');
      document.querySelectorAll('.conflict-highlight').forEach(el => el.classList.remove('conflict-highlight'));
      document.querySelectorAll('.conflict-slot').forEach(el => el.classList.remove('conflict-slot'));
    }
  </script>
}
