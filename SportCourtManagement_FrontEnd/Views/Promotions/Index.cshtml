@model SportCourtManagement_FrontEnd.Models.Promotions.PromotionListViewModel
@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    Layout = (userRole == "Manager" || userRole == "Owner") ? "_ManagerLayout" : "_AdminLayout";
    ViewData["Title"] = "Quản lý Chương trình Khuyến mãi";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-tags text-primary me-2"></i>Quản lý Khuyến mãi</h1>
        <p class="page-subtitle">Quản lý các mã giảm giá và chiến dịch ưu đãi cho khách hàng</p>
    </div>
    <a asp-action="Create" class="btn btn-primary fw-semibold shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Tạo khuyến mãi mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4 bg-dark text-success border-success">
        <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-4 bg-dark text-danger border-danger">
        <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-card p-4 mb-4">
    <form method="get" asp-action="Index" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label small text-secondary fw-semibold">Từ khóa tìm kiếm</label>
            <input type="text" name="keyword" value="@Model.Keyword" class="form-control bg-dark text-white border-secondary" placeholder="Mã khuyến mãi hoặc tên chương trình..." />
        </div>
        <div class="col-md-4">
            <label class="form-label small text-secondary fw-semibold">Trạng thái hoạt động</label>
            <select name="isActive" class="form-select bg-dark text-white border-secondary">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="true" selected="@(Model.IsActive == true)">Đang kích hoạt</option>
                <option value="false" selected="@(Model.IsActive == false)">Đã khóa / Hết hạn</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 fw-semibold"><i class="fa-solid fa-filter me-1"></i> Lọc</button>
            <a asp-action="Index" class="btn-ghost text-secondary text-decoration-none px-3 py-2">Đặt lại</a>
        </div>
    </form>
</div>

@if (Model.PagedData.Items == null || !Model.PagedData.Items.Any())
{
    <div class="empty-state py-5 text-center">
        <i class="fa-solid fa-gift fs-1 text-secondary d-block mb-3"></i>
        <p class="text-secondary">Chưa có dữ liệu chương trình khuyến mãi nào.</p>
    </div>
}
else
{
    <div class="admin-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Mã CODE</th>
                    <th>Tên chương trình</th>
                    <th>Mức giảm</th>
                    <th>Đơn tối thiểu</th>
                    <th>Thời gian áp dụng</th>
                    <th>Đã dùng</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.PagedData.Items)
                {
                    <tr>
                        <td>
                            <span class="type-badge type-default fw-bold text-white fs-6">@item.PromoCode</span>
                        </td>
                        <td class="fw-semibold text-white">@item.PromoName</td>
                        <td>
                            <span class="text-success fw-bold">
                                @(item.DiscountType == SportCourtManagement_FrontEnd.Models.Promotions.DiscountType.Percent ? $"{item.DiscountValue}%" : $"{item.DiscountValue:N0}đ")
                            </span>
                        </td>
                        <td class="text-secondary">@item.MinOrderAmount.ToString("N0")đ</td>
                        <td>
                            <div class="small text-secondary">Từ: @item.StartDate.ToString("dd/MM/yyyy")</div>
                            <div class="small text-secondary">Đến: @item.EndDate.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td>
                            <span class="type-badge">@item.UsedCount / @(item.UsageLimit?.ToString() ?? "∞")</span>
                        </td>
                        <td>
                            @if (item.IsActive && item.EndDate >= DateTime.UtcNow)
                            {
                                <span class="status-badge status-available">Hoạt động</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Ngừng hoạt động</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.PromotionId" class="btn-ghost me-1 text-primary" title="Sửa">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.PromotionId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa khuyến mãi này?');">
                                <button type="submit" class="btn-ghost text-danger" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PagedData.TotalPages > 1)
    {
        <div class="pagination-custom mt-4">
            @for (int i = 1; i <= Model.PagedData.TotalPages; i++)
            {
                <a asp-action="Index" asp-route-page="@i" asp-route-keyword="@Model.Keyword" asp-route-isActive="@Model.IsActive" class="@(i == Model.PagedData.PageNumber ? "active" : "")">@i</a>
            }
        </div>
    }
}
